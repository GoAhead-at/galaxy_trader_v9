<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_FleetReplacement" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <!--
    Bridges the vanilla fleet reconstitution system into GT-controlled fleets.

    Vanilla raises the 'reconstitute_fleet' signal only from a small set of AI scripts
    (orders.base, order.wait, order.move.follow, order.fight.escort, fight.attack.object.station)
    and only when the firing ship is itself a top-level commander (no commander, no fleetunit).
    GT miners/traders run infinite custom orders and are commonly subordinated to a station,
    so neither condition is met for their fleets and lost subordinate slots never get rebuilt
    by Fleet_Reconstitution.ProcessRequest.

    This script raises 'reconstitute_fleet' from the destruction event of any player-owned
    subordinate. The vanilla cue Fleet_Reconstitution.ProcessRequest then walks up to
    toplevelcommander, picks the closest reachable player shipyard with the right macro and
    loadout equipment, and queues the rebuild; on completion it ships the replacement back
    via MoveToObject(joinfleet=true) and reinstate_fleet_ship slots it into the original
    fleet position. No other glue is needed.

    Composition with existing GT destruction handlers in gt_core_system.xml:
      - UnregisterShip          : cleans GT registries on any destroyed player object.
      - HandleCommanderDestroyed: handles promotion when a commander dies.
      - This cue                : only fires when the destroyed object had a commander
                                  (i.e. was a subordinate), so it never overlaps with
                                  HandleCommanderDestroyed (which acts on top-level deaths).
  -->
  <cues>

    <cue name="Init" version="1" instantiate="true">
      <conditions>
        <check_any>
          <event_player_created/>
          <event_game_loaded/>
        </check_any>
        <check_value value="not global.$GT_LastReconstituteSignal?"/>
      </conditions>
      <actions>
        <set_value name="global.$GT_LastReconstituteSignal" exact="table[]" comment="Per-commander cooldown timestamps (player.age) for the reconstitute_fleet signal"/>
      </actions>
    </cue>

    <cue name="RequestFleetReconstitution" instantiate="true">
      <conditions>
        <event_object_destroyed object="player.entity"/>
        <check_value value="event.object.commander?"/>
      </conditions>
      <delay exact="500ms"/>
      <actions>
        <set_value name="$commander" exact="event.object.commander"/>
        <do_if value="$commander? and $commander.exists and $commander.isoperational and @$commander.fleetunits.count">
          <set_value name="$shouldSignal" exact="false"/>
          <do_if value="not global.$GT_LastReconstituteSignal?">
            <set_value name="global.$GT_LastReconstituteSignal" exact="table[]"/>
            <set_value name="$shouldSignal" exact="true"/>
          </do_if>
          <do_elseif value="not global.$GT_LastReconstituteSignal.{$commander}?">
            <set_value name="$shouldSignal" exact="true"/>
          </do_elseif>
          <do_elseif value="(player.age - global.$GT_LastReconstituteSignal.{$commander}) gt 1s">
            <set_value name="$shouldSignal" exact="true"/>
          </do_elseif>
          <do_if value="$shouldSignal">
            <set_value name="global.$GT_LastReconstituteSignal.{$commander}" exact="player.age"/>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT-FleetReplacement] Requesting fleet reconstitution: commander=' + @$commander.knownname + ' [' + @$commander.idcode + '], tracked slots=' + $commander.fleetunits.count" chance="100"/>
            </do_if>
            <signal_objects object="player.entity" param="'reconstitute_fleet'" param2="$commander" param3="$commander.fleetunits"/>
          </do_if>
        </do_if>
      </actions>
    </cue>

  </cues>
</mdscript>
