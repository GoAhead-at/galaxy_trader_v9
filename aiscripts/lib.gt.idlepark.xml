<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.idlepark" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Idle parking helpers for GT traders/miners (non-blocking: trader default order keeps searching).
    Modes: is_active | trigger | check_timed_release
    Do NOT run_script order.gt.idlepark for helpers — order params are validated at game load.
  -->
  <params>
    <param name="handoffMode" default="''"/>
    <param name="handoffShip" default="this.ship"/>
    <param name="home" default="null"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="$handoffMode == 'is_active'">
        <set_value name="$parkShip" exact="$handoffShip"/>
        <set_value name="$isActive" exact="false"/>
        <do_if value="global.$GT_IdleParkingHold? and global.$GT_IdleParkingHold.{$parkShip}?">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.order? and @$parkShip.order.id == 'GTIdlePark'">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.order? and @$parkShip.order.id == 'DockAndWait' and $parkShip.order.$callerid? and @$parkShip.order.$callerid.id == 'GTIdlePark'">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.orders.count gt 0">
          <do_all exact="$parkShip.orders.count" counter="$ipoi">
            <set_value name="$ipOrder" exact="$parkShip.orders.{$ipoi}"/>
            <do_if value="@$ipOrder.id == 'GTIdlePark'">
              <set_value name="$isActive" exact="true"/>
              <break/>
            </do_if>
            <do_elseif value="@$ipOrder.id == 'DockAndWait' and $ipOrder.$callerid? and @$ipOrder.$callerid.id == 'GTIdlePark'">
              <set_value name="$isActive" exact="true"/>
              <break/>
            </do_elseif>
          </do_all>
        </do_if>
        <return value="$isActive"/>
      </do_if>

      <do_if value="$handoffMode == 'trigger'">
        <set_value name="$parkShip" exact="$handoffShip"/>
        <set_value name="$isActive" exact="false"/>
        <do_if value="global.$GT_IdleParkingHold? and global.$GT_IdleParkingHold.{$parkShip}?">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.order? and @$parkShip.order.id == 'GTIdlePark'">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.order? and @$parkShip.order.id == 'DockAndWait' and $parkShip.order.$callerid? and @$parkShip.order.$callerid.id == 'GTIdlePark'">
          <set_value name="$isActive" exact="true"/>
        </do_if>
        <do_if value="not $isActive and $parkShip.orders.count gt 0">
          <do_all exact="$parkShip.orders.count" counter="$ipoi">
            <set_value name="$ipOrder" exact="$parkShip.orders.{$ipoi}"/>
            <do_if value="@$ipOrder.id == 'GTIdlePark'">
              <set_value name="$isActive" exact="true"/>
              <break/>
            </do_if>
            <do_elseif value="@$ipOrder.id == 'DockAndWait' and $ipOrder.$callerid? and @$ipOrder.$callerid.id == 'GTIdlePark'">
              <set_value name="$isActive" exact="true"/>
              <break/>
            </do_elseif>
          </do_all>
        </do_if>
        <do_if value="$isActive">
          <return value="false"/>
        </do_if>
        <do_if value="not $home? or not $home.exists">
          <return value="false"/>
        </do_if>
        <set_value name="$releaseMinutes" exact="1"/>
        <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Fleet?">
          <do_all exact="global.$GT_GlobalSettings.$Fleet.keys.count" counter="$fki">
            <set_value name="$fleetKey" exact="global.$GT_GlobalSettings.$Fleet.keys.{$fki}"/>
            <do_if value="$fleetKey == '$IdleParkingReleaseMinutes'">
              <set_value name="$releaseMinutes" exact="[[global.$GT_GlobalSettings.$Fleet.{$fleetKey}, 0].max, 60].min"/>
            </do_if>
          </do_all>
        </do_if>
        <do_if value="not global.$GT_IdleParkingHold?">
          <set_value name="global.$GT_IdleParkingHold" exact="table[]"/>
        </do_if>
        <do_if value="not global.$GT_IdleParkingHoldUntil?">
          <set_value name="global.$GT_IdleParkingHoldUntil" exact="table[]"/>
        </do_if>
        <set_value name="global.$GT_IdleParkingHold.{$parkShip}" exact="true"/>
        <do_if value="$releaseMinutes gt 0">
          <set_value name="global.$GT_IdleParkingHoldUntil.{$parkShip}" exact="player.age + $releaseMinutes * 1min"/>
        </do_if>
        <do_else>
          <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{$parkShip}?">
            <remove_value name="global.$GT_IdleParkingHoldUntil.{$parkShip}"/>
          </do_if>
        </do_else>
        <debug_text text="'[GT-IdlePark] ' + $parkShip.idcode + ': idle parking threshold reached - parking at ' + $home.knownname" chance="$debugchance"/>
        <create_order name="$idleParkOrder" object="$parkShip" id="'GTIdlePark'" immediate="false">
          <param name="home" value="$home"/>
          <param name="debugchance" value="$debugchance"/>
        </create_order>
        <return value="true"/>
      </do_if>

      <do_if value="$handoffMode == 'check_timed_release'">
        <set_value name="$parkShip" exact="if $handoffShip? and $handoffShip.exists then $handoffShip else this.ship"/>
        <do_if value="global.$GT_IdleParkingHold? and global.$GT_IdleParkingHold.{$parkShip}? and global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{$parkShip}? and player.age ge global.$GT_IdleParkingHoldUntil.{$parkShip}">
          <remove_value name="global.$GT_IdleParkingHold.{$parkShip}"/>
          <remove_value name="global.$GT_IdleParkingHoldUntil.{$parkShip}"/>
          <do_if value="global.$GT_IdleParkingDockedSince? and global.$GT_IdleParkingDockedSince.{$parkShip}?">
            <remove_value name="global.$GT_IdleParkingDockedSince.{$parkShip}"/>
          </do_if>
          <set_value name="global.$GT_IdleParkingReleased.{$parkShip}" exact="true"/>
          <debug_text text="'[GT-IdlePark] ' + $parkShip.idcode + ': timed idle release - undocking to free port'" chance="$debugchance"/>
          <do_if value="$parkShip.dock or $parkShip.parkedat">
            <create_order object="$parkShip" id="'Undock'" immediate="true"/>
          </do_if>
        </do_if>
        <return value="true"/>
      </do_if>

      <return value="false"/>
    </actions>
  </attention>
</aiscript>
