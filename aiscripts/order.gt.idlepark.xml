<?xml version="1.0" encoding="utf-8"?>
<aiscript name="order.gt.idlepark" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <order id="GTIdlePark" name="{77000, 1096}" description="{77000, 1097}" category="navigation" infinite="false">
    <params>
      <param name="home" type="object" text="{77000, 1002}" comment="{77000, 1020}">
        <input_param name="class" value="[class.station,class.sector]"/>
      </param>
      <param name="debugchance" default="0" type="number" text="{1001, 9074}" comment="{1001, 9075}">
        <input_param name="min" value="0"/>
        <input_param name="max" value="100"/>
      </param>
    </params>
    <requires>
      <match shiptype="shiptype.lasertower" negate="true"/>
    </requires>
    <location object="$home" condition="@$home.exists"/>
  </order>

  <interrupts>
    <handler ref="TargetInvalidHandler"/>
    <handler ref="AttackHandler"/>
  </interrupts>

  <init>
    <set_order_syncpoint_reached order="this.ship.order"/>
    <set_command command="command.wait"/>
    <set_command_action commandaction="commandaction.standingby"/>
  </init>

  <attention min="unknown">
    <actions>
      <do_if value="not $home? or not $home.exists">
        <set_command_action commandaction="commandaction.orderfailed"/>
        <return/>
      </do_if>

      <do_if value="not global.$GT_IdleParkingHold?">
        <set_value name="global.$GT_IdleParkingHold" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_IdleParkingHoldUntil?">
        <set_value name="global.$GT_IdleParkingHoldUntil" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_IdleParkingDockedSince?">
        <set_value name="global.$GT_IdleParkingDockedSince" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_IdleParkingReleased?">
        <set_value name="global.$GT_IdleParkingReleased" exact="table[]"/>
      </do_if>

      <set_value name="$parkStation" exact="null"/>
      <set_value name="$parkSector" exact="null"/>

      <do_if value="$home.isclass.station">
        <set_value name="$parkStation" exact="$home"/>
        <set_value name="$parkSector" exact="$home.sector"/>
      </do_if>
      <do_elseif value="$home.isclass.sector">
        <set_value name="$parkSector" exact="$home"/>
      </do_elseif>

      <do_if value="$parkStation? and $parkStation != null and $parkStation.exists">
        <find_dockingbay name="$homeDock" object="$parkStation" checkoperational="true" multiple="false">
          <match_dock size="this.ship.docksize" storage="false"/>
        </find_dockingbay>
        <do_if value="not $homeDock?">
          <set_value name="$parkStation" exact="null"/>
        </do_if>
        <remove_value name="$homeDock"/>
      </do_if>

      <do_if value="(not $parkStation? or $parkStation == null) and $parkSector? and $parkSector.exists">
        <find_station name="$sectorStations" space="$parkSector" checkoperational="true" multiple="true"/>
        <set_value name="$stationIndex" exact="1"/>
        <do_while value="$sectorStations? and $stationIndex le $sectorStations.count and (not $parkStation? or $parkStation == null)">
          <set_value name="$candidateStation" exact="$sectorStations.{$stationIndex}"/>
          <do_if value="$candidateStation? and $candidateStation.exists and $candidateStation.isclass.station and $candidateStation.isoperational and $candidateStation.isplayerowned">
            <find_dockingbay name="$candidateDock" object="$candidateStation" checkoperational="true" multiple="false">
              <match_dock size="this.ship.docksize" storage="false"/>
            </find_dockingbay>
            <do_if value="$candidateDock?">
              <set_value name="$parkStation" exact="$candidateStation"/>
            </do_if>
            <remove_value name="$candidateDock"/>
          </do_if>
          <set_value name="$stationIndex" operation="add"/>
        </do_while>
        <set_value name="$stationIndex" exact="1"/>
        <do_while value="$sectorStations? and $stationIndex le $sectorStations.count and (not $parkStation? or $parkStation == null)">
          <set_value name="$candidateStation" exact="$sectorStations.{$stationIndex}"/>
          <do_if value="$candidateStation? and $candidateStation.exists and $candidateStation.isclass.station and $candidateStation.isoperational and not $candidateStation.isplayerowned and (not @$candidateStation.owner or not this.ship.hasrelation.enemy.{@$candidateStation.owner})">
            <find_dockingbay name="$candidateDock" object="$candidateStation" checkoperational="true" multiple="false">
              <match_dock size="this.ship.docksize" storage="false"/>
            </find_dockingbay>
            <do_if value="$candidateDock?">
              <set_value name="$parkStation" exact="$candidateStation"/>
            </do_if>
            <remove_value name="$candidateDock"/>
          </do_if>
          <set_value name="$stationIndex" operation="add"/>
        </do_while>
        <remove_value name="$sectorStations"/>
        <remove_value name="$stationIndex"/>
        <do_if value="$candidateStation?">
          <remove_value name="$candidateStation"/>
        </do_if>
      </do_if>

      <do_if value="$parkStation? and $parkStation != null and $parkStation.exists">
        <set_value name="$alreadyDocked" exact="(this.ship.dock and this.ship.dock.container == $parkStation) or (this.ship.parkedat and ((this.ship.parkedat == $parkStation) or this.ship.parkedat.hascontext.{$parkStation}))"/>
        <do_if value="not $alreadyDocked">
          <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': parking at station ' + $parkStation.knownname" chance="$debugchance"/>
          <create_order name="$dockOrder" id="'DockAndWait'" object="this.ship" immediate="true">
            <param name="destination" value="$parkStation"/>
            <param name="building" value="false"/>
            <param name="trading" value="true"/>
            <param name="dockfollowers" value="false"/>
            <param name="allowplayeronly" value="true"/>
            <param name="callerid" value="this.ship.order"/>
            <param name="debugchance" value="$debugchance"/>
          </create_order>
          <wait>
            <interrupt>
              <conditions>
                <event_object_order_ready object="this.ship" order="$dockOrder"/>
              </conditions>
            </interrupt>
          </wait>
        </do_if>

        <set_value name="$isDockedAtParkStation" exact="(this.ship.dock and this.ship.dock.container == $parkStation) or (this.ship.parkedat and ((this.ship.parkedat == $parkStation) or this.ship.parkedat.hascontext.{$parkStation}))"/>
        <do_if value="$isDockedAtParkStation">
          <set_value name="global.$GT_IdleParkingHold.{this.ship}" exact="true"/>
          <set_value name="global.$GT_IdleParkingHoldUntil.{this.ship}" exact="player.age + 6h"/>
          <do_if value="not global.$GT_IdleParkingDockedSince.{this.ship}?">
            <set_value name="global.$GT_IdleParkingDockedSince.{this.ship}" exact="player.age"/>
          </do_if>
          <set_command_action commandaction="commandaction.standingby"/>
          <wait exact="60s"/>
          <do_if value="global.$GT_IdleParkingHold? and global.$GT_IdleParkingHold.{this.ship}?">
            <remove_value name="global.$GT_IdleParkingHold.{this.ship}"/>
          </do_if>
          <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">
            <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>
          </do_if>
          <do_if value="global.$GT_IdleParkingDockedSince? and global.$GT_IdleParkingDockedSince.{this.ship}?">
            <remove_value name="global.$GT_IdleParkingDockedSince.{this.ship}"/>
          </do_if>
          <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>
          <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': docked idle release after 60s - undocking to free port'" chance="$debugchance"/>
          <create_order object="this.ship" id="'Undock'" immediate="true"/>
          <wait max="30s">
            <interrupt>
              <conditions>
                <event_object_order_ready object="this.ship"/>
              </conditions>
            </interrupt>
          </wait>
        </do_if>
        <return/>
      </do_if>

      <do_if value="$parkSector? and $parkSector.exists">
        <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': no dockable station in home sector - moving to sector ' + $parkSector.knownname" chance="$debugchance"/>
        <run_script name="'move.generic'" result="$moveSuccess">
          <param name="destination" value="$parkSector"/>
          <param name="position" value="$parkSector.coreposition"/>
          <param name="endintargetzone" value="true"/>
          <param name="debugchance" value="$debugchance"/>
        </run_script>
        <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>
        <set_command_action commandaction="commandaction.standingby"/>
        <return/>
      </do_if>

      <set_command_action commandaction="commandaction.orderfailed"/>
    </actions>
  </attention>
</aiscript>
