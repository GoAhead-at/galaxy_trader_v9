<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.emit_gt_state_changed" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Fires the matched pair of state-change signals that every GT order
    assignment / cancellation site emits:
      1) `GT_Ship_State_Update`         (UI / fleet-roster MD listener)
      2) `GT_Commander_GT_State_Changed`(commander-graph MD listener)

    Both signals carry the ship as the affected entity, the boolean
    `IsGTActive` flag, the current subordinate count snapshot, and a free-form
    `source` tag so MD-side traces can attribute each emission to the AI
    site that produced it.

    Replaces 4 inline emit pairs in MK3 init / main_loop (`AI_INIT_ASSIGN`,
    `AI_INIT_REASSIGN`, `AI_LOOP_REASSIGN`, `AI_LOOP_CANCEL`) and 4 more in
    MK4. The payloads are byte-identical aside from the `source` string,
    making this the highest-payoff dedup of the attention-lifecycle group.
    See DOCS/MK3_PIPELINE_REFACTOR.md §3.11.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="isGTActive" default="true"/>
    <param name="source" default="'AI_UNSPECIFIED'"/>
    <param name="updateType" default="if $isGTActive then 'GT_Order_Assigned' else 'GT_Order_Cancelled'"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists">
        <return/>
      </do_if>

      <set_value name="$subordinateCount" exact="if $ship.allsubordinates? then @$ship.allsubordinates.count else 0"/>

      <do_if value="$isGTActive">
        <signal_objects object="player.galaxy" param="'GT_Ship_State_Update'" param2="table[
          $Ship = $ship,
          $UpdateType = $updateType,
          $MacroShipName = @$ship.macro.name
        ]"/>
      </do_if>
      <do_else>
        <signal_objects object="player.galaxy" param="'GT_Ship_State_Update'" param2="table[
          $Ship = $ship,
          $UpdateType = $updateType
        ]"/>
      </do_else>

      <signal_objects object="player.galaxy" param="'GT_Commander_GT_State_Changed'" param2="table[
        $Commander = $ship,
        $IsGTActive = $isGTActive,
        $SubordinateCount = $subordinateCount,
        $Source = $source
      ]"/>
    </actions>
  </attention>
</aiscript>
