<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.autojump_distance_toggle" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Detects false -> true transition on autoJumpDistanceByLevel and signals MD for one-shot tier-max sync.
    Save-load baseline is set via per-order script patch (this.$prevAutoJumpDistance) so existing
    enabled orders do not sync on first main-loop tick after load.
  -->
  <params>
    <param name="autoJumpDistanceByLevel" default="false"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $autoJumpDistanceByLevel?">
        <set_value name="$autoJumpDistanceByLevel" exact="false"/>
      </do_if>

      <do_if value="not this.$prevAutoJumpDistance?">
        <set_value name="this.$prevAutoJumpDistance" exact="$autoJumpDistanceByLevel"/>
      </do_if>
      <do_elseif value="$autoJumpDistanceByLevel and not this.$prevAutoJumpDistance">
        <signal_objects object="player.galaxy" param="'GT_AutoJumpDistance_Apply'" param2="table[
          $Ship = this.ship,
          $Reason = 'checkbox_enabled'
        ]"/>
      </do_elseif>
      <set_value name="this.$prevAutoJumpDistance" exact="$autoJumpDistanceByLevel"/>
    </actions>
  </attention>
</aiscript>
