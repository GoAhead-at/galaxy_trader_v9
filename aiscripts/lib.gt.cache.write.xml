<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.cache.write" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="2">
  <!-- Writes trade results into the global trade cache with sorted insertion (by Score descending).
       Runs in AI script context so <wait> can be used to yield between insertions,
       preventing frame drops while maintaining sort order atomically per entry.

       cachePool selects the storage bucket: mk3 (GalaxyTraderMK3) or mk4 (GalaxyTraderMK4Supply).

       Each insertion (linear search + insert) runs without yielding = atomic.
       Yields happen only BETWEEN entries, so concurrent writers to the same
       home sector cache see consistent state at each insertion boundary.

       Also performs write-time cleanup of expired/dead entries before insertion. -->
  <params>
    <param name="cachePool" default="'mk3'" comment="Trade cache pool: mk3 (traders) or mk4 (supply)"/>
    <param name="tradeList" default="[]"/>
    <param name="homeSector"/>
    <param name="cacheTTL" default="300s"/>
    <param name="maxSearchDistance" default="0"/> <!-- For per-pool max-distance metadata tracking -->
    <param name="cacheDropoffTolerance" default="15"/> <!-- Accepted at call site for API compat; band filter is read-time only (lib.gt.cache.search). -->
    <param name="sellPriceMax" default="1.0" comment="Unused at write; per-ship band filter runs at cache read."/>
    <param name="buyPriceMin" default="-1.0" comment="Unused at write; per-ship band filter runs at cache read."/>
    <param name="debugchance" default="0"/>
  </params>
  <patch sinceversion="2">
    <do_if value="not $cachePool?">
      <set_value name="$cachePool" exact="'mk3'"/>
    </do_if>
  </patch>
  <attention min="unknown">
    <actions>
      <set_value name="this.$gt_cachePoolIsMk4" exact="$cachePool == 'mk4'"/>

      <!-- Read performance settings from global settings -->
      <set_value name="this.$gt_yieldMs" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$AIYieldInterval?">
        <set_value name="this.$gt_yieldMs" exact="[1, @global.$GT_GlobalSettings.$Performance.$AIYieldInterval].max"/>
      </do_if>
      <set_value name="this.$writeBatchSize" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$CacheWriteBatchSize?">
        <set_value name="this.$writeBatchSize" exact="[1, @global.$GT_GlobalSettings.$Performance.$CacheWriteBatchSize].max"/>
      </do_if>
      <set_value name="this.$writeBatchSize" exact="(this.$writeBatchSize)i"/>
      <set_value name="this.$cleanupBatchSize" exact="50"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$CacheCleanupBatchSize?">
        <set_value name="this.$cleanupBatchSize" exact="[10, @global.$GT_GlobalSettings.$Performance.$CacheCleanupBatchSize].max"/>
      </do_if>
      <set_value name="this.$cleanupBatchSize" exact="(this.$cleanupBatchSize)i"/>

      <!-- Early exit if nothing to write -->
      <do_if value="$tradeList.count == 0 or not $homeSector?">
        <return value="table[$Written = 0, $Cleaned = 0, $CacheSize = 0]"/>
      </do_if>

      <!-- Ensure cache structure exists for the selected pool -->
      <do_if value="this.$gt_cachePoolIsMk4">
        <do_if value="not global.$GT_TradeCacheMK4?">
          <set_value name="global.$GT_TradeCacheMK4" exact="table[]"/>
        </do_if>
        <do_if value="not global.$GT_TradeCacheMK4.{$homeSector}?">
          <set_value name="global.$GT_TradeCacheMK4.{$homeSector}" exact="[]"/>
        </do_if>
      </do_if>
      <do_else>
        <do_if value="not global.$GT_TradeCache?">
          <set_value name="global.$GT_TradeCache" exact="table[]"/>
        </do_if>
        <do_if value="not global.$GT_TradeCache.{$homeSector}?">
          <set_value name="global.$GT_TradeCache.{$homeSector}" exact="[]"/>
        </do_if>
      </do_else>

      <set_value name="$cacheNow" exact="player.age"/>

      <!-- Phase 1: Write-time cleanup -->
      <set_value name="$expiredCount" exact="0"/>
      <set_value name="$cleanupSize" exact="0"/>
      <do_if value="this.$gt_cachePoolIsMk4">
        <set_value name="$cleanupSize" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
      </do_if>
      <do_else>
        <set_value name="$cleanupSize" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
      </do_else>
      <do_all exact="$cleanupSize" counter="$ci" reverse="true">
        <set_value name="$liveCleanupCount" exact="0"/>
        <do_if value="this.$gt_cachePoolIsMk4">
          <set_value name="$liveCleanupCount" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
        </do_if>
        <do_else>
          <set_value name="$liveCleanupCount" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
        </do_else>
        <do_if value="$ci gt $liveCleanupCount">
          <continue/>
        </do_if>
        <set_value name="$oldEntry" exact="null"/>
        <do_if value="this.$gt_cachePoolIsMk4">
          <set_value name="$oldEntry" exact="@global.$GT_TradeCacheMK4.{$homeSector}.{$ci}"/>
        </do_if>
        <do_else>
          <set_value name="$oldEntry" exact="@global.$GT_TradeCache.{$homeSector}.{$ci}"/>
        </do_else>
        <do_if value="not $oldEntry?">
          <do_if value="$ci le $liveCleanupCount">
            <do_if value="this.$gt_cachePoolIsMk4">
              <remove_value name="global.$GT_TradeCacheMK4.{$homeSector}.{$ci}"/>
            </do_if>
            <do_else>
              <remove_value name="global.$GT_TradeCache.{$homeSector}.{$ci}"/>
            </do_else>
            <set_value name="$expiredCount" operation="add"/>
          </do_if>
          <continue/>
        </do_if>

        <set_value name="$oldTs" exact="@$oldEntry.$CachedAt"/>
        <do_if value="$oldTs == null">
          <set_value name="$oldTs" exact="@$oldEntry.$Timestamp"/>
        </do_if>

        <set_value name="$isStale" exact="false"/>
        <do_if value="$oldTs != null and ($cacheNow - $oldTs) gt $cacheTTL">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <set_value name="$oldReResolvable" exact="(@$oldEntry.$Ware != null or @$oldEntry.$DeliveryStationName != null) and (@$oldEntry.$DeliveryStationId != null or @$oldEntry.$DeliveryStationName != null) and ((@$oldEntry.$SellSector != null and @$oldEntry.$SellSector.exists) or @$oldEntry.$SellSectorId != null or @$oldEntry.$DeliveryStationId != null)"/>
        <do_if value="not $isStale and @$oldEntry.$BuyOffer != null and not @$oldEntry.$BuyOffer.exists">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <!-- Dead delivery offer/station refs are normal when buy offers refresh; permanent keys allow re-discovery at read. -->
        <do_if value="not $isStale and not $oldReResolvable and @$oldEntry.$SellOffer != null and not @$oldEntry.$SellOffer.exists">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <do_if value="not $isStale and not $oldReResolvable and @$oldEntry.$SellStation != null and not @$oldEntry.$SellStation.exists">
          <set_value name="$isStale" exact="true"/>
        </do_if>

        <do_if value="$isStale">
          <set_value name="$liveBeforeRemove" exact="0"/>
          <do_if value="this.$gt_cachePoolIsMk4">
            <set_value name="$liveBeforeRemove" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
          </do_if>
          <do_else>
            <set_value name="$liveBeforeRemove" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
          </do_else>
          <do_if value="$ci le $liveBeforeRemove">
            <do_if value="this.$gt_cachePoolIsMk4">
              <remove_value name="global.$GT_TradeCacheMK4.{$homeSector}.{$ci}"/>
            </do_if>
            <do_else>
              <remove_value name="global.$GT_TradeCache.{$homeSector}.{$ci}"/>
            </do_else>
            <set_value name="$expiredCount" operation="add"/>
          </do_if>
        </do_if>

        <set_value name="$ciInt" exact="($ci)i"/>
        <do_if value="($ciInt % this.$cleanupBatchSize) == 0">
          <wait exact="this.$gt_yieldMs * 1ms" comment="Yield cleanup loop"/>
        </do_if>
      </do_all>

      <set_value name="$poolLabel" exact="if this.$gt_cachePoolIsMk4 then 'MK4' else 'MK3'"/>
      <do_if value="$expiredCount gt 0 and @global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <set_value name="$remainingAfterCleanup" exact="0"/>
        <do_if value="this.$gt_cachePoolIsMk4">
          <set_value name="$remainingAfterCleanup" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
        </do_if>
        <do_else>
          <set_value name="$remainingAfterCleanup" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
        </do_else>
        <debug_text text="'[GT-CacheWrite] ' + this.ship.idcode + ': (' + $poolLabel + ') Write-time cleanup removed ' + $expiredCount + ' expired/stale entries from ' + $homeSector.knownname + ' (remaining: ' + $remainingAfterCleanup + ')'" chance="100"/>
      </do_if>

      <!-- Phase 2: Sorted insertion by $Score descending -->
      <do_all exact="$tradeList.count" counter="$ti">
        <set_value name="$newTrade" exact="$tradeList.{$ti}"/>
        <set_value name="$newTrade.$CachedAt" exact="$cacheNow"/>
        <set_value name="$newTrade.$Timestamp" exact="$cacheNow"/>
        <!-- Snapshot delivery station name so diagnose can show stale cache rows after offer refs die. -->
        <do_if value="not $newTrade.$DeliveryStationName? and $newTrade.$SellStation? and @$newTrade.$SellStation.exists and @$newTrade.$SellStation.knownname">
          <set_value name="$newTrade.$DeliveryStationName" exact="@$newTrade.$SellStation.knownname"/>
        </do_if>
        <do_if value="not $newTrade.$DeliveryStationName? and $newTrade.$SellOffer? and @$newTrade.$SellOffer.exists">
          <do_if value="$newTrade.$SellOffer.buyer? and @$newTrade.$SellOffer.buyer.exists and @$newTrade.$SellOffer.buyer.knownname">
            <set_value name="$newTrade.$DeliveryStationName" exact="@$newTrade.$SellOffer.buyer.knownname"/>
          </do_if>
          <do_elseif value="$newTrade.$SellOffer.owner? and @$newTrade.$SellOffer.owner.exists and @$newTrade.$SellOffer.owner.knownname">
            <set_value name="$newTrade.$DeliveryStationName" exact="@$newTrade.$SellOffer.owner.knownname"/>
          </do_elseif>
        </do_if>
        <!-- Stable delivery keys: customer buy-offer refs die on refresh; idcode + sector + ware re-discover the live offer. -->
        <do_if value="not $newTrade.$SellStationBase?">
          <set_value name="$wAnchorSell" exact="null"/>
          <do_if value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists">
            <set_value name="$wAnchorSell" exact="@$newTrade.$SellStation"/>
          </do_if>
          <do_elseif value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $newTrade.$SellOffer.buyer? and @$newTrade.$SellOffer.buyer.exists">
            <set_value name="$wAnchorSell" exact="@$newTrade.$SellOffer.buyer"/>
          </do_elseif>
          <do_if value="$wAnchorSell? and @$wAnchorSell.isclass.buildstorage and $wAnchorSell.base? and @$wAnchorSell.base.exists">
            <set_value name="$newTrade.$SellStationBase" exact="@$wAnchorSell.base"/>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$DeliveryStationId?">
          <set_value name="$wIdSell" exact="null"/>
          <do_if value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists">
            <set_value name="$wIdSell" exact="@$newTrade.$SellStation"/>
          </do_if>
          <do_elseif value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $newTrade.$SellOffer.buyer? and @$newTrade.$SellOffer.buyer.exists">
            <set_value name="$wIdSell" exact="@$newTrade.$SellOffer.buyer"/>
          </do_elseif>
          <do_if value="$wIdSell? and @$wIdSell.exists">
            <do_if value="@$wIdSell.isclass.buildstorage and $wIdSell.base? and @$wIdSell.base.exists">
              <set_value name="$newTrade.$DeliveryStationId" exact="@$wIdSell.base.idcode"/>
            </do_if>
            <do_else>
              <set_value name="$newTrade.$DeliveryStationId" exact="@$wIdSell.idcode"/>
            </do_else>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$SellSectorId?">
          <set_value name="$wSecSell" exact="null"/>
          <do_if value="$newTrade.$SellSector? and @$newTrade.$SellSector.exists and $newTrade.$SellSector.idcode?">
            <set_value name="$wSecSell" exact="@$newTrade.$SellSector.idcode"/>
          </do_if>
          <do_elseif value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists and $newTrade.$SellStation.sector? and @$newTrade.$SellStation.sector.exists and $newTrade.$SellStation.sector.idcode?">
            <set_value name="$wSecSell" exact="@$newTrade.$SellStation.sector.idcode"/>
          </do_elseif>
          <do_if value="$wSecSell?">
            <set_value name="$newTrade.$SellSectorId" exact="$wSecSell"/>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$SupplierStationId?">
          <set_value name="$wIdBuy" exact="null"/>
          <do_if value="$newTrade.$BuyStation? and @$newTrade.$BuyStation.exists and $newTrade.$BuyStation.idcode?">
            <set_value name="$wIdBuy" exact="@$newTrade.$BuyStation.idcode"/>
          </do_if>
          <do_elseif value="$newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and $newTrade.$BuyOffer.seller? and @$newTrade.$BuyOffer.seller.exists and $newTrade.$BuyOffer.seller.idcode?">
            <set_value name="$wIdBuy" exact="@$newTrade.$BuyOffer.seller.idcode"/>
          </do_elseif>
          <do_if value="$wIdBuy?">
            <set_value name="$newTrade.$SupplierStationId" exact="$wIdBuy"/>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$BuySectorId?">
          <set_value name="$wSecBuy" exact="null"/>
          <do_if value="$newTrade.$BuySector? and @$newTrade.$BuySector.exists and $newTrade.$BuySector.idcode?">
            <set_value name="$wSecBuy" exact="@$newTrade.$BuySector.idcode"/>
          </do_if>
          <do_elseif value="$newTrade.$BuyStation? and @$newTrade.$BuyStation.exists and $newTrade.$BuyStation.sector? and @$newTrade.$BuyStation.sector.exists and $newTrade.$BuyStation.sector.idcode?">
            <set_value name="$wSecBuy" exact="@$newTrade.$BuyStation.sector.idcode"/>
          </do_elseif>
          <do_if value="$wSecBuy?">
            <set_value name="$newTrade.$BuySectorId" exact="$wSecBuy"/>
          </do_if>
        </do_if>
        <!-- Ensure sector object refs exist for hop-memo / ship-route rescore (Market Fabric Phase 3). -->
        <do_if value="not $newTrade.$BuySector? or not @$newTrade.$BuySector.exists">
          <do_if value="$newTrade.$BuyStation? and @$newTrade.$BuyStation.exists and $newTrade.$BuyStation.sector?">
            <set_value name="$newTrade.$BuySector" exact="@$newTrade.$BuyStation.sector"/>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$SellSector? or not @$newTrade.$SellSector.exists">
          <do_if value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists and $newTrade.$SellStation.sector?">
            <set_value name="$newTrade.$SellSector" exact="@$newTrade.$SellStation.sector"/>
          </do_if>
        </do_if>
        <!-- Route-centric key: one cache row per (supplier, delivery, ware). -->
        <set_value name="$routeWareId" exact="if $newTrade.$Ware? and $newTrade.$Ware.id? then @$newTrade.$Ware.id else '?'"/>
        <set_value name="$routeSupplierId" exact="if $newTrade.$SupplierStationId? then $newTrade.$SupplierStationId else '?'"/>
        <set_value name="$routeDeliveryId" exact="if $newTrade.$DeliveryStationId? then $newTrade.$DeliveryStationId else '?'"/>
        <set_value name="$newTrade.$RouteKey" exact="'' + $routeSupplierId + '|' + $routeDeliveryId + '|' + $routeWareId"/>
        <!-- Stamp trade-rule verdict for player-owned legs only (fresh offer refs).
             NPC×NPC cantradewith is not a player trade rule — do not stamp or skip those rows. -->
        <do_if value="not $newTrade.$IsSellOnly?">
          <set_value name="$trbBuyStation" exact="null"/>
          <do_if value="$newTrade.$BuyStation? and @$newTrade.$BuyStation.exists">
            <set_value name="$trbBuyStation" exact="@$newTrade.$BuyStation"/>
          </do_if>
          <do_elseif value="$newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and $newTrade.$BuyOffer.seller? and @$newTrade.$BuyOffer.seller.exists">
            <set_value name="$trbBuyStation" exact="@$newTrade.$BuyOffer.seller"/>
          </do_elseif>
          <do_elseif value="$newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and $newTrade.$BuyOffer.owner? and @$newTrade.$BuyOffer.owner.exists">
            <set_value name="$trbBuyStation" exact="@$newTrade.$BuyOffer.owner"/>
          </do_elseif>
          <set_value name="$trbSellStation" exact="null"/>
          <do_if value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $newTrade.$SellOffer.buyer? and @$newTrade.$SellOffer.buyer.exists">
            <set_value name="$trbSellStation" exact="@$newTrade.$SellOffer.buyer"/>
          </do_if>
          <do_elseif value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists">
            <set_value name="$trbSellStation" exact="@$newTrade.$SellStation"/>
          </do_elseif>
          <do_elseif value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $newTrade.$SellOffer.owner? and @$newTrade.$SellOffer.owner.exists">
            <set_value name="$trbSellStation" exact="@$newTrade.$SellOffer.owner"/>
          </do_elseif>
          <set_value name="$trbPlayerStationInvolved" exact="false"/>
          <do_if value="$trbBuyStation? and @$trbBuyStation.exists">
            <do_if value="@$trbBuyStation.isplayerowned">
              <set_value name="$trbPlayerStationInvolved" exact="true"/>
            </do_if>
            <do_elseif value="@$trbBuyStation.isclass.buildstorage and $trbBuyStation.base? and @$trbBuyStation.base.exists and @$trbBuyStation.base.isplayerowned">
              <set_value name="$trbPlayerStationInvolved" exact="true"/>
            </do_elseif>
          </do_if>
          <do_if value="not $trbPlayerStationInvolved and $trbSellStation? and @$trbSellStation.exists">
            <do_if value="@$trbSellStation.isplayerowned">
              <set_value name="$trbPlayerStationInvolved" exact="true"/>
            </do_if>
            <do_elseif value="@$trbSellStation.isclass.buildstorage and $trbSellStation.base? and @$trbSellStation.base.exists and @$trbSellStation.base.isplayerowned">
              <set_value name="$trbPlayerStationInvolved" exact="true"/>
            </do_elseif>
          </do_if>
          <set_value name="$newTrade.$TradeRuleBlocked" exact="false"/>
          <do_if value="$trbPlayerStationInvolved">
            <do_if value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $trbBuyStation? and @$trbBuyStation.exists and not $newTrade.$SellOffer.cantradewith.{$trbBuyStation}">
              <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
            </do_if>
            <do_elseif value="$newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and $trbSellStation? and @$trbSellStation.exists and not $newTrade.$BuyOffer.cantradewith.{$trbSellStation}">
              <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
            </do_elseif>
            <do_if value="$newTrade.$TradeRuleBlocked? and $newTrade.$TradeRuleBlocked">
              <continue/>
            </do_if>
          </do_if>
        </do_if>
        <!-- MK4 shared pool: persist ware transport (container/solid/liquid) so readers skip incompatible holds without validation poisoning. -->
        <do_if value="this.$gt_cachePoolIsMk4 and not $newTrade.$CargoWareTransport?">
          <set_value name="$cacheTagWare" exact="if $newTrade.$Ware? then $newTrade.$Ware else null"/>
          <do_if value="not $cacheTagWare? and $newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and @$newTrade.$BuyOffer.ware != null">
            <set_value name="$cacheTagWare" exact="@$newTrade.$BuyOffer.ware"/>
          </do_if>
          <do_if value="not $cacheTagWare? and $newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and @$newTrade.$SellOffer.ware != null">
            <set_value name="$cacheTagWare" exact="@$newTrade.$SellOffer.ware"/>
          </do_if>
          <do_if value="$cacheTagWare?">
            <set_value name="$newTrade.$CargoWareTransport" exact="@$cacheTagWare.waretransport"/>
          </do_if>
        </do_if>
        <set_value name="$newScore" exact="if $newTrade.$Score? then @$newTrade.$Score else 0"/>

        <!-- MK3: strip ephemeral per-ship route fields — shared cache stays ship-agnostic (LC4). -->
        <do_if value="not this.$gt_cachePoolIsMk4">
          <do_if value="$newTrade.$ShipRouteScored?">
            <remove_value name="$newTrade.$ShipRouteScored"/>
          </do_if>
          <do_if value="$newTrade.$ShipScore?">
            <remove_value name="$newTrade.$ShipScore"/>
          </do_if>
          <do_if value="$newTrade.$ShipToBuyDistance?">
            <remove_value name="$newTrade.$ShipToBuyDistance"/>
          </do_if>
          <do_if value="$newTrade.$ShipRouteDistance?">
            <remove_value name="$newTrade.$ShipRouteDistance"/>
          </do_if>
          <do_if value="$newTrade.$SelectionScore?">
            <remove_value name="$newTrade.$SelectionScore"/>
          </do_if>
        </do_if>

        <do_if value="this.$gt_cachePoolIsMk4">
          <do_if value="not global.$GT_TradeCacheMK4?">
            <set_value name="global.$GT_TradeCacheMK4" exact="table[]"/>
          </do_if>
          <do_if value="not global.$GT_TradeCacheMK4.{$homeSector}?">
            <set_value name="global.$GT_TradeCacheMK4.{$homeSector}" exact="[]"/>
          </do_if>
        </do_if>
        <do_else>
          <do_if value="not global.$GT_TradeCache?">
            <set_value name="global.$GT_TradeCache" exact="table[]"/>
          </do_if>
          <do_if value="not global.$GT_TradeCache.{$homeSector}?">
            <set_value name="global.$GT_TradeCache.{$homeSector}" exact="[]"/>
          </do_if>
        </do_else>

        <!-- Route-centric dedup: replace prior rows for the same supplier→delivery→ware (keep FailedShips). -->
        <set_value name="$dedupeRemoved" exact="0"/>
        <set_value name="$dedupeCacheSize" exact="0"/>
        <do_if value="this.$gt_cachePoolIsMk4">
          <set_value name="$dedupeCacheSize" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
        </do_if>
        <do_else>
          <set_value name="$dedupeCacheSize" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
        </do_else>
        <do_if value="$dedupeCacheSize gt 0 and $newTrade.$RouteKey? and $newTrade.$RouteKey != '?' and $newTrade.$RouteKey != '?|?|?'">
          <do_all exact="$dedupeCacheSize" counter="$dui" reverse="true">
            <set_value name="$dupEntry" exact="null"/>
            <do_if value="this.$gt_cachePoolIsMk4">
              <do_if value="$dui le @global.$GT_TradeCacheMK4.{$homeSector}.count">
                <set_value name="$dupEntry" exact="@global.$GT_TradeCacheMK4.{$homeSector}.{$dui}"/>
              </do_if>
            </do_if>
            <do_else>
              <do_if value="$dui le @global.$GT_TradeCache.{$homeSector}.count">
                <set_value name="$dupEntry" exact="@global.$GT_TradeCache.{$homeSector}.{$dui}"/>
              </do_if>
            </do_else>
            <do_if value="$dupEntry?">
              <set_value name="$dupKey" exact="if $dupEntry.$RouteKey? then $dupEntry.$RouteKey else null"/>
              <do_if value="not $dupKey?">
                <set_value name="$dupWareId" exact="if $dupEntry.$Ware? and $dupEntry.$Ware.id? then @$dupEntry.$Ware.id else '?'"/>
                <set_value name="$dupSupplierId" exact="if $dupEntry.$SupplierStationId? then $dupEntry.$SupplierStationId else '?'"/>
                <set_value name="$dupDeliveryId" exact="if $dupEntry.$DeliveryStationId? then $dupEntry.$DeliveryStationId else '?'"/>
                <set_value name="$dupKey" exact="'' + $dupSupplierId + '|' + $dupDeliveryId + '|' + $dupWareId"/>
              </do_if>
              <do_if value="$dupKey == $newTrade.$RouteKey">
                <do_if value="$dupEntry.$FailedShips? and $dupEntry.$FailedShips.count gt 0">
                  <do_if value="not $newTrade.$FailedShips?">
                    <create_list name="$newTrade.$FailedShips"/>
                  </do_if>
                  <do_all exact="$dupEntry.$FailedShips.count" counter="$dfs">
                    <append_to_list name="$newTrade.$FailedShips" exact="$dupEntry.$FailedShips.{$dfs}"/>
                  </do_all>
                </do_if>
                <do_if value="$dupEntry.$FailedShipIdcodes? and $dupEntry.$FailedShipIdcodes.count gt 0">
                  <do_if value="not $newTrade.$FailedShipIdcodes?">
                    <create_list name="$newTrade.$FailedShipIdcodes"/>
                  </do_if>
                  <do_all exact="$dupEntry.$FailedShipIdcodes.count" counter="$dfi">
                    <append_to_list name="$newTrade.$FailedShipIdcodes" exact="$dupEntry.$FailedShipIdcodes.{$dfi}"/>
                  </do_all>
                </do_if>
                <do_if value="this.$gt_cachePoolIsMk4">
                  <remove_value name="global.$GT_TradeCacheMK4.{$homeSector}.{$dui}"/>
                </do_if>
                <do_else>
                  <remove_value name="global.$GT_TradeCache.{$homeSector}.{$dui}"/>
                </do_else>
                <set_value name="$dedupeRemoved" operation="add"/>
              </do_if>
            </do_if>
          </do_all>
        </do_if>

        <set_value name="$insertIdx" exact="0"/>
        <set_value name="$insertFound" exact="false"/>
        <set_value name="$cacheSize" exact="0"/>
        <do_if value="this.$gt_cachePoolIsMk4">
          <set_value name="$cacheSize" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
        </do_if>
        <do_else>
          <set_value name="$cacheSize" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
        </do_else>
        <do_if value="$cacheSize gt 0">
          <do_all exact="$cacheSize" counter="$si">
            <set_value name="$existingScore" exact="0"/>
            <do_if value="this.$gt_cachePoolIsMk4">
              <set_value name="$existingScore" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.{$si}.$Score != null then @global.$GT_TradeCacheMK4.{$homeSector}.{$si}.$Score else 0"/>
            </do_if>
            <do_else>
              <set_value name="$existingScore" exact="if @global.$GT_TradeCache.{$homeSector}.{$si}.$Score != null then @global.$GT_TradeCache.{$homeSector}.{$si}.$Score else 0"/>
            </do_else>
            <do_if value="$newScore gt $existingScore">
              <set_value name="$insertIdx" exact="$si"/>
              <set_value name="$insertFound" exact="true"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>

        <do_if value="$insertFound">
          <do_if value="this.$gt_cachePoolIsMk4">
            <set_value name="global.$GT_TradeCacheMK4.{$homeSector}.{$insertIdx}" exact="$newTrade" operation="insert"/>
          </do_if>
          <do_else>
            <set_value name="global.$GT_TradeCache.{$homeSector}.{$insertIdx}" exact="$newTrade" operation="insert"/>
          </do_else>
        </do_if>
        <do_else>
          <do_if value="this.$gt_cachePoolIsMk4">
            <append_to_list name="global.$GT_TradeCacheMK4.{$homeSector}" exact="$newTrade"/>
          </do_if>
          <do_else>
            <append_to_list name="global.$GT_TradeCache.{$homeSector}" exact="$newTrade"/>
          </do_else>
        </do_else>

        <set_value name="$tiInt" exact="($ti)i"/>
        <do_if value="($tiInt % this.$writeBatchSize) == 0">
          <wait exact="this.$gt_yieldMs * 1ms" comment="Yield between sorted insertions"/>
        </do_if>
      </do_all>

      <set_value name="$finalCacheSize" exact="0"/>
      <do_if value="this.$gt_cachePoolIsMk4">
        <set_value name="$finalCacheSize" exact="if @global.$GT_TradeCacheMK4.{$homeSector}.count != null then @global.$GT_TradeCacheMK4.{$homeSector}.count else 0"/>
      </do_if>
      <do_else>
        <set_value name="$finalCacheSize" exact="if @global.$GT_TradeCache.{$homeSector}.count != null then @global.$GT_TradeCache.{$homeSector}.count else 0"/>
      </do_else>
      <!-- MK3 pool: when over cap, evict oldest entries by $CachedAt (not lowest home $Score tail).
           MK3 cache read scans the full pool and re-ranks per ship; age trim keeps fresh home-valid rows. -->
      <do_if value="not this.$gt_cachePoolIsMk4 and $finalCacheSize gt 0">
        <set_value name="$cacheMaxEntries" exact="200"/>
        <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$CacheQueryMaxEntries?">
          <set_value name="$cacheMaxEntries" exact="@global.$GT_GlobalSettings.$Performance.$CacheQueryMaxEntries"/>
        </do_if>
        <do_while value="$finalCacheSize gt $cacheMaxEntries">
          <set_value name="$oldestIdx" exact="1"/>
          <set_value name="$oldestTs" exact="null"/>
          <do_all exact="$finalCacheSize" counter="$trimIdx">
            <set_value name="$trimEntry" exact="@global.$GT_TradeCache.{$homeSector}.{$trimIdx}"/>
            <set_value name="$trimTs" exact="null"/>
            <do_if value="$trimEntry?">
              <set_value name="$trimTs" exact="@$trimEntry.$CachedAt"/>
              <do_if value="$trimTs == null">
                <set_value name="$trimTs" exact="@$trimEntry.$Timestamp"/>
              </do_if>
            </do_if>
            <do_if value="$trimTs == null">
              <set_value name="$trimTs" exact="0"/>
            </do_if>
            <do_if value="$oldestTs == null or $trimTs le $oldestTs">
              <set_value name="$oldestTs" exact="$trimTs"/>
              <set_value name="$oldestIdx" exact="$trimIdx"/>
            </do_if>
          </do_all>
          <remove_value name="global.$GT_TradeCache.{$homeSector}.{$oldestIdx}"/>
          <set_value name="$finalCacheSize" operation="subtract"/>
        </do_while>
      </do_if>
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-CacheWrite] ' + this.ship.idcode + ': (' + $poolLabel + ') Wrote ' + $tradeList.count + ' trades (sorted) into ' + $homeSector.knownname + ' cache (total: ' + $finalCacheSize + ', cleaned: ' + $expiredCount + ')'" chance="100"/>
      </do_if>

      <!-- Phase 3: Update per-pool max-distance metadata -->
      <set_value name="$metadataUpdated" exact="false"/>
      <do_if value="$maxSearchDistance gt 0">
        <do_if value="this.$gt_cachePoolIsMk4">
          <do_if value="not global.$GT_TradeCacheMK4MaxDistance?">
            <set_value name="global.$GT_TradeCacheMK4MaxDistance" exact="table[]"/>
          </do_if>
          <do_if value="not global.$GT_TradeCacheMK4MaxDistance.{$homeSector}? or $maxSearchDistance gt global.$GT_TradeCacheMK4MaxDistance.{$homeSector}">
            <set_value name="global.$GT_TradeCacheMK4MaxDistance.{$homeSector}" exact="$maxSearchDistance"/>
            <set_value name="$metadataUpdated" exact="true"/>
          </do_if>
        </do_if>
        <do_else>
          <do_if value="not global.$GT_TradeCacheMaxDistance?">
            <set_value name="global.$GT_TradeCacheMaxDistance" exact="table[]"/>
          </do_if>
          <do_if value="not global.$GT_TradeCacheMaxDistance.{$homeSector}? or $maxSearchDistance gt global.$GT_TradeCacheMaxDistance.{$homeSector}">
            <set_value name="global.$GT_TradeCacheMaxDistance.{$homeSector}" exact="$maxSearchDistance"/>
            <set_value name="$metadataUpdated" exact="true"/>
          </do_if>
        </do_else>
      </do_if>
      <!-- Wake same-home waiters on any pool write (MK3 traders + MK4 supply). -->
      <set_value name="$cacheWakeNeeded" exact="$homeSector? and $homeSector.exists and ($tradeList.count gt 0 or $metadataUpdated)"/>
      <do_if value="$cacheWakeNeeded">
        <signal_objects object="player.galaxy" param="'GT_MK4_Cache_Updated'" param2="table[
          $HomeSector = $homeSector,
          $MaxDistance = $maxSearchDistance,
          $Written = $tradeList.count,
          $CacheSize = $finalCacheSize,
          $CachePool = if this.$gt_cachePoolIsMk4 then 'mk4' else 'mk3'
        ]"/>
      </do_if>

      <return value="table[
        $Written = $tradeList.count,
        $Cleaned = $expiredCount,
        $CacheSize = $finalCacheSize
      ]"/>
    </actions>
  </attention>
</aiscript>
