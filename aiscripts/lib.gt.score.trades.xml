<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.score.trades" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="3">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="debugchance" default="0"/>
    <param name="priorityWares" default="[]" comment="Optional: wares to boost (MK3 Priority Wares). Applied last."/>
    <param name="priorityScoreMultiplier" default="125" comment="Optional: score multiplier for priority wares (125=+25%%, 150=+50%%, 200=2x). Applied last."/>
    <!-- MK4 auto-wares: round-robin one trade per ware per pass so niche wares (e.g. Quantum Tubes)
         are not buried behind a global score sort dominated by high-volume cheap wares. -->
    <param name="diversifyByWare" default="false"/>
    <!-- MK4 supply: priority wares lead each diversify round before other wares (still one slot/ware/round). -->
    <param name="priorityFirstInDiversify" default="false"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bestTrade" exact="null"/>
      <set_value name="$bestScore" exact="0"/>
      <set_value name="$haveBest" exact="false"/>
      <create_list name="$sortedTrades"/>

      <!-- null-safe: never read .count when $tradeList is null (X4 evaluates both sides of 'or'). -->
      <do_if value="not $tradeList?">
        <wait exact="1ms" comment="Cooperative yield before immediate return (wake-loop guard)"/>
        <return value="table[
          $Found = false,
          $BestTrade = null,
          $BestScore = 0,
          $SortedTrades = $sortedTrades
        ]"/>
      </do_if>
      <do_if value="$tradeList.count == 0">
        <wait exact="1ms" comment="Cooperative yield before immediate return (wake-loop guard)"/>
        <return value="table[
          $Found = false,
          $BestTrade = null,
          $BestScore = 0,
          $SortedTrades = $sortedTrades
        ]"/>
      </do_if>

      <!-- Apply priority ware score multiplier LAST (after all other scoring).
           Normalize nullable incoming list first (save/load resume safety). -->
      <set_value name="$safePriorityWares" exact="if $priorityWares? and $priorityWares != null then $priorityWares else []"/>
      <set_value name="$hasPriorityWares" exact="$safePriorityWares.count gt 0"/>
      <set_value name="$multPct" exact="if $priorityScoreMultiplier? then $priorityScoreMultiplier else 125"/>
      <do_if value="$multPct lt 125"><set_value name="$multPct" exact="125"/></do_if>
      <do_if value="$multPct gt 300"><set_value name="$multPct" exact="300"/></do_if>
      <set_value name="$mult" exact="$multPct / 100.0"/>

      <do_all exact="$tradeList.count" counter="$i">
        <set_value name="$trade" exact="$tradeList.{$i}"/>
        <set_value name="$baseScore" exact="if $trade.$Score? then $trade.$Score else 0"/>
        <set_value name="$finalScore" exact="$baseScore"/>
        <do_if value="$hasPriorityWares and $trade.$Ware?">
          <set_value name="$isPriority" exact="false"/>
          <do_all exact="$safePriorityWares.count" counter="$pw">
            <do_if value="$safePriorityWares.{$pw} == $trade.$Ware">
              <set_value name="$isPriority" exact="true"/>
              <break/>
            </do_if>
          </do_all>
          <do_if value="$isPriority">
            <set_value name="$finalScore" exact="$baseScore * $mult"/>
          </do_if>
        </do_if>
        <set_value name="$trade.$Score" exact="$finalScore"/>
        <append_to_list name="$sortedTrades" exact="$trade"/>
        <!-- Candidates are already fully validated upstream (profit/ROI/offers/amount), so the
             score is a pure ranking heuristic and may legitimately be <= 0 (e.g. a tiny base
             score overwhelmed by the fleet-usage penalty). Always keep the highest-scoring
             candidate regardless of sign; a 0-init floor with "gt 0" would drop every
             non-positive candidate and wrongly report no trade. -->
        <do_if value="not $haveBest or $finalScore gt $bestScore">
          <set_value name="$bestScore" exact="$finalScore"/>
          <set_value name="$bestTrade" exact="$trade"/>
          <set_value name="$haveBest" exact="true"/>
        </do_if>
      </do_all>

      <sort_list list="$sortedTrades" sortbyvalue="loop.element.$Score" sortdescending="true"/>

      <!-- Per-ware quota (floor): after score sort, interleave so each ware's best trade
           appears in the validation window before lower-ranked trades from dominant wares. -->
      <do_if value="$diversifyByWare and $sortedTrades.count gt 1">
        <create_list name="$diversifiedTrades"/>
        <set_value name="$diversifyPicked" exact="table[]"/>
        <set_value name="$usePriorityFirst" exact="$priorityFirstInDiversify and $hasPriorityWares"/>
        <do_while value="$diversifiedTrades.count lt $sortedTrades.count">
          <set_value name="$diversifyRoundServed" exact="table[]"/>
          <set_value name="$diversifyRoundAdded" exact="0"/>
          <!-- Priority wares first each round (MK4 supply fairness + priority boost placement). -->
          <do_if value="$usePriorityFirst">
            <do_all exact="$safePriorityWares.count" counter="$dpp">
              <set_value name="$dpw" exact="$safePriorityWares.{$dpp}"/>
              <do_if value="not $dpw? or $dpw == null">
                <continue/>
              </do_if>
              <do_if value="$diversifyRoundServed.{$dpw}?">
                <continue/>
              </do_if>
              <do_all exact="$sortedTrades.count" counter="$dpwi">
                <do_if value="not $diversifyPicked.{$dpwi}?">
                  <set_value name="$dpTrade" exact="$sortedTrades.{$dpwi}"/>
                  <set_value name="$dpWare" exact="if $dpTrade.$Ware? then $dpTrade.$Ware else null"/>
                  <do_if value="$dpWare? and $dpWare == $dpw">
                    <append_to_list name="$diversifiedTrades" exact="$dpTrade"/>
                    <set_value name="$diversifyPicked.{$dpwi}" exact="true"/>
                    <set_value name="$diversifyRoundServed.{$dpw}" exact="true"/>
                    <set_value name="$diversifyRoundAdded" operation="add"/>
                    <break/>
                  </do_if>
                </do_if>
              </do_all>
            </do_all>
          </do_if>
          <do_all exact="$sortedTrades.count" counter="$dwi">
            <do_if value="not $diversifyPicked.{$dwi}?">
              <set_value name="$dwTrade" exact="$sortedTrades.{$dwi}"/>
              <set_value name="$dwWare" exact="if $dwTrade.$Ware? then $dwTrade.$Ware else null"/>
              <do_if value="$dwWare? and not $diversifyRoundServed.{$dwWare}?">
                <append_to_list name="$diversifiedTrades" exact="$dwTrade"/>
                <set_value name="$diversifyPicked.{$dwi}" exact="true"/>
                <set_value name="$diversifyRoundServed.{$dwWare}" exact="true"/>
                <set_value name="$diversifyRoundAdded" operation="add"/>
              </do_if>
            </do_if>
          </do_all>
          <do_if value="$diversifyRoundAdded == 0">
            <break/>
          </do_if>
        </do_while>
        <!-- Trades without a ware tag (should not happen) append at tail in score order. -->
        <do_all exact="$sortedTrades.count" counter="$dwt">
          <do_if value="not $diversifyPicked.{$dwt}?">
            <append_to_list name="$diversifiedTrades" exact="$sortedTrades.{$dwt}"/>
            <set_value name="$diversifyPicked.{$dwt}" exact="true"/>
          </do_if>
        </do_all>
        <set_value name="$sortedTrades" exact="$diversifiedTrades"/>
        <set_value name="$bestTrade" exact="if $sortedTrades.count gt 0 then $sortedTrades.{1} else null"/>
        <set_value name="$bestScore" exact="if $bestTrade? and $bestTrade.$Score? then $bestTrade.$Score else 0"/>
        <debug_text text="'[GT-ScoreTrades] diversifyByWare: interleaved ' + $sortedTrades.count + ' trades (best=' + (if $bestTrade? and $bestTrade.$Ware? then $bestTrade.$Ware.name else '?') + ' score=' + $bestScore + ' priorityFirst=' + $usePriorityFirst + ')'" chance="$debugchance"/>
      </do_if>

      <wait exact="1ms" comment="Cooperative yield before return (wake-loop guard)"/>
      <return value="table[
        $Found = ($bestTrade != null),
        $BestTrade = $bestTrade,
        $BestScore = $bestScore,
        $SortedTrades = $sortedTrades
      ]"/>
    </actions>
  </attention>
</aiscript>
