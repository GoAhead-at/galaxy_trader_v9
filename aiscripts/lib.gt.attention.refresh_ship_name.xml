<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.refresh_ship_name" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Requests an MD-side ship name refresh via GT_Refresh_Ship_Name.
    Main-loop call site for all GT service orders (MK1/MK2/MK3/MK4/Miner).
    MD applies content dedupe ($LastResolvedShipName) before set_object_name.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="nameType" default="'trader'"/>
    <param name="force" default="false"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists">
        <return value="false"/>
      </do_if>

      <signal_objects object="player.galaxy" param="'GT_Refresh_Ship_Name'" param2="table[
        $Ship = $ship,
        $nameType = $nameType,
        $force = $force
      ]"/>
      <return value="true"/>
    </actions>
  </attention>
</aiscript>
