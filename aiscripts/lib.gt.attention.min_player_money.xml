<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.min_player_money" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Resolves the effective `MinPlayerMoney` setting (in credits) used by every
    money-gate and the authoritative budget guard.

    Read order:
      1) `global.$GT_GlobalSettings.$Fleet.$MinPlayerMoney` (when present and > 0)
      2) Fallback to 1000 (the historical default if settings are not yet populated)

    Replaces ~10 inline `do_if value="not this.$minPlayerMoney?"` resolve blocks
    that were copy-pasted across `init`, `main_loop`, the early-money-gate region,
    `trade_found` fast-money short-circuit, the budget clamp, and the logbook —
    each of which redid the same `?-and-!=null-and-gt 0` triple guard against the
    same global. See DOCS/MK3_PIPELINE_REFACTOR.md §3.11.
  -->
  <attention min="unknown">
    <actions>
      <set_value name="$resolved" exact="1000"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Fleet? and global.$GT_GlobalSettings.$Fleet.$MinPlayerMoney?">
        <set_value name="$tmpMinMoney" exact="@global.$GT_GlobalSettings.$Fleet.$MinPlayerMoney"/>
        <do_if value="$tmpMinMoney? and $tmpMinMoney != null and $tmpMinMoney gt 0">
          <set_value name="$resolved" exact="$tmpMinMoney"/>
        </do_if>
      </do_if>
      <return value="$resolved"/>
    </actions>
  </attention>
</aiscript>
