<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_Context_Sector_Blacklist" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <cues>
    <!-- ============================================================ -->
    <!-- GT Sector Blacklist Diagnose                                  -->
    <!-- Right-click any sector -> GalaxyTrader -> GT Diagnose         -->
    <!-- Focus: stuck-BL episode (reporter + tracked hostiles + regs)  -->
    <!-- ============================================================ -->

    <cue name="RegisterGTActionGroup" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'Interact_Menu_API'" control="'reloaded'"/>
      </conditions>
      <actions>
        <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Id'" param="'gt_actions'"/>
        <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Text'" param="'GalaxyTrader'"/>
      </actions>
    </cue>

    <cue name="AddSectorBlacklistDiagnoseAction" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Interact_Menu_API.Get_Actions"/>
      </conditions>
      <actions>
        <set_value name="$target" exact="event.param.$object"/>
        <do_if value="$target? and $target.exists and $target.isclass.{class.sector}">
          <signal_cue_instantly
            cue="md.Interact_Menu_API.Add_Action"
            param="table[
              $id         = 'gt_mk3_sector_blacklist_diagnose',
              $text       = 'GT Diagnose',
              $section    = 'gt_actions',
              $callback   = GT_SectorBlacklistDiagnoseAction,
            ]"/>
        </do_if>
      </actions>
    </cue>

    <cue name="GT_SectorBlacklistDiagnoseAction" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$sector" exact="event.param.$object"/>
        <set_value name="$deny" exact="false"/>
        <do_if value="not $sector? or not $sector.exists or not $sector.isclass.{class.sector}">
          <show_notification text="'GT Diagnose: invalid sector target'" timeout="5s"/>
          <set_value name="$deny" exact="true"/>
        </do_if>

        <do_if value="not $deny">
        <show_notification text="'GT Diagnose: Sector blacklist report for ' + $sector.knownname + '...'" timeout="5s"/>

        <set_value name="$sectorMacro" exact="'' + @$sector.macro.id"/>
        <set_value name="$threatKey" exact="'$' + $sectorMacro"/>
        <set_value name="$hasThreat" exact="false"/>
        <set_value name="$threat" exact="null"/>
        <do_if value="global.$GT_ThreatIntelligence? and global.$GT_ThreatIntelligence.{$threatKey}?">
          <set_value name="$hasThreat" exact="true"/>
          <set_value name="$threat" exact="global.$GT_ThreatIntelligence.{$threatKey}"/>
        </do_if>

        <!-- Vanilla GT fleet blacklist: query macros directly via Lua (no ship isblacklisted probe) -->
        <set_value name="$onVanillaGT" exact="false"/>
        <set_value name="$lastWrittenHas" exact="false"/>
        <set_value name="$vanillaQueryOk" exact="false"/>
        <set_value name="$vanillaInitialized" exact="false"/>
        <set_value name="$vanillaFleetId" exact="0"/>
        <set_value name="$vanillaMacroCount" exact="0"/>
        <remove_value name="player.entity.$GT_SectorBL_VanillaQueryReady"/>
        <remove_value name="player.entity.$GT_SectorBL_VanillaOnGT"/>
        <remove_value name="player.entity.$GT_SectorBL_LastWrittenHas"/>
        <set_value name="player.entity.$GT_SectorBL_QueryMacro" exact="$sectorMacro"/>
        <raise_lua_event name="'GT_Blacklist.QuerySectorMacro'" param="$sectorMacro"/>
        <!-- Persist across delay so Lua blackboard write is visible to MD -->
        <set_value name="this.$Deny" exact="$deny"/>
        <set_value name="this.$Sector" exact="$sector"/>
        <set_value name="this.$SectorMacro" exact="$sectorMacro"/>
        <set_value name="this.$ThreatKey" exact="$threatKey"/>
        <set_value name="this.$HasThreat" exact="$hasThreat"/>
        <set_value name="this.$Threat" exact="$threat"/>
        </do_if>
        <do_else>
          <set_value name="this.$Deny" exact="true"/>
        </do_else>
      </actions>
      <delay exact="1ms"/>
      <actions>
        <do_if value="not this.$Deny">
        <set_value name="$sector" exact="this.$Sector"/>
        <set_value name="$sectorMacro" exact="this.$SectorMacro"/>
        <set_value name="$threatKey" exact="this.$ThreatKey"/>
        <set_value name="$hasThreat" exact="this.$HasThreat"/>
        <set_value name="$threat" exact="this.$Threat"/>

        <set_value name="$onVanillaGT" exact="false"/>
        <set_value name="$lastWrittenHas" exact="false"/>
        <set_value name="$vanillaQueryOk" exact="false"/>
        <set_value name="$vanillaInitialized" exact="false"/>
        <set_value name="$vanillaFleetId" exact="0"/>
        <set_value name="$vanillaMacroCount" exact="0"/>
        <do_if value="player.entity.$GT_SectorBL_VanillaQueryReady? and player.entity.$GT_SectorBL_VanillaQueryReady">
          <set_value name="$vanillaQueryOk" exact="true"/>
          <do_if value="player.entity.$GT_SectorBL_VanillaOnGT? and player.entity.$GT_SectorBL_VanillaOnGT">
            <set_value name="$onVanillaGT" exact="true"/>
          </do_if>
          <do_if value="player.entity.$GT_SectorBL_LastWrittenHas? and player.entity.$GT_SectorBL_LastWrittenHas">
            <set_value name="$lastWrittenHas" exact="true"/>
          </do_if>
          <do_if value="player.entity.$GT_SectorBL_VanillaInitialized? and player.entity.$GT_SectorBL_VanillaInitialized">
            <set_value name="$vanillaInitialized" exact="true"/>
          </do_if>
          <do_if value="player.entity.$GT_SectorBL_VanillaFleetId?">
            <set_value name="$vanillaFleetId" exact="player.entity.$GT_SectorBL_VanillaFleetId"/>
          </do_if>
          <do_if value="player.entity.$GT_SectorBL_VanillaMacroCount?">
            <set_value name="$vanillaMacroCount" exact="player.entity.$GT_SectorBL_VanillaMacroCount"/>
          </do_if>
        </do_if>
        <do_else>
          <debug_text text="'[GT SectorBL] Vanilla query not ready after Lua raise (handler missing? reload UI / restart). macro=' + $sectorMacro" chance="100"/>
        </do_else>
        <!-- Keep $engineBL alias for verdict text compatibility (= on GT vanilla fleet list) -->
        <set_value name="$engineBL" exact="$onVanillaGT"/>

        <!-- Registry membership -->
        <run_actions ref="md.GT_ThreatIntelligence.EnsureBlacklistRegistryGlobals"/>
        <set_value name="$inAutoList" exact="false"/>
        <set_value name="$inPendingRemove" exact="false"/>
        <set_value name="$inDismissed" exact="false"/>
        <set_value name="$dismissedIdcodes" exact="[]"/>
        <do_if value="global.$GT_AutoBlacklistedMacroList?">
          <do_all exact="global.$GT_AutoBlacklistedMacroList.count" counter="$ai">
            <do_if value="global.$GT_AutoBlacklistedMacroList.{$ai} == $sectorMacro">
              <set_value name="$inAutoList" exact="true"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>
        <do_if value="global.$GT_PendingBlacklistMacroRemovals?">
          <do_all exact="global.$GT_PendingBlacklistMacroRemovals.count" counter="$pi">
            <do_if value="global.$GT_PendingBlacklistMacroRemovals.{$pi} == $sectorMacro">
              <set_value name="$inPendingRemove" exact="true"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>
        <do_if value="global.$GT_PlayerDismissedHostileEntries?">
          <do_all exact="global.$GT_PlayerDismissedHostileEntries.count" counter="$di">
            <set_value name="$dEntry" exact="global.$GT_PlayerDismissedHostileEntries.{$di}"/>
            <do_if value="$dEntry.$SectorMacro? and $dEntry.$SectorMacro == $sectorMacro">
              <set_value name="$inDismissed" exact="true"/>
              <do_if value="$dEntry.$Idcodes?">
                <set_value name="$dismissedIdcodes" exact="$dEntry.$Idcodes"/>
              </do_if>
              <break/>
            </do_if>
          </do_all>
        </do_if>

        <set_value name="$threatAvoidEnabled" exact="@global.$GT_GlobalSettings.$ThreatAvoidance.$Enabled"/>
        <set_value name="$useDynamicBL" exact="@global.$GT_GlobalSettings.$ThreatAvoidance.$UseDynamicBlacklist"/>
        <set_value name="$blThreshold" exact="@global.$GT_GlobalSettings.$ThreatAvoidance.$BlacklistThreshold"/>
        <do_if value="not $blThreshold?">
          <set_value name="$blThreshold" exact="3"/>
        </do_if>
        <set_value name="$blacklistEpoch" exact="if global.$GT_BlacklistEpoch? then global.$GT_BlacklistEpoch else 0"/>

        <set_value name="$shouldBL" exact="false"/>
        <do_if value="$hasThreat">
          <do_if value="$threat.$ShouldBlacklist?">
            <set_value name="$shouldBL" exact="$threat.$ShouldBlacklist"/>
          </do_if>
        </do_if>

        <!-- Tracked hostile live analysis -->
        <set_value name="$trackedShips" exact="[]"/>
        <set_value name="$trackedIdcodes" exact="[]"/>
        <do_if value="$hasThreat">
          <do_if value="$threat.$TrackedEnemyShips?">
            <set_value name="$trackedShips" exact="$threat.$TrackedEnemyShips"/>
          </do_if>
          <do_if value="$threat.$TrackedEnemyShipIdcodes?">
            <set_value name="$trackedIdcodes" exact="$threat.$TrackedEnemyShipIdcodes"/>
          </do_if>
        </do_if>
        <set_value name="$trackedShipCount" exact="$trackedShips.count"/>
        <set_value name="$trackedIdCount" exact="$trackedIdcodes.count"/>
        <set_value name="$scanCount" exact="[$trackedShipCount, $trackedIdCount].max"/>
        <set_value name="$liveInSector" exact="0"/>
        <set_value name="$liveElsewhere" exact="0"/>
        <set_value name="$deadOrInvalid" exact="0"/>
        <set_value name="$inDestroyGroupCount" exact="0"/>

        <do_all exact="$scanCount" counter="$ti">
          <set_value name="$tShip" exact="null"/>
          <set_value name="$tId" exact="''"/>
          <do_if value="$ti le $trackedShipCount and $trackedShips.{$ti}?">
            <set_value name="$tShip" exact="$trackedShips.{$ti}"/>
          </do_if>
          <do_if value="$ti le $trackedIdCount and $trackedIdcodes.{$ti}?">
            <set_value name="$tId" exact="'' + $trackedIdcodes.{$ti}"/>
          </do_if>

          <set_value name="$shipAlive" exact="false"/>
          <do_if value="$tShip? and $tShip != null and @$tShip.exists">
            <set_value name="$shipAlive" exact="true"/>
          </do_if>

          <do_if value="not $shipAlive">
            <set_value name="$deadOrInvalid" exact="$deadOrInvalid + 1"/>
          </do_if>
          <do_else>
            <do_if value="global.$GT_TrackedEnemyShipsGroup? and global.$GT_TrackedEnemyShipsGroup.indexof.{$tShip} gt 0">
              <set_value name="$inDestroyGroupCount" exact="$inDestroyGroupCount + 1"/>
            </do_if>
            <set_value name="$inThisSector" exact="false"/>
            <do_if value="$tShip.sector?">
              <do_if value="$tShip.sector == $sector">
                <set_value name="$inThisSector" exact="true"/>
              </do_if>
              <do_elseif value="$tShip.sector.macro.id? and $tShip.sector.macro.id == $sectorMacro">
                <set_value name="$inThisSector" exact="true"/>
              </do_elseif>
            </do_if>
            <do_if value="$inThisSector and @$tShip.isoperational">
              <set_value name="$liveInSector" exact="$liveInSector + 1"/>
            </do_if>
            <do_else>
              <set_value name="$liveElsewhere" exact="$liveElsewhere + 1"/>
            </do_else>
          </do_else>
        </do_all>

        <!-- VERDICT -->
        <set_value name="$verdict" exact="'OK: no GT threat intel and no vanilla/registry blacklist for this sector'"/>
        <set_value name="$verdictStatus" exact="'PASS'"/>
        <do_if value="$liveInSector gt 0">
          <set_value name="$verdict" exact="'ACTIVE: ' + $liveInSector + ' tracked hostile(s) still live in sector (tracked entries=' + $scanCount + ')'"/>
          <set_value name="$verdictStatus" exact="'WARN'"/>
        </do_if>
        <do_elseif value="$inPendingRemove">
          <set_value name="$verdict" exact="'PENDING CLEAR: sector macro is in $GT_PendingBlacklistMacroRemovals (onVanillaGT=' + $onVanillaGT + ', inAutoList=' + $inAutoList + ')'"/>
          <set_value name="$verdictStatus" exact="'WARN'"/>
        </do_elseif>
        <do_elseif value="($onVanillaGT or $inAutoList or $shouldBL) and $liveInSector == 0 and $scanCount gt 0 and $deadOrInvalid == $scanCount">
          <set_value name="$verdict" exact="'STUCK: all ' + $scanCount + ' tracked hostile(s) are destroyed/invalid but sector still blacklisted (onVanillaGT=' + $onVanillaGT + ', ShouldBlacklist=' + $shouldBL + ', inAutoList=' + $inAutoList + ')'"/>
          <set_value name="$verdictStatus" exact="'FAIL'"/>
        </do_elseif>
        <do_elseif value="($onVanillaGT or $inAutoList or $shouldBL) and $liveInSector == 0 and $scanCount == 0 and $hasThreat">
          <set_value name="$verdict" exact="'STUCK: threat row exists with ShouldBlacklist/vanilla/auto BL but zero tracked hostiles (onVanillaGT=' + $onVanillaGT + ', ShouldBlacklist=' + $shouldBL + ', inAutoList=' + $inAutoList + ')'"/>
          <set_value name="$verdictStatus" exact="'FAIL'"/>
        </do_elseif>
        <do_elseif value="($onVanillaGT or $inAutoList) and not $hasThreat">
          <set_value name="$verdict" exact="'STUCK/ORPHAN: vanilla GT and/or auto-macro blacklist present but no $GT_ThreatIntelligence row (onVanillaGT=' + $onVanillaGT + ', inAutoList=' + $inAutoList + ')'"/>
          <set_value name="$verdictStatus" exact="'FAIL'"/>
        </do_elseif>
        <do_elseif value="$shouldBL != $onVanillaGT or $shouldBL != $inAutoList or $onVanillaGT != $inAutoList">
          <set_value name="$verdict" exact="'MISMATCH: ShouldBlacklist=' + $shouldBL + ' onVanillaGT=' + $onVanillaGT + ' inAutoList=' + $inAutoList + ' lastWritten=' + $lastWrittenHas + ' (liveInSector=' + $liveInSector + ')'"/>
          <set_value name="$verdictStatus" exact="'WARN'"/>
        </do_elseif>
        <do_elseif value="$hasThreat">
          <set_value name="$verdict" exact="'INFO: threat intel present - ShouldBlacklist=' + $shouldBL + ', tracked=' + $scanCount + ', liveInSector=' + $liveInSector"/>
          <set_value name="$verdictStatus" exact="'INFO'"/>
        </do_elseif>

        <!-- Build report sections -->
        <set_value name="$report" exact="table[]"/>
        <set_value name="$report.$Sections" exact="[]"/>

        <!-- Section: Verdict -->
        <set_value name="$secV" exact="table[$Name = 'Verdict', $Rows = []]"/>
        <append_to_list name="$secV.$Rows" exact="table[$Status = $verdictStatus, $Check = 'VERDICT', $Detail = $verdict]"/>
        <append_to_list name="$secV.$Rows" exact="table[$Status = 'INFO', $Check = 'Sector', $Detail = $sector.knownname + ' (' + $sectorMacro + ')']"/>
        <append_to_list name="$secV.$Rows" exact="table[$Status = 'INFO', $Check = 'Game time', $Detail = '' + player.age + 's']"/>
        <append_to_list name="$report.$Sections" exact="$secV"/>

        <!-- Section: Attribution -->
        <set_value name="$secA" exact="table[$Name = 'Attribution', $Rows = []]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'ThreatAvoidance.Enabled', $Detail = '' + $threatAvoidEnabled]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'UseDynamicBlacklist', $Detail = '' + $useDynamicBL]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'BlacklistThreshold', $Detail = '' + $blThreshold]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = if $shouldBL then 'WARN' else 'INFO', $Check = 'ShouldBlacklist (intel)', $Detail = if $hasThreat then ('' + $shouldBL) else 'n/a (no threat row)']"/>
        <set_value name="$vanillaRowStatus" exact="'PASS'"/>
        <do_if value="not $vanillaQueryOk">
          <set_value name="$vanillaRowStatus" exact="'WARN'"/>
        </do_if>
        <do_elseif value="$onVanillaGT">
          <set_value name="$vanillaRowStatus" exact="'FAIL'"/>
        </do_elseif>
        <append_to_list name="$secA.$Rows" exact="table[$Status = $vanillaRowStatus, $Check = 'On vanilla GT fleet blacklist', $Detail = if $vanillaQueryOk then ('' + $onVanillaGT) else 'query failed (Lua not ready?)']"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'GT fleet blacklist id', $Detail = if $vanillaQueryOk then ('' + $vanillaFleetId + ' (initialized=' + $vanillaInitialized + ', macros=' + $vanillaMacroCount + ')') else 'n/a']"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = if $lastWrittenHas then 'WARN' else 'INFO', $Check = 'In Lua last_written_macros', $Detail = if $vanillaQueryOk then ('' + $lastWrittenHas) else 'n/a']"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = if $inAutoList then 'WARN' else 'INFO', $Check = 'In AutoBlacklistedMacroList', $Detail = '' + $inAutoList]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = if $inPendingRemove then 'WARN' else 'INFO', $Check = 'In PendingBlacklistMacroRemovals', $Detail = '' + $inPendingRemove]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'In PlayerDismissedHostileEntries', $Detail = '' + $inDismissed]"/>
        <append_to_list name="$secA.$Rows" exact="table[$Status = 'INFO', $Check = 'BlacklistEpoch', $Detail = '' + $blacklistEpoch]"/>
        <append_to_list name="$report.$Sections" exact="$secA"/>

        <!-- Section: Threat Intel -->
        <set_value name="$secT" exact="table[$Name = 'Threat Intel', $Rows = []]"/>
        <do_if value="not $hasThreat">
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'PASS', $Check = 'Threat row', $Detail = 'none for key ' + $threatKey]"/>
        </do_if>
        <do_else>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'Threat key', $Detail = $threatKey]"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'ThreatLevel', $Detail = if $threat.$ThreatLevel? then ('' + $threat.$ThreatLevel) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'ThreatType', $Detail = if $threat.$ThreatType? then ('' + $threat.$ThreatType) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'ThreatScore', $Detail = if $threat.$ThreatScore? then ('' + $threat.$ThreatScore) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'HostileCount', $Detail = if $threat.$HostileCount? then ('' + $threat.$HostileCount) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'Timestamp', $Detail = if $threat.$Timestamp? then ('' + $threat.$Timestamp + 's (age ' + (player.age - $threat.$Timestamp) + 's)') else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'AttackerFaction', $Detail = if $threat.$AttackerFaction? then ('' + $threat.$AttackerFaction) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'AttackerType/idcode', $Detail = if $threat.$AttackerType? then ('' + $threat.$AttackerType) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'PrimaryFaction', $Detail = if $threat.$PrimaryFaction? then ('' + $threat.$PrimaryFaction) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'Class counts XL/L/M/S', $Detail = (if $threat.$ShipClass_XL? then ('' + $threat.$ShipClass_XL) else '0') + '/' + (if $threat.$ShipClass_L? then ('' + $threat.$ShipClass_L) else '0') + '/' + (if $threat.$ShipClass_M? then ('' + $threat.$ShipClass_M) else '0') + '/' + (if $threat.$ShipClass_S? then ('' + $threat.$ShipClass_S) else '0')]"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'SectorMacro stored', $Detail = if $threat.$SectorMacro? then ('' + $threat.$SectorMacro) else 'n/a']"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'Tracked ships / idcodes', $Detail = '' + $trackedShipCount + ' / ' + $trackedIdCount]"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = if $trackedShipCount != $trackedIdCount then 'WARN' else 'PASS', $Check = 'List/idcode count match', $Detail = if $trackedShipCount == $trackedIdCount then 'yes' else 'MISMATCH ships=' + $trackedShipCount + ' idcodes=' + $trackedIdCount]"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'Live in sector / elsewhere / dead', $Detail = '' + $liveInSector + ' / ' + $liveElsewhere + ' / ' + $deadOrInvalid]"/>
          <append_to_list name="$secT.$Rows" exact="table[$Status = 'INFO', $Check = 'In destroy listener group', $Detail = '' + $inDestroyGroupCount + ' of live entries']"/>
        </do_else>
        <append_to_list name="$report.$Sections" exact="$secT"/>

        <!-- Section: Reporter -->
        <set_value name="$secR" exact="table[$Name = 'Reporter', $Rows = []]"/>
        <set_value name="$detectedByName" exact="''"/>
        <set_value name="$reportingName" exact="''"/>
        <set_value name="$victimName" exact="''"/>
        <do_if value="$hasThreat">
          <do_if value="$threat.$DetectedBy?">
            <set_value name="$detectedByName" exact="'' + $threat.$DetectedBy"/>
          </do_if>
          <do_if value="$threat.$ReportingShip?">
            <set_value name="$reportingName" exact="'' + $threat.$ReportingShip"/>
          </do_if>
          <do_if value="$threat.$VictimShip?">
            <set_value name="$victimName" exact="'' + $threat.$VictimShip"/>
          </do_if>
        </do_if>
        <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'DetectedBy (stored)', $Detail = if $detectedByName != '' then $detectedByName else 'n/a']"/>
        <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'ReportingShip (stored)', $Detail = if $reportingName != '' then $reportingName else 'n/a']"/>
        <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'VictimShip (stored)', $Detail = if $victimName != '' then $victimName else 'n/a']"/>

        <set_value name="$reporterShip" exact="null"/>
        <set_value name="$reporterMatch" exact="''"/>
        <do_if value="global.$GT_Ships? and ($detectedByName != '' or $reportingName != '' or $victimName != '')">
          <do_all exact="global.$GT_Ships.keys.count" counter="$ri">
            <set_value name="$cand" exact="global.$GT_Ships.keys.list.{$ri}"/>
            <do_if value="$cand? and @$cand.exists">
              <set_value name="$candName" exact="'' + $cand.knownname"/>
              <do_if value="$detectedByName != '' and $candName == $detectedByName">
                <set_value name="$reporterShip" exact="$cand"/>
                <set_value name="$reporterMatch" exact="'DetectedBy'"/>
                <break/>
              </do_if>
              <do_elseif value="$reportingName != '' and $candName == $reportingName">
                <set_value name="$reporterShip" exact="$cand"/>
                <set_value name="$reporterMatch" exact="'ReportingShip'"/>
                <break/>
              </do_elseif>
              <do_elseif value="$victimName != '' and $candName == $victimName">
                <set_value name="$reporterShip" exact="$cand"/>
                <set_value name="$reporterMatch" exact="'VictimShip'"/>
                <break/>
              </do_elseif>
            </do_if>
          </do_all>
        </do_if>

        <do_if value="$reporterShip? and $reporterShip != null">
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'PASS', $Check = 'Resolved reporter', $Detail = $reporterShip.knownname + ' (' + $reporterShip.idcode + ') via ' + $reporterMatch]"/>
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'Reporter exists', $Detail = '' + @$reporterShip.exists]"/>
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'Reporter sector', $Detail = if $reporterShip.sector? then $reporterShip.sector.knownname else 'n/a']"/>
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'Reporter order', $Detail = if $reporterShip.defaultorder? then ('' + @$reporterShip.defaultorder.id) else 'n/a']"/>
          <do_if value="global.$GT_Ships.{$reporterShip}?">
            <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'ThreatReports', $Detail = if global.$GT_Ships.{$reporterShip}.$ThreatReports? then ('' + global.$GT_Ships.{$reporterShip}.$ThreatReports) else '0']"/>
            <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'LastThreatTime', $Detail = if global.$GT_Ships.{$reporterShip}.$LastThreatTime? then ('' + global.$GT_Ships.{$reporterShip}.$LastThreatTime + 's (age ' + (player.age - global.$GT_Ships.{$reporterShip}.$LastThreatTime) + 's)') else 'n/a']"/>
          </do_if>
          <do_else>
            <append_to_list name="$secR.$Rows" exact="table[$Status = 'WARN', $Check = 'GT_Ships registry', $Detail = 'resolved ship not in global.$GT_Ships']"/>
          </do_else>
        </do_if>
        <do_elseif value="$hasThreat">
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'WARN', $Check = 'Resolved reporter', $Detail = 'could not match stored names to a live GT ship']"/>
        </do_elseif>
        <do_else>
          <append_to_list name="$secR.$Rows" exact="table[$Status = 'INFO', $Check = 'Resolved reporter', $Detail = 'n/a']"/>
        </do_else>
        <append_to_list name="$report.$Sections" exact="$secR"/>

        <!-- Section: Tracked Hostiles -->
        <set_value name="$secH" exact="table[$Name = 'Tracked Hostiles', $Rows = []]"/>
        <do_if value="$scanCount == 0">
          <append_to_list name="$secH.$Rows" exact="table[$Status = 'INFO', $Check = 'Tracked list', $Detail = 'empty']"/>
        </do_if>
        <do_else>
          <do_all exact="$scanCount" counter="$hi">
            <set_value name="$hShip" exact="null"/>
            <set_value name="$hId" exact="''"/>
            <do_if value="$hi le $trackedShipCount and $trackedShips.{$hi}?">
              <set_value name="$hShip" exact="$trackedShips.{$hi}"/>
            </do_if>
            <do_if value="$hi le $trackedIdCount and $trackedIdcodes.{$hi}?">
              <set_value name="$hId" exact="'' + $trackedIdcodes.{$hi}"/>
            </do_if>

            <set_value name="$hStatus" exact="'FAIL'"/>
            <set_value name="$hLive" exact="'destroyed-or-invalid'"/>
            <set_value name="$hName" exact="'(no object)'"/>
            <set_value name="$hClass" exact="'?'"/>
            <set_value name="$hFaction" exact="'?'"/>
            <set_value name="$hSector" exact="'n/a'"/>
            <set_value name="$hInGroup" exact="'no'"/>

            <do_if value="$hShip? and $hShip != null and @$hShip.exists">
              <set_value name="$hName" exact="'' + $hShip.knownname"/>
              <do_if value="$hId == ''">
                <set_value name="$hId" exact="'' + @$hShip.idcode"/>
              </do_if>
              <set_value name="$hFaction" exact="if $hShip.owner? then ('' + $hShip.owner.knownname) else '?'"/>
              <do_if value="$hShip.isclass.ship_xl">
                <set_value name="$hClass" exact="'XL'"/>
              </do_if>
              <do_elseif value="$hShip.isclass.ship_l">
                <set_value name="$hClass" exact="'L'"/>
              </do_elseif>
              <do_elseif value="$hShip.isclass.ship_m">
                <set_value name="$hClass" exact="'M'"/>
              </do_elseif>
              <do_elseif value="$hShip.isclass.ship_s">
                <set_value name="$hClass" exact="'S'"/>
              </do_elseif>
              <do_else>
                <set_value name="$hClass" exact="'other'"/>
              </do_else>
              <set_value name="$hSector" exact="if $hShip.sector? then $hShip.sector.knownname else 'n/a'"/>
              <do_if value="global.$GT_TrackedEnemyShipsGroup? and global.$GT_TrackedEnemyShipsGroup.indexof.{$hShip} gt 0">
                <set_value name="$hInGroup" exact="'yes'"/>
              </do_if>
              <set_value name="$hInSector" exact="false"/>
              <do_if value="$hShip.sector? and ($hShip.sector == $sector or ($hShip.sector.macro.id? and $hShip.sector.macro.id == $sectorMacro))">
                <set_value name="$hInSector" exact="true"/>
              </do_if>
              <do_if value="not @$hShip.isoperational">
                <set_value name="$hLive" exact="'exists-not-operational'"/>
                <set_value name="$hStatus" exact="'WARN'"/>
              </do_if>
              <do_elseif value="$hInSector">
                <set_value name="$hLive" exact="'in-sector'"/>
                <set_value name="$hStatus" exact="'WARN'"/>
              </do_elseif>
              <do_else>
                <set_value name="$hLive" exact="'left-sector'"/>
                <set_value name="$hStatus" exact="'WARN'"/>
              </do_else>
            </do_if>
            <do_else>
              <do_if value="$hId == ''">
                <set_value name="$hId" exact="'UNKNOWN'"/>
              </do_if>
            </do_else>

            <append_to_list name="$secH.$Rows" exact="table[
              $Status = $hStatus,
              $Check = '#' + $hi + ' ' + $hId,
              $Detail = $hName + ' | class=' + $hClass + ' | faction=' + $hFaction + ' | sector=' + $hSector + ' | live=' + $hLive + ' | destroyGroup=' + $hInGroup
            ]"/>
          </do_all>
        </do_else>
        <append_to_list name="$report.$Sections" exact="$secH"/>

        <!-- Section: Registries -->
        <set_value name="$secG" exact="table[$Name = 'Registries', $Rows = []]"/>
        <append_to_list name="$secG.$Rows" exact="table[$Status = if $inAutoList then 'WARN' else 'PASS', $Check = 'AutoBlacklistedMacroList', $Detail = if $inAutoList then ('YES - ' + $sectorMacro) else ('no - ' + $sectorMacro)]"/>
        <append_to_list name="$secG.$Rows" exact="table[$Status = if $inPendingRemove then 'WARN' else 'PASS', $Check = 'PendingBlacklistMacroRemovals', $Detail = if $inPendingRemove then ('YES - ' + $sectorMacro) else 'no']"/>
        <append_to_list name="$secG.$Rows" exact="table[$Status = 'INFO', $Check = 'PlayerDismissedHostileEntries', $Detail = if $inDismissed then ('YES - idcodes=' + $dismissedIdcodes.count) else 'no']"/>
        <do_if value="$inDismissed and $dismissedIdcodes.count gt 0">
          <do_all exact="$dismissedIdcodes.count" counter="$dii">
            <append_to_list name="$secG.$Rows" exact="table[$Status = 'INFO', $Check = 'Dismissed idcode #' + $dii, $Detail = '' + $dismissedIdcodes.{$dii}]"/>
          </do_all>
        </do_if>
        <append_to_list name="$secG.$Rows" exact="table[$Status = 'INFO', $Check = 'TrackedEnemyShipsGroup count', $Detail = if global.$GT_TrackedEnemyShipsGroup? then ('' + global.$GT_TrackedEnemyShipsGroup.count) else 'group missing']"/>
        <append_to_list name="$secG.$Rows" exact="table[$Status = 'INFO', $Check = 'BlacklistEpoch', $Detail = '' + $blacklistEpoch]"/>
        <append_to_list name="$report.$Sections" exact="$secG"/>

        <!-- Serialize -->
        <set_value name="$serialized" exact="''"/>
        <do_all exact="$report.$Sections.count" counter="$secIdx">
          <set_value name="$sec" exact="$report.$Sections.{$secIdx}"/>
          <do_if value="$secIdx gt 1">
            <set_value name="$serialized" exact="$serialized + '@@'"/>
          </do_if>
          <set_value name="$serialized" exact="$serialized + $sec.$Name"/>
          <do_all exact="$sec.$Rows.count" counter="$rowIdx">
            <set_value name="$row" exact="$sec.$Rows.{$rowIdx}"/>
            <do_if value="$row?">
              <set_value name="$serialized" exact="$serialized + ';;' + $row.$Status + '||' + $row.$Check + '||' + $row.$Detail"/>
            </do_if>
          </do_all>
        </do_all>

        <set_value name="player.entity.$GT_SectorBL_Report" exact="$serialized"/>
        <set_value name="player.entity.$GT_SectorBL_SectorId" exact="$sectorMacro"/>
        <set_value name="player.entity.$GT_SectorBL_SectorName" exact="$sector.knownname"/>
        <set_value name="player.entity.$GT_SectorBL_Timestamp" exact="player.age"/>

        <!-- Always log (not gated by debug toggle) -->
        <debug_text text="'[GT SectorBL] ================================================================'" chance="100"/>
        <debug_text text="'[GT SectorBL] SECTOR BLACKLIST REPORT for ' + $sector.knownname + ' (' + $sectorMacro + ')'" chance="100"/>
        <debug_text text="'[GT SectorBL] VERDICT: ' + $verdict" chance="100"/>
        <debug_text text="'[GT SectorBL] ================================================================'" chance="100"/>
        <do_all exact="$report.$Sections.count" counter="$logSecIdx">
          <set_value name="$logSec" exact="$report.$Sections.{$logSecIdx}"/>
          <debug_text text="'[GT SectorBL] --- ' + $logSec.$Name + ' ---'" chance="100"/>
          <do_all exact="$logSec.$Rows.count" counter="$logRowIdx">
            <set_value name="$logRow" exact="$logSec.$Rows.{$logRowIdx}"/>
            <do_if value="$logRow?">
              <debug_text text="'[GT SectorBL]   [' + $logRow.$Status + '] ' + $logRow.$Check + ': ' + $logRow.$Detail" chance="100"/>
            </do_if>
          </do_all>
        </do_all>
        <debug_text text="'[GT SectorBL] ================================================================'" chance="100"/>

        <raise_lua_event name="'gt.openSectorBlacklistReport'" param="$sector"/>
        </do_if>
      </actions>
    </cue>

    <!-- Clear AutoBlacklistedMacroList entries that have no active threat row, queue #rem=, resync vanilla. -->
    <cue name="GT_SectorBlacklistClearOrphans" instantiate="true">
      <conditions>
        <event_object_signalled object="player.entity" param="'gt_sector_bl_clear_orphans'"/>
      </conditions>
      <actions>
        <run_actions ref="md.GT_ThreatIntelligence.EnsureBlacklistRegistryGlobals"/>
        <set_value name="$focusMacro" exact="''"/>
        <do_if value="player.entity.$GT_SectorBL_ClearOrphansMacro?">
          <set_value name="$focusMacro" exact="'' + player.entity.$GT_SectorBL_ClearOrphansMacro"/>
        </do_if>
        <do_elseif value="player.entity.$GT_SectorBL_SectorId?">
          <set_value name="$focusMacro" exact="'' + player.entity.$GT_SectorBL_SectorId"/>
        </do_elseif>

        <set_value name="$orphanMacros" exact="[]"/>
        <set_value name="$clearedCount" exact="0"/>

        <!-- Collect auto-list macros with no active ShouldBlacklist threat row -->
        <do_if value="global.$GT_AutoBlacklistedMacroList? and global.$GT_AutoBlacklistedMacroList.count gt 0">
          <do_all exact="global.$GT_AutoBlacklistedMacroList.count" counter="$ai">
            <set_value name="$autoMacro" exact="'' + global.$GT_AutoBlacklistedMacroList.{$ai}"/>
            <set_value name="$hasActiveThreat" exact="false"/>
            <do_if value="global.$GT_ThreatIntelligence? and global.$GT_ThreatIntelligence.{'$' + $autoMacro}?">
              <set_value name="$tiRow" exact="global.$GT_ThreatIntelligence.{'$' + $autoMacro}"/>
              <do_if value="$tiRow.$ShouldBlacklist? and $tiRow.$ShouldBlacklist">
                <set_value name="$hasActiveThreat" exact="true"/>
              </do_if>
            </do_if>
            <do_if value="not $hasActiveThreat">
              <append_to_list name="$orphanMacros" exact="$autoMacro"/>
            </do_if>
          </do_all>
        </do_if>

        <!-- Always include diagnose focus macro when it has no active threat row -->
        <do_if value="$focusMacro != ''">
          <set_value name="$focusActive" exact="false"/>
          <do_if value="global.$GT_ThreatIntelligence? and global.$GT_ThreatIntelligence.{'$' + $focusMacro}?">
            <set_value name="$focusRow" exact="global.$GT_ThreatIntelligence.{'$' + $focusMacro}"/>
            <do_if value="$focusRow.$ShouldBlacklist? and $focusRow.$ShouldBlacklist">
              <set_value name="$focusActive" exact="true"/>
            </do_if>
          </do_if>
          <do_if value="not $focusActive">
            <set_value name="$alreadyQueued" exact="false"/>
            <do_all exact="$orphanMacros.count" counter="$oi">
              <do_if value="$orphanMacros.{$oi} == $focusMacro">
                <set_value name="$alreadyQueued" exact="true"/>
                <break/>
              </do_if>
            </do_all>
            <do_if value="not $alreadyQueued">
              <append_to_list name="$orphanMacros" exact="$focusMacro"/>
            </do_if>
          </do_if>
        </do_if>

        <do_all exact="$orphanMacros.count" counter="$ci">
          <set_value name="$clearMacro" exact="$orphanMacros.{$ci}"/>
          <run_actions ref="md.GT_ThreatIntelligence.QueueBlacklistMacroRemoval">
            <param name="SectorMacro" value="$clearMacro"/>
          </run_actions>
          <!-- Drop any leftover non-blacklisting threat shell for this macro -->
          <do_if value="global.$GT_ThreatIntelligence? and global.$GT_ThreatIntelligence.{'$' + $clearMacro}?">
            <set_value name="$dropRow" exact="global.$GT_ThreatIntelligence.{'$' + $clearMacro}"/>
            <do_if value="not $dropRow.$ShouldBlacklist? or not $dropRow.$ShouldBlacklist">
              <do_if value="$dropRow.$Sector?">
                <run_actions ref="md.GT_ThreatIntelligence.GT_RemoveThreatEpisode">
                  <param name="Sector" value="$dropRow.$Sector"/>
                  <param name="DebugChance" value="0"/>
                </run_actions>
              </do_if>
              <do_else>
                <remove_value name="global.$GT_ThreatIntelligence.{'$' + $clearMacro}"/>
              </do_else>
            </do_if>
          </do_if>
          <set_value name="$clearedCount" exact="$clearedCount + 1"/>
          <debug_text text="'[GT SectorBL] Cleared orphan auto-macro: ' + $clearMacro" chance="100"/>
        </do_all>

        <remove_value name="player.entity.$GT_SectorBL_ClearOrphansMacro"/>

        <do_if value="$clearedCount gt 0">
          <signal_cue_instantly cue="md.GT_ThreatIntelligence.UpdateBlacklistOnThreat"/>
          <show_notification text="'GT SectorBL: cleared ' + $clearedCount + ' orphan blacklist entr' + (if $clearedCount == 1 then 'y' else 'ies') + ' and resynced'" timeout="8s"/>
          <debug_text text="'[GT SectorBL] Clear Orphans done: cleared=' + $clearedCount + ' focus=' + $focusMacro" chance="100"/>
        </do_if>
        <do_else>
          <show_notification text="'GT SectorBL: no orphan auto-blacklist entries found'" timeout="5s"/>
          <debug_text text="'[GT SectorBL] Clear Orphans: nothing to clear (focus=' + $focusMacro + ')'" chance="100"/>
        </do_else>
      </actions>
      <!-- Cue-level delay only (not inside <actions>): let Lua finish GT_Blacklist.Update before re-query -->
      <delay exact="250ms"/>
      <actions>
        <!-- Re-run diagnose for the focused sector so the panel refreshes -->
        <do_if value="$focusMacro != ''">
          <find_sector name="$refreshSector" macro="macro.{$focusMacro}" space="player.galaxy"/>
          <do_if value="$refreshSector? and @$refreshSector.exists">
            <signal_cue_instantly cue="GT_SectorBlacklistDiagnoseAction" param="table[$object = $refreshSector]"/>
          </do_if>
        </do_if>
      </actions>
    </cue>
  </cues>
</mdscript>
