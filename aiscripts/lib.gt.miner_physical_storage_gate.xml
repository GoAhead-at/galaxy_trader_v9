<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.miner_physical_storage_gate" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Galaxy Miner in-routine physical storage gate (v1).
    Returns table[$Trips = bool, optional $OpenAltWare, optional debug fields when $Trips is true].
    Uses live station physical cargo + sum of relevant miners' bay cargo — not intent estimates.
    Pass $altWareCandidates (+ optional $altWareUrgency) to scan alternates in one invocation.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="ware" default="null"/>
    <param name="primaryTargetStations" default="[]"/>
    <param name="physicalStorageAbortPercent" default="0"/>
    <param name="checkDemandFirst" default="true"/>
    <param name="resourcescout" default="false"/>
    <param name="debugchance" default="0"/>
    <param name="altWareCandidates" default="[]"/>
    <param name="altWareUrgency" default="table[]"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$result" exact="table[$Trips = false]"/>

      <do_if value="not $ware? or $ware == null">
        <return value="$result"/>
      </do_if>
      <do_if value="$physicalStorageAbortPercent le 0">
        <return value="$result"/>
      </do_if>
      <do_if value="not $checkDemandFirst">
        <return value="$result"/>
      </do_if>
      <do_if value="$resourcescout">
        <return value="$result"/>
      </do_if>
      <do_if value="not $primaryTargetStations? or $primaryTargetStations.count le 0">
        <return value="$result"/>
      </do_if>

      <set_value name="$pilotLevelOk" exact="false"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly">
        <do_if value="$ship.pilot? and $ship.pilot.skill.piloting ge 6">
          <set_value name="$pilotLevelOk" exact="true"/>
        </do_if>
      </do_if>
      <do_else>
        <do_if value="$ship.pilot? and global.$GT_Pilots? and global.$GT_Pilots.{$ship.pilot}? and global.$GT_Pilots.{$ship.pilot}.$Level ge 6">
          <set_value name="$pilotLevelOk" exact="true"/>
        </do_if>
      </do_else>
      <do_if value="not $pilotLevelOk">
        <return value="$result"/>
      </do_if>

      <set_value name="$headroomPct" exact="$physicalStorageAbortPercent"/>

      <!-- Check primary ware -->
      <set_value name="$gateCheckWare" exact="$ware"/>
      <set_value name="$gateCheckTrips" exact="false"/>
      <set_value name="$gateCheckReturnAlt" exact="false"/>
      <resume label="gate_check_ware"/>
      <label name="gate_check_return_primary"/>
      <set_value name="$physGateAltScanActive" exact="false"/>
      <do_if value="$gateCheckTrips and $altWareCandidates? and $altWareCandidates.count gt 0">
        <set_value name="$physGateAltScanActive" exact="true"/>
        <set_value name="$physGateBestOpenAlt" exact="null"/>
        <set_value name="$physGateBestOpenUrgency" exact="-1"/>
        <set_value name="$physGateAltIndex" exact="1"/>
        <resume label="gate_alt_loop"/>
      </do_if>

      <label name="gate_alt_done"/>
      <do_if value="$physGateAltScanActive? and $physGateAltScanActive">
        <do_if value="$physGateBestOpenAlt? and $physGateBestOpenAlt != null">
          <set_value name="$result" exact="table[$Trips = false, $OpenAltWare = $physGateBestOpenAlt]"/>
          <remove_value name="$physGateBestOpenAlt"/>
          <remove_value name="$physGateBestOpenUrgency"/>
          <remove_value name="$physGateAltIndex"/>
          <remove_value name="$physGateAltCandidate"/>
          <remove_value name="$physGateAltScanActive"/>
          <remove_value name="$gateCheckWare"/>
          <remove_value name="$gateCheckTrips"/>
          <remove_value name="$gateCheckReturnAlt"/>
          <return value="$result"/>
        </do_if>
        <remove_value name="$physGateBestOpenAlt"/>
        <remove_value name="$physGateBestOpenUrgency"/>
        <remove_value name="$physGateAltIndex"/>
        <remove_value name="$physGateAltCandidate"/>
        <remove_value name="$physGateAltScanActive"/>
      </do_if>
      <do_if value="$gateCheckTrips">
        <set_value name="$result" exact="$gateCheckTripResult"/>
        <remove_value name="$gateCheckWare"/>
        <remove_value name="$gateCheckTrips"/>
        <remove_value name="$gateCheckTripResult"/>
        <remove_value name="$gateCheckReturnAlt"/>
        <return value="$result"/>
      </do_if>

      <remove_value name="$gateCheckWare"/>
      <remove_value name="$gateCheckTrips"/>
      <remove_value name="$gateCheckReturnAlt"/>
      <return value="$result"/>

      <label name="gate_alt_loop"/>
      <do_if value="not $physGateAltIndex? or not $altWareCandidates? or $physGateAltIndex gt $altWareCandidates.count">
        <resume label="gate_alt_done"/>
      </do_if>
      <set_value name="$physGateAltCandidate" exact="$altWareCandidates.{$physGateAltIndex}"/>
      <do_if value="not $physGateAltCandidate? or $physGateAltCandidate == $ware">
        <set_value name="$physGateAltIndex" exact="$physGateAltIndex + 1"/>
        <resume label="gate_alt_loop"/>
      </do_if>
      <set_value name="$gateCheckWare" exact="$physGateAltCandidate"/>
      <set_value name="$gateCheckTrips" exact="false"/>
      <set_value name="$gateCheckReturnAlt" exact="true"/>
      <resume label="gate_check_ware"/>

      <label name="gate_check_return_alt"/>
      <do_if value="not $gateCheckTrips">
        <set_value name="$physGateAltUrgency" exact="if $altWareUrgency? and $altWareUrgency.{$physGateAltCandidate}? then $altWareUrgency.{$physGateAltCandidate} else 0"/>
        <do_if value="not $physGateBestOpenAlt? or $physGateBestOpenAlt == null or $physGateAltUrgency gt $physGateBestOpenUrgency">
          <set_value name="$physGateBestOpenAlt" exact="$physGateAltCandidate"/>
          <set_value name="$physGateBestOpenUrgency" exact="$physGateAltUrgency"/>
        </do_if>
        <remove_value name="$physGateAltUrgency"/>
      </do_if>
      <set_value name="$physGateAltIndex" exact="$physGateAltIndex + 1"/>
      <do_if value="$physGateAltIndex? and $altWareCandidates? and $physGateAltIndex le $altWareCandidates.count">
        <wait exact="1ms"/>
      </do_if>
      <resume label="gate_alt_loop"/>

      <label name="gate_check_ware"/>
      <create_list name="$relevantShips"/>
      <do_if value="$ship? and $ship.exists">
        <append_to_list name="$relevantShips" exact="$ship"/>
      </do_if>

      <set_value name="$stationIndex" exact="1"/>
      <do_while value="$stationIndex le $primaryTargetStations.count">
        <set_value name="$chunkEnd" exact="[[$stationIndex + 4, $primaryTargetStations.count].min, $primaryTargetStations.count].max"/>
        <do_all exact="$chunkEnd - $stationIndex + 1" counter="$chunkOffset">
          <set_value name="$si" exact="$stationIndex + $chunkOffset - 1"/>
          <set_value name="$gateStation" exact="$primaryTargetStations.{$si}"/>
          <do_if value="not $gateStation? or not $gateStation.exists">
            <continue/>
          </do_if>
          <do_if value="global.$GT_MinerStationAssignments? and global.$GT_MinerStationAssignments.{$gateStation}? and global.$GT_MinerStationAssignments.{$gateStation}.{$gateCheckWare}?">
            <set_value name="$assignShips" exact="global.$GT_MinerStationAssignments.{$gateStation}.{$gateCheckWare}.keys.list"/>
            <do_all exact="$assignShips.count" counter="$asi">
              <set_value name="$assignShip" exact="$assignShips.{$asi}"/>
              <set_value name="$shipA" exact="$ship"/>
              <set_value name="$shipB" exact="$assignShip"/>
              <include_interrupt_actions ref="MinerSameFleetMatch"/>
              <do_if value="$assignShip? and $assignShip.exists and $fleetMatch and not $relevantShips.indexof.{$assignShip}">
                <append_to_list name="$relevantShips" exact="$assignShip"/>
              </do_if>
            </do_all>
          </do_if>
          <do_if value="global.$GT_MinerIntents? and global.$GT_MinerIntents.{$gateStation}? and global.$GT_MinerIntents.{$gateStation}.{$gateCheckWare}?">
            <set_value name="$intentShips" exact="global.$GT_MinerIntents.{$gateStation}.{$gateCheckWare}.keys.list"/>
            <do_all exact="$intentShips.count" counter="$isi">
              <set_value name="$intentShip" exact="$intentShips.{$isi}"/>
              <set_value name="$shipA" exact="$ship"/>
              <set_value name="$shipB" exact="$intentShip"/>
              <include_interrupt_actions ref="MinerSameFleetMatch"/>
              <do_if value="$intentShip? and $intentShip.exists and $fleetMatch and not $relevantShips.indexof.{$intentShip}">
                <append_to_list name="$relevantShips" exact="$intentShip"/>
              </do_if>
            </do_all>
          </do_if>
        </do_all>
        <set_value name="$stationIndex" exact="$chunkEnd + 1"/>
        <do_if value="$stationIndex le $primaryTargetStations.count">
          <wait exact="1ms"/>
        </do_if>
      </do_while>

      <set_value name="$stationIndex" exact="1"/>
      <do_while value="$stationIndex le $primaryTargetStations.count">
        <set_value name="$chunkEnd" exact="[[$stationIndex + 4, $primaryTargetStations.count].min, $primaryTargetStations.count].max"/>
        <do_all exact="$chunkEnd - $stationIndex + 1" counter="$chunkOffset">
          <set_value name="$si" exact="$stationIndex + $chunkOffset - 1"/>
          <set_value name="$gateStation" exact="$primaryTargetStations.{$si}"/>
          <do_if value="not $gateStation? or not $gateStation.exists">
            <continue/>
          </do_if>
          <set_value name="$targetAmount" exact="$gateStation.cargo.{$gateCheckWare}.target"/>
          <do_if value="$targetAmount le 0">
            <continue/>
          </do_if>
          <set_value name="$stationPhysical" exact="$gateStation.cargo.{$gateCheckWare}.count"/>
          <set_value name="$incomingCargo" exact="0"/>
          <set_value name="$shipIndex" exact="1"/>
          <do_while value="$shipIndex le $relevantShips.count">
            <set_value name="$shipChunkEnd" exact="[[$shipIndex + 9, $relevantShips.count].min, $relevantShips.count].max"/>
            <do_all exact="$shipChunkEnd - $shipIndex + 1" counter="$shipChunkOffset">
              <set_value name="$ri" exact="$shipIndex + $shipChunkOffset - 1"/>
              <set_value name="$minerShip" exact="$relevantShips.{$ri}"/>
              <set_value name="$minerShipIsMinerControlled" exact="false"/>
              <do_if value="$minerShip? and $minerShip.exists and $minerShip.isoperational and $minerShip.isplayerowned">
                <do_if value="$minerShip.defaultorder? and @$minerShip.defaultorder.id == 'GalaxyMiner'">
                  <set_value name="$minerShipIsMinerControlled" exact="true"/>
                </do_if>
                <do_elseif value="$minerShip.defaultorder? and @$minerShip.defaultorder.id == 'Assist' and $minerShip.defaultorder.$baseorder? and @$minerShip.defaultorder.$baseorder.id == 'GalaxyMiner'">
                  <set_value name="$minerShipIsMinerControlled" exact="true"/>
                </do_elseif>
                <do_elseif value="$minerShip.commander? and $minerShip.commander.exists and $minerShip.commander.defaultorder? and @$minerShip.commander.defaultorder.id == 'GalaxyMiner'">
                  <set_value name="$minerShipIsMinerControlled" exact="true"/>
                </do_elseif>
                <do_elseif value="$minerShip.commander? and $minerShip.commander.exists and $minerShip.commander.defaultorder? and @$minerShip.commander.defaultorder.id == 'Assist' and $minerShip.commander.defaultorder.$baseorder? and @$minerShip.commander.defaultorder.$baseorder.id == 'GalaxyMiner'">
                  <set_value name="$minerShipIsMinerControlled" exact="true"/>
                </do_elseif>
                <do_if value="$minerShipIsMinerControlled">
                  <set_value name="$shipInContext" exact="false"/>
                  <do_if value="$minerShip == $ship">
                    <set_value name="$shipInContext" exact="true"/>
                  </do_if>
                  <do_if value="not $shipInContext and global.$GT_MinerStationAssignments? and global.$GT_MinerStationAssignments.{$gateStation}? and global.$GT_MinerStationAssignments.{$gateStation}.{$gateCheckWare}? and global.$GT_MinerStationAssignments.{$gateStation}.{$gateCheckWare}.{$minerShip}?">
                    <set_value name="$shipInContext" exact="true"/>
                  </do_if>
                  <do_if value="not $shipInContext and global.$GT_MinerIntents? and global.$GT_MinerIntents.{$gateStation}? and global.$GT_MinerIntents.{$gateStation}.{$gateCheckWare}? and global.$GT_MinerIntents.{$gateStation}.{$gateCheckWare}.{$minerShip}?">
                    <set_value name="$shipInContext" exact="true"/>
                  </do_if>
                  <do_if value="$shipInContext">
                    <set_value name="$incomingCargo" exact="$incomingCargo + $minerShip.cargo.{$gateCheckWare}.count"/>
                  </do_if>
                </do_if>
              </do_if>
            </do_all>
            <set_value name="$shipIndex" exact="$shipChunkEnd + 1"/>
            <do_if value="$shipIndex le $relevantShips.count">
              <wait exact="1ms"/>
            </do_if>
          </do_while>
          <set_value name="$projectedPhysical" exact="$stationPhysical + $incomingCargo"/>
          <!-- Integer-safe headroom: (physical * (100 + headroomPct)) / 100 — NOT 1 + (headroomPct/100) which truncates to 1. -->
          <set_value name="$abortThreshold" exact="($stationPhysical * (100 + $headroomPct)) / 100"/>
          <set_value name="$gateTripsForStation" exact="false"/>
          <do_if value="$stationPhysical gt 0">
            <do_if value="$projectedPhysical ge $abortThreshold">
              <set_value name="$gateTripsForStation" exact="true"/>
            </do_if>
          </do_if>
          <do_elseif value="$incomingCargo gt 0">
            <set_value name="$gateTripsForStation" exact="true"/>
          </do_elseif>
          <do_if value="$gateTripsForStation">
            <set_value name="$gateCheckTrips" exact="true"/>
            <set_value name="$gateCheckTripResult" exact="table[
              $Trips = true,
              $Station = $gateStation,
              $StationPhysical = $stationPhysical,
              $IncomingCargo = $incomingCargo,
              $ProjectedPhysical = $projectedPhysical,
              $AbortThreshold = $abortThreshold,
              $HeadroomPct = $headroomPct,
              $Ware = $gateCheckWare
            ]"/>
            <set_value name="$pilotLevelDbg" exact="if global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly and $ship.pilot? then $ship.pilot.skill.piloting else (if $ship.pilot? and global.$GT_Pilots? and global.$GT_Pilots.{$ship.pilot}? and global.$GT_Pilots.{$ship.pilot}.$Level? then global.$GT_Pilots.{$ship.pilot}.$Level else 0)"/>
            <debug_text text="'[GT-Miner] ' + $ship.idcode + ': Physical storage gate TRIP pilotLevel=' + $pilotLevelDbg + ' ware=' + $gateCheckWare.name + ' station=' + $gateStation.idcode + ' physical=' + $stationPhysical + ' incoming=' + $incomingCargo + ' projected=' + $projectedPhysical + ' threshold=' + $abortThreshold + ' headroomPct=' + $headroomPct" chance="$debugchance"/>
            <remove_value name="$relevantShips"/>
            <do_if value="$gateCheckReturnAlt? and $gateCheckReturnAlt">
              <resume label="gate_check_return_alt"/>
            </do_if>
            <resume label="gate_check_return_primary"/>
          </do_if>
        </do_all>
        <set_value name="$stationIndex" exact="$chunkEnd + 1"/>
        <do_if value="$stationIndex le $primaryTargetStations.count">
          <wait exact="1ms"/>
        </do_if>
      </do_while>

      <remove_value name="$relevantShips"/>
      <do_if value="$gateCheckReturnAlt? and $gateCheckReturnAlt">
        <resume label="gate_check_return_alt"/>
      </do_if>
      <resume label="gate_check_return_primary"/>
    </actions>
  </attention>
</aiscript>
