<?xml version="1.0" encoding="utf-8"?>
<aiscript name="order.dock.pilotexchange" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <order id="DockAndPilotExchange" name="{77000, 10004}" description="{77000, 10104}" category="navigation" infinite="false">
    <params>
      <param name="destination" type="object" text="{1041, 10141}" comment="Rendezvous station for pilot exchange">
        <input_param name="class" value="[class.station]"/>
      </param>
      <param name="partner" type="object" default="null" text="{1001, 1612}" comment="Other ship in the pilot exchange pair">
        <input_param name="class" value="[class.ship]"/>
      </param>
    </params>
    <requires>
      <match shiptype="shiptype.lasertower" negate="true"/>
    </requires>
    <location object="$destination" condition="@$destination.exists"/>
  </order>

  <interrupts>
    <handler ref="TargetInvalidHandler"/>
    <handler ref="AttackHandler"/>
  </interrupts>

  <init>
    <set_order_syncpoint_reached order="this.ship.order"/>
    <set_command command="command.dockat" param="$destination"/>
    <set_command_action commandaction="commandaction.waitingtodock" param="$destination"/>
    <debug_text text="'[GT PilotExchange] init ship=' + this.ship.idcode + ' destination=' + (if $destination? then $destination.idcode else 'NONE') + ' partner=' + (if $partner? then $partner.idcode else 'NONE')" chance="100"/>
    <do_if value="not $destination or not this.ship.pilot">
      <debug_text text="'[GT PilotExchange] init failed ship=' + this.ship.idcode + ' destination=' + (if $destination? then $destination.idcode else 'NONE') + ' hasPilot=' + (if this.ship.pilot? then 'yes' else 'no')" chance="100"/>
      <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
        $Ship = this.ship,
        $ShipID = this.ship.idcode,
        $State = 'failed',
        $StationID = if $destination? then $destination.idcode else ''
      ]"/>
      <set_order_state order="this.ship.order" state="orderstate.critical"/>
      <return/>
    </do_if>
    <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
      $Ship = this.ship,
      $ShipID = this.ship.idcode,
      $State = 'started',
      $StationID = $destination.idcode,
      $PartnerID = if $partner? then $partner.idcode else ''
    ]"/>
  </init>

  <attention min="unknown">
    <actions>
      <set_value name="$holdTime" exact="2h"/>
      <set_value name="$arrived" exact="false"/>

      <do_if value="(this.ship.dock and (this.ship.dock.container == $destination)) or (this.ship.parkedat and ((this.ship.parkedat == $destination) or this.ship.parkedat.hascontext.{$destination}))">
        <debug_text text="'[GT PilotExchange] already docked ship=' + this.ship.idcode + ' station=' + $destination.idcode" chance="100"/>
        <set_command_action commandaction="commandaction.standingby"/>
        <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
          $Ship = this.ship,
          $ShipID = this.ship.idcode,
          $State = 'arrived',
          $StationID = $destination.idcode,
          $PartnerID = if $partner? then $partner.idcode else ''
        ]"/>
        <set_value name="$arrived" exact="true"/>
      </do_if>
      <do_if value="not $arrived">
        <debug_text text="'[GT PilotExchange] create DockAndWait ship=' + this.ship.idcode + ' station=' + $destination.idcode" chance="100"/>
        <set_command_action commandaction="commandaction.waitingtodock" param="$destination"/>
        <create_order name="$dockOrder" id="'DockAndWait'" object="this.ship" immediate="true">
          <param name="destination" value="$destination"/>
          <param name="building" value="false"/>
          <param name="trading" value="false"/>
          <param name="dockfollowers" value="$destination.isclass.station"/>
          <param name="callerid" value="this.ship.order"/>
        </create_order>

        <wait>
          <interrupt>
            <conditions>
              <event_object_order_ready object="this.ship" order="$dockOrder"/>
            </conditions>
          </interrupt>
        </wait>

        <do_if value="(this.ship.dock and (this.ship.dock.container == $destination)) or (this.ship.parkedat and ((this.ship.parkedat == $destination) or this.ship.parkedat.hascontext.{$destination}))">
          <debug_text text="'[GT PilotExchange] arrived ship=' + this.ship.idcode + ' station=' + $destination.idcode" chance="100"/>
          <set_command_action commandaction="commandaction.standingby"/>
          <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
            $Ship = this.ship,
            $ShipID = this.ship.idcode,
            $State = 'arrived',
            $StationID = $destination.idcode,
            $PartnerID = if $partner? then $partner.idcode else ''
          ]"/>
          <set_value name="$arrived" exact="true"/>
        </do_if>
        <do_else>
          <debug_text text="'[GT PilotExchange] failed to dock ship=' + this.ship.idcode + ' station=' + $destination.idcode" chance="100"/>
          <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
            $Ship = this.ship,
            $ShipID = this.ship.idcode,
            $State = 'failed',
            $StationID = $destination.idcode,
            $PartnerID = if $partner? then $partner.idcode else ''
          ]"/>
          <set_command_action commandaction="commandaction.orderfailed"/>
          <return/>
        </do_else>
      </do_if>

      <!-- Keep ship docked for exchange until explicit release signal.
           Failsafe timeout is aligned with MD swap-tracker timeout. -->
      <wait max="$holdTime">
        <interrupt>
          <conditions>
            <event_object_signalled object="this.ship" param="'GT_PilotExchange_Release'"/>
          </conditions>
        </interrupt>
      </wait>
      <debug_text text="'[GT PilotExchange] release/timeout ship=' + this.ship.idcode + ' station=' + $destination.idcode" chance="100"/>
      <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
        $Ship = this.ship,
        $ShipID = this.ship.idcode,
        $State = 'released',
        $StationID = if $destination? then $destination.idcode else '',
        $PartnerID = if $partner? then $partner.idcode else ''
      ]"/>
    </actions>
  </attention>

  <on_abort>
    <!-- Always emit aborted for this order instance so MD can reliably clear PilotExchange state on cancel. -->
    <signal_objects object="player.galaxy" param="'GT_PilotExchange_OrderState'" param2="table[
      $Ship = this.ship,
      $ShipID = this.ship.idcode,
      $State = 'aborted',
      $StationID = if $destination? then $destination.idcode else '',
      $PartnerID = if $partner? then $partner.idcode else ''
    ]"/>
  </on_abort>
</aiscript>
