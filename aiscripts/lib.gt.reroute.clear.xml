<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.reroute.clear" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Clears global.$GT_Ships.{ship}.$Rerouting and refreshes the ship name (removes [RR] prefix).
    Call when a replacement trade destination is accepted (trade_found / trade queue).
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="logPrefix" default="'GT-Reroute'"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists">
        <return/>
      </do_if>
      <do_if value="not global.$GT_Ships? or not global.$GT_Ships.{$ship}? or not global.$GT_Ships.{$ship}.$Rerouting?">
        <return/>
      </do_if>

      <remove_value name="global.$GT_Ships.{$ship}.$Rerouting"/>

      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': cleared Rerouting state (RR label)'" chance="100"/>
      </do_if>

      <do_if value="$ship.pilot? and global.$GT_Pilots? and global.$GT_Pilots.{$ship.pilot}?">
        <signal_objects object="player.galaxy" param="'GT_Update_Ship_Name'" param2="table[
          $Ship = $ship,
          $pilot = $ship.pilot,
          $xp = global.$GT_Pilots.{$ship.pilot}.$XP,
          $level = global.$GT_Pilots.{$ship.pilot}.$Level,
          $rank = @global.$GT_Pilots.{$ship.pilot}.$CurrentRank,
          $nameType = 'trader'
        ]"/>
      </do_if>
      <do_else>
        <run_script name="'lib.gt.attention.refresh_ship_name'">
          <param name="ship" value="$ship"/>
          <param name="force" value="true"/>
        </run_script>
      </do_else>
    </actions>
  </attention>
</aiscript>
