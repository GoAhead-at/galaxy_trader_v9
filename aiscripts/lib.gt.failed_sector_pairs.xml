<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.failed_sector_pairs" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!-- Normalize per-sector GT_FailedSectorPairs entry to nested table {buySector}->{sellSector}->record.
       Mirrors md.GT_Libraries_General.GT_NormalizeFailedSectorPairsSectorEntry for AI cache prefilter. -->
  <params>
    <param name="rawEntry" default="null"/>
    <param name="expirationTime" default="1800s"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$yieldMs" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$AIYieldInterval?">
        <set_value name="$yieldMs" exact="[1, @global.$GT_GlobalSettings.$Performance.$AIYieldInterval].max"/>
      </do_if>

      <set_value name="$normalized" exact="table[]"/>
      <do_if value="not $rawEntry?">
        <wait exact="$yieldMs * 1ms"/>
        <return value="$normalized"/>
      </do_if>
      <do_if value="typeof $rawEntry == datatype.table">
        <set_value name="$buyKeys" exact="$rawEntry.keys"/>
        <do_all exact="$buyKeys.count" counter="$bki">
          <set_value name="$buyKey" exact="$buyKeys.{$bki}"/>
          <do_if value="$rawEntry.{$buyKey}? and typeof $rawEntry.{$buyKey} == datatype.table">
            <set_value name="$innerTable" exact="$rawEntry.{$buyKey}"/>
            <set_value name="$sellKeys" exact="$innerTable.keys"/>
            <do_all exact="$sellKeys.count" counter="$ski">
              <set_value name="$sellKey" exact="$sellKeys.{$ski}"/>
              <set_value name="$record" exact="@$innerTable.{$sellKey}"/>
              <set_value name="$keep" exact="true"/>
              <do_if value="$expirationTime gt 0s and $record? and $record.$Timestamp?">
                <do_if value="(player.age - $record.$Timestamp) gt $expirationTime">
                  <set_value name="$keep" exact="false"/>
                </do_if>
              </do_if>
              <do_if value="$keep and $record?">
                <set_value name="$buyMap" exact="if $normalized.{$buyKey}? then $normalized.{$buyKey} else table[]"/>
                <set_value name="$buyMap.{$sellKey}" exact="$record"/>
                <set_value name="$normalized.{$buyKey}" exact="$buyMap"/>
              </do_if>
            </do_all>
          </do_if>
        </do_all>
      </do_if>
      <do_elseif value="typeof $rawEntry == datatype.list">
        <do_all exact="$rawEntry.count" counter="$li">
          <set_value name="$legacyRec" exact="$rawEntry.{$li}"/>
          <do_if value="$legacyRec? and $legacyRec.$BuySector? and $legacyRec.$BuySector.exists and $legacyRec.$SellSector? and $legacyRec.$SellSector.exists">
            <set_value name="$keepLegacy" exact="true"/>
            <do_if value="$expirationTime gt 0s and $legacyRec.$Timestamp?">
              <do_if value="(player.age - $legacyRec.$Timestamp) gt $expirationTime">
                <set_value name="$keepLegacy" exact="false"/>
              </do_if>
            </do_if>
            <do_if value="$keepLegacy">
              <set_value name="$legacyBuy" exact="$legacyRec.$BuySector"/>
              <set_value name="$legacySell" exact="$legacyRec.$SellSector"/>
              <set_value name="$legacyBuyMap" exact="if $normalized.{$legacyBuy}? then $normalized.{$legacyBuy} else table[]"/>
              <set_value name="$legacyBuyMap.{$legacySell}" exact="table[
                $Reason = if $legacyRec.$Reason? then $legacyRec.$Reason else '',
                $Timestamp = if $legacyRec.$Timestamp? then $legacyRec.$Timestamp else player.age
              ]"/>
              <set_value name="$normalized.{$legacyBuy}" exact="$legacyBuyMap"/>
            </do_if>
          </do_if>
        </do_all>
      </do_elseif>

      <wait exact="$yieldMs * 1ms"/>
      <return value="$normalized"/>
    </actions>
  </attention>
</aiscript>
