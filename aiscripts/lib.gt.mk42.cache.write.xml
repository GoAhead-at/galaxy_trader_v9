<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.mk42.cache.write" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="homeSector"/>
    <param name="cacheTTL" default="300s"/>
    <param name="maxSearchDistance" default="0"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="this.$gt_yieldMs" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$AIYieldInterval?">
        <set_value name="this.$gt_yieldMs" exact="[1, @global.$GT_GlobalSettings.$Performance.$AIYieldInterval].max"/>
      </do_if>
      <set_value name="this.$writeBatchSize" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$CacheWriteBatchSize?">
        <set_value name="this.$writeBatchSize" exact="[1, @global.$GT_GlobalSettings.$Performance.$CacheWriteBatchSize].max"/>
      </do_if>
      <set_value name="this.$writeBatchSize" exact="(this.$writeBatchSize)i"/>
      <set_value name="this.$cleanupBatchSize" exact="50"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$CacheCleanupBatchSize?">
        <set_value name="this.$cleanupBatchSize" exact="[10, @global.$GT_GlobalSettings.$Performance.$CacheCleanupBatchSize].max"/>
      </do_if>
      <set_value name="this.$cleanupBatchSize" exact="(this.$cleanupBatchSize)i"/>

      <do_if value="$tradeList.count == 0 or not $homeSector?">
        <return value="table[$Written = 0, $Cleaned = 0, $CacheSize = 0]"/>
      </do_if>

      <do_if value="not global.$GT_TradeCacheMK42?">
        <set_value name="global.$GT_TradeCacheMK42" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_TradeCacheMK42.{$homeSector}?">
        <set_value name="global.$GT_TradeCacheMK42.{$homeSector}" exact="[]"/>
      </do_if>

      <set_value name="$cacheNow" exact="player.age"/>
      <set_value name="$expiredCount" exact="0"/>
      <set_value name="$cleanupSize" exact="if @global.$GT_TradeCacheMK42.{$homeSector}.count != null then @global.$GT_TradeCacheMK42.{$homeSector}.count else 0"/>

      <do_all exact="$cleanupSize" counter="$ci" reverse="true">
        <set_value name="$oldEntry" exact="@global.$GT_TradeCacheMK42.{$homeSector}.{$ci}"/>
        <set_value name="$isStale" exact="false"/>
        <do_if value="not $oldEntry?">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <set_value name="$oldTs" exact="null"/>
        <do_if value="not $isStale">
          <set_value name="$oldTs" exact="@$oldEntry.$CachedAt"/>
          <do_if value="$oldTs == null">
            <set_value name="$oldTs" exact="@$oldEntry.$Timestamp"/>
          </do_if>
          <do_if value="$oldTs != null and ($cacheNow - $oldTs) gt $cacheTTL">
            <set_value name="$isStale" exact="true"/>
          </do_if>
        </do_if>
        <!-- Positive resolvability (same dead-ref-returns-null reasoning as the sell side below):
             keep only if the supplier is still resolvable live. -->
        <set_value name="$buyResolvable" exact="(@$oldEntry.$BuyStation != null and @$oldEntry.$BuyStation.exists) or (@$oldEntry.$BuyOffer != null and @$oldEntry.$BuyOffer.exists)"/>
        <do_if value="not $isStale and not $buyResolvable">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <!-- Positive resolvability check: a dead component ref returns null under @, so the old
             "!= null and not .exists" guard silently MISSED dead build-storage refs and broken rows
             accumulated forever. Instead, keep a row only if its delivery is still resolvable live -
             directly (SellStation/SellOffer) or, for build storages, via the stable base anchor
             (base.buildstorage). Mirrors lib.gt.mk42.cache.search resolution; anything else is broken
             and gets evicted. -->
        <set_value name="$oldHasLiveBase" exact="@$oldEntry.$SellStationBase != null and @$oldEntry.$SellStationBase.exists and @$oldEntry.$SellStationBase.buildstorage != null and @$oldEntry.$SellStationBase.buildstorage.exists"/>
        <!-- Build-storage rows legitimately have ALL component handles dead at any instant (offer, build
             storage and base are recreated each construction tick) yet remain valid: cache.search
             re-discovers the live offer from the permanent keys (sell sector + ware + delivery idcode).
             So a row with live permanent keys is resolvable here too; TTL still evicts genuinely-gone
             stations, keeping the cache bounded without an expensive per-entry find_buy_offer in purge. -->
        <set_value name="$oldHasPermanentKeys" exact="(@$oldEntry.$Ware != null or @$oldEntry.$DeliveryStationName != null) and (@$oldEntry.$DeliveryStationId != null or @$oldEntry.$DeliveryStationName != null) and ((@$oldEntry.$SellSector != null and @$oldEntry.$SellSector.exists) or @$oldEntry.$SellSectorId != null or @$oldEntry.$DeliveryStationId != null)"/>
        <set_value name="$sellResolvable" exact="$oldHasLiveBase or $oldHasPermanentKeys or (@$oldEntry.$SellStation != null and @$oldEntry.$SellStation.exists) or (@$oldEntry.$SellOffer != null and @$oldEntry.$SellOffer.exists)"/>
        <do_if value="not $isStale and not $sellResolvable">
          <set_value name="$isStale" exact="true"/>
        </do_if>
        <do_if value="$isStale">
          <remove_value name="global.$GT_TradeCacheMK42.{$homeSector}.{$ci}"/>
          <set_value name="$expiredCount" operation="add"/>
        </do_if>
        <set_value name="$ciInt" exact="($ci)i"/>
        <do_if value="($ciInt % this.$cleanupBatchSize) == 0">
          <wait exact="this.$gt_yieldMs * 1ms"/>
        </do_if>
      </do_all>

      <do_all exact="$tradeList.count" counter="$ti">
        <set_value name="$newTrade" exact="$tradeList.{$ti}"/>
        <set_value name="$newTrade.$CachedAt" exact="$cacheNow"/>
        <set_value name="$newTrade.$Timestamp" exact="$cacheNow"/>
        <!-- Stamp the stable build-storage base anchor at write time, when the sell refs are still
             fresh. Done here (the single chokepoint every cached trade passes through) so it is
             independent of which matcher built the trade. The base station survives while the
             transient build storage component/offer die; cache.search re-resolves base.buildstorage. -->
        <do_if value="not $newTrade.$SellStationBase?">
          <set_value name="$wAnchorSell" exact="null"/>
          <do_if value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists">
            <set_value name="$wAnchorSell" exact="@$newTrade.$SellStation"/>
          </do_if>
          <do_elseif value="$newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and $newTrade.$SellOffer.buyer? and @$newTrade.$SellOffer.buyer.exists">
            <set_value name="$wAnchorSell" exact="@$newTrade.$SellOffer.buyer"/>
          </do_elseif>
          <do_if value="$wAnchorSell? and @$wAnchorSell.isclass.buildstorage and $wAnchorSell.base? and @$wAnchorSell.base.exists">
            <set_value name="$newTrade.$SellStationBase" exact="@$wAnchorSell.base"/>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$DeliveryStationName? and $newTrade.$SellStation? and @$newTrade.$SellStation.exists and @$newTrade.$SellStation.knownname">
          <set_value name="$newTrade.$DeliveryStationName" exact="@$newTrade.$SellStation.knownname"/>
        </do_if>
        <!-- Stamp the delivery station's STABLE idcode (a string that outlives the recreated build-storage
             and base entities). cache.search uses it to disambiguate which re-discovered player buy offer
             corresponds to this cached row. For build storage we store the parent base station's idcode. -->
        <do_if value="not $newTrade.$DeliveryStationId? and $newTrade.$SellStation? and @$newTrade.$SellStation.exists">
          <do_if value="@$newTrade.$SellStation.isclass.buildstorage and $newTrade.$SellStation.base? and @$newTrade.$SellStation.base.exists">
            <set_value name="$newTrade.$DeliveryStationId" exact="@$newTrade.$SellStation.base.idcode"/>
          </do_if>
          <do_else>
            <set_value name="$newTrade.$DeliveryStationId" exact="@$newTrade.$SellStation.idcode"/>
          </do_else>
        </do_if>
        <do_if value="not $newTrade.$SellSectorId?">
          <set_value name="$wSecSell" exact="null"/>
          <do_if value="$newTrade.$SellSector? and @$newTrade.$SellSector.exists and $newTrade.$SellSector.idcode?">
            <set_value name="$wSecSell" exact="@$newTrade.$SellSector.idcode"/>
          </do_if>
          <do_elseif value="$newTrade.$SellStation? and @$newTrade.$SellStation.exists and $newTrade.$SellStation.sector? and @$newTrade.$SellStation.sector.exists and $newTrade.$SellStation.sector.idcode?">
            <set_value name="$wSecSell" exact="@$newTrade.$SellStation.sector.idcode"/>
          </do_elseif>
          <do_if value="$wSecSell?">
            <set_value name="$newTrade.$SellSectorId" exact="$wSecSell"/>
          </do_if>
        </do_if>
        <!-- Ship-independent stamps (TTL + rewrite bound drift):
             $TradeRuleBlocked = offer.restriction.factions excludes faction.player (true faction gate;
               Ignore Trade Rules ships still see the row). Do NOT use cantradewith.{otherStation}:
               that returns false when a player BS has no money and was mislabeled as trade rules.
             Do NOT stamp customer funds: BS/station money is ephemeral. Cache read re-checks live
             money each pass; a write-time funds stamp poisoned the pool until manual clear. -->
        <do_if value="not $newTrade.$IsSellOnly?">
          <set_value name="$newTrade.$TradeRuleBlocked" exact="false"/>
          <do_if value="$newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and @$newTrade.$BuyOffer.restriction.factions.count">
            <do_if value="@$newTrade.$BuyOffer.restriction.inverted">
              <do_if value="$newTrade.$BuyOffer.restriction.factions.indexof.{faction.player}">
                <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
              </do_if>
            </do_if>
            <do_else>
              <do_if value="not $newTrade.$BuyOffer.restriction.factions.indexof.{faction.player}">
                <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
              </do_if>
            </do_else>
          </do_if>
          <do_if value="not $newTrade.$TradeRuleBlocked and $newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and @$newTrade.$SellOffer.restriction.factions.count">
            <do_if value="@$newTrade.$SellOffer.restriction.inverted">
              <do_if value="$newTrade.$SellOffer.restriction.factions.indexof.{faction.player}">
                <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
              </do_if>
            </do_if>
            <do_else>
              <do_if value="not $newTrade.$SellOffer.restriction.factions.indexof.{faction.player}">
                <set_value name="$newTrade.$TradeRuleBlocked" exact="true"/>
              </do_if>
            </do_else>
          </do_if>
        </do_if>
        <do_if value="not $newTrade.$CargoWareTransport?">
          <set_value name="$cacheTagWare" exact="if $newTrade.$Ware? then $newTrade.$Ware else null"/>
          <do_if value="not $cacheTagWare? and $newTrade.$BuyOffer? and @$newTrade.$BuyOffer.exists and @$newTrade.$BuyOffer.ware != null">
            <set_value name="$cacheTagWare" exact="@$newTrade.$BuyOffer.ware"/>
          </do_if>
          <do_if value="not $cacheTagWare? and $newTrade.$SellOffer? and @$newTrade.$SellOffer.exists and @$newTrade.$SellOffer.ware != null">
            <set_value name="$cacheTagWare" exact="@$newTrade.$SellOffer.ware"/>
          </do_if>
          <do_if value="$cacheTagWare?">
            <set_value name="$newTrade.$CargoWareTransport" exact="@$cacheTagWare.waretransport"/>
            <do_if value="not $newTrade.$VolumePerUnit? and $cacheTagWare? and $cacheTagWare.volume?">
              <set_value name="$newTrade.$VolumePerUnit" exact="$cacheTagWare.volume"/>
            </do_if>
          </do_if>
        </do_if>
        <set_value name="$newScore" exact="if $newTrade.$Score? then @$newTrade.$Score else 0"/>

        <set_value name="$insertIdx" exact="0"/>
        <set_value name="$insertFound" exact="false"/>
        <set_value name="$cacheSize" exact="if @global.$GT_TradeCacheMK42.{$homeSector}.count != null then @global.$GT_TradeCacheMK42.{$homeSector}.count else 0"/>
        <do_if value="$cacheSize gt 0">
          <do_all exact="$cacheSize" counter="$si">
            <set_value name="$existingScore" exact="if @global.$GT_TradeCacheMK42.{$homeSector}.{$si}.$Score != null then @global.$GT_TradeCacheMK42.{$homeSector}.{$si}.$Score else 0"/>
            <do_if value="$newScore gt $existingScore">
              <set_value name="$insertIdx" exact="$si"/>
              <set_value name="$insertFound" exact="true"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>

        <do_if value="$insertFound">
          <set_value name="global.$GT_TradeCacheMK42.{$homeSector}.{$insertIdx}" exact="$newTrade" operation="insert"/>
        </do_if>
        <do_else>
          <append_to_list name="global.$GT_TradeCacheMK42.{$homeSector}" exact="$newTrade"/>
        </do_else>

        <set_value name="$tiInt" exact="($ti)i"/>
        <do_if value="($tiInt % this.$writeBatchSize) == 0">
          <wait exact="this.$gt_yieldMs * 1ms"/>
        </do_if>
      </do_all>

      <set_value name="$finalCacheSize" exact="if @global.$GT_TradeCacheMK42.{$homeSector}.count != null then @global.$GT_TradeCacheMK42.{$homeSector}.count else 0"/>
      <set_value name="$metadataUpdated" exact="false"/>
      <do_if value="$maxSearchDistance gt 0">
        <do_if value="not global.$GT_TradeCacheMK42MaxDistance?">
          <set_value name="global.$GT_TradeCacheMK42MaxDistance" exact="table[]"/>
        </do_if>
        <do_if value="not global.$GT_TradeCacheMK42MaxDistance.{$homeSector}? or $maxSearchDistance gt global.$GT_TradeCacheMK42MaxDistance.{$homeSector}">
          <set_value name="global.$GT_TradeCacheMK42MaxDistance.{$homeSector}" exact="$maxSearchDistance"/>
          <set_value name="$metadataUpdated" exact="true"/>
        </do_if>
      </do_if>
      <do_if value="$homeSector? and $homeSector.exists and ($tradeList.count gt 0 or $metadataUpdated)">
        <signal_objects object="player.galaxy" param="'GT_MK42_Cache_Updated'" param2="table[
          $HomeSector = $homeSector,
          $MaxDistance = $maxSearchDistance,
          $Written = $tradeList.count,
          $CacheSize = $finalCacheSize
        ]"/>
      </do_if>

      <return value="table[$Written = $tradeList.count, $Cleaned = $expiredCount, $CacheSize = $finalCacheSize]"/>
    </actions>
  </attention>
</aiscript>
