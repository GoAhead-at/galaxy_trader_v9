<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.mk42.exec.virtualmoney — create a temporary virtualmoney trade offer and order.
     Used for player-supplier free pickup (sell offer on supplier) and free delivery
     (buy offer on customer). Caller removes nothing — this lib creates, orders, removes.
     No <wait>: must not yield between create_trade_order calls while the multitrade
     SELL-then-BUY queue is still being built (premature sell → ERR_NOTHING_TO_SELL).
     Must be run from the trading ship order context (this.ship). -->
<aiscript name="lib.gt.mk42.exec.virtualmoney" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="ship" default="this.ship"/>
    <param name="station" default="null" comment="Supplier (buy leg) or customer (sell leg)"/>
    <param name="ware" default="null"/>
    <param name="amount" default="0"/>
    <param name="side" default="'sell'" comment="sell = ship sells to station (customer buy offer); buy = ship buys from station (supplier sell offer)"/>
    <param name="internal" default="true"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$created" exact="false"/>
      <set_value name="$ordered" exact="false"/>
      <do_if value="not $ship? or not @$ship.exists or not $station? or not @$station.exists or $ware == null or not $amount? or $amount le 0">
        <return value="table[$Created = false, $Ordered = false]"/>
      </do_if>

      <set_value name="$freeOffer" exact="null"/>
      <do_if value="$side == 'buy'">
        <create_trade_offer name="$freeOffer" object="$station" seller="$station" ware="$ware" amount="$amount" price="0Cr" virtualmoney="true" virtual="false" playeronly="true"/>
      </do_if>
      <do_else>
        <create_trade_offer name="$freeOffer" object="$station" buyer="$station" ware="$ware" amount="$amount" price="0Cr" virtualmoney="true" virtual="false" playeronly="true"/>
      </do_else>

      <do_if value="$freeOffer?">
        <set_value name="$created" exact="true"/>
        <create_trade_order object="$ship" tradeoffer="$freeOffer" amount="$amount" immediate="true" internal="$internal"/>
        <set_value name="$ordered" exact="true"/>
        <remove_trade_offer object="$station" tradeoffer="$freeOffer"/>
      </do_if>

      <return value="table[$Created = $created, $Ordered = $ordered]"/>
    </actions>
  </attention>
</aiscript>
