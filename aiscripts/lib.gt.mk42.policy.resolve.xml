<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.mk42.policy.resolve — MK4-2 priority sliders, prioSig, delivery-class policy (OPEN_GALAXYTRADER_MK4-2_SUPPLY_ORDER.md §3.1 / §4.3). -->
<aiscript name="lib.gt.mk42.policy.resolve" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="priorityBuildstorage" default="null"/>
    <param name="priorityStations" default="null"/>
    <param name="priorityAux" default="null"/>
    <param name="priorityCarrier" default="null"/>
    <param name="prioritywares" default="[]"/>
    <param name="priorityscoremultiplier" default="null"/>
    <param name="buyFromPlayer" default="null" comment="Player supplier priority slider (0-10); folded into prioSig so supplier-priority changes invalidate the per-ship cache view like delivery-class sliders"/>
    <param name="buyFromFaction" default="null" comment="Faction supplier priority slider (0-10); folded into prioSig"/>
    <param name="seedNullSliders" default="true" comment="When true, null/unset sliders get fresh-order defaults (§3.1.1a)"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bs" exact="if $priorityBuildstorage? then $priorityBuildstorage else (if $seedNullSliders then 10 else 0)"/>
      <set_value name="$st" exact="if $priorityStations? then $priorityStations else (if $seedNullSliders then 8 else 0)"/>
      <set_value name="$ax" exact="if $priorityAux? then $priorityAux else 0"/>
      <set_value name="$cr" exact="if $priorityCarrier? then $priorityCarrier else 0"/>
      <set_value name="$seededNulls" exact="false"/>
      <do_if value="$seedNullSliders">
        <do_if value="not $priorityBuildstorage? or not $priorityStations? or not $priorityAux? or not $priorityCarrier?">
          <set_value name="$seededNulls" exact="true"/>
        </do_if>
      </do_if>

      <do_if value="$bs lt 0"><set_value name="$bs" exact="0"/></do_if>
      <do_if value="$bs gt 10"><set_value name="$bs" exact="10"/></do_if>
      <do_if value="$st lt 0"><set_value name="$st" exact="0"/></do_if>
      <do_if value="$st gt 10"><set_value name="$st" exact="10"/></do_if>
      <do_if value="$ax lt 0"><set_value name="$ax" exact="0"/></do_if>
      <do_if value="$ax gt 10"><set_value name="$ax" exact="10"/></do_if>
      <do_if value="$cr lt 0"><set_value name="$cr" exact="0"/></do_if>
      <do_if value="$cr gt 10"><set_value name="$cr" exact="10"/></do_if>

      <set_value name="$psm" exact="if $priorityscoremultiplier? then $priorityscoremultiplier else 1"/>
      <do_if value="$psm lt 1"><set_value name="$psm" exact="1"/></do_if>
      <do_if value="$psm gt 10"><set_value name="$psm" exact="10"/></do_if>

      <!-- Supplier sliders: default to the neutral 5 when unset so an order that never set them keeps a
           stable signature. Clamp 0-10. These do not gate delivery classes; they live in prioSig only so a
           change to player/faction supplier preference invalidates each ship's cached trade ranking. -->
      <set_value name="$sp" exact="if $buyFromPlayer? then $buyFromPlayer else 5"/>
      <set_value name="$sf" exact="if $buyFromFaction? then $buyFromFaction else 5"/>
      <do_if value="$sp lt 0"><set_value name="$sp" exact="0"/></do_if>
      <do_if value="$sp gt 10"><set_value name="$sp" exact="10"/></do_if>
      <do_if value="$sf lt 0"><set_value name="$sf" exact="0"/></do_if>
      <do_if value="$sf gt 10"><set_value name="$sf" exact="10"/></do_if>

      <set_value name="$priorities" exact="table[$Buildstorage = $bs, $Stations = $st, $Aux = $ax, $Carrier = $cr]"/>
      <set_value name="$enabledAny" exact="$bs gt 0 or $st gt 0 or $ax gt 0 or $cr gt 0"/>
      <set_value name="$noDeliveryTargets" exact="$bs == 0 and $st == 0 and $ax == 0 and $cr == 0"/>

      <!-- Canonical prioritywares: stable sort by ware id before stringifying (§4.3). -->
      <set_value name="$canonicalPw" exact="'0'"/>
      <do_if value="$prioritywares? and typeof $prioritywares == datatype.list and $prioritywares.count gt 0">
        <set_value name="$pwIds" exact="[]"/>
        <do_all exact="$prioritywares.count" counter="$pwi">
          <set_value name="$pw" exact="$prioritywares.{$pwi}"/>
          <do_if value="$pw? and $pw != null and $pw.id?">
            <append_to_list name="$pwIds" exact="@$pw.id"/>
          </do_if>
        </do_all>
        <do_if value="$pwIds.count gt 0">
          <sort_list list="$pwIds"/>
          <set_value name="$canonicalPw" exact="''"/>
          <do_all exact="$pwIds.count" counter="$pwi2">
            <set_value name="$canonicalPw" exact="$canonicalPw + (if $pwi2 gt 1 then ',' else '') + $pwIds.{$pwi2}"/>
          </do_all>
        </do_if>
      </do_if>

      <set_value name="$prioSig" exact="'BS=' + $bs + '|ST=' + $st + '|AX=' + $ax + '|CR=' + $cr + '|PSM=' + $psm + '|SP=' + $sp + '|SF=' + $sf + '|PW=' + $canonicalPw"/>

      <return value="table[
        $Priorities = $priorities,
        $PrioSig = $prioSig,
        $CanonicalPriorityWares = $canonicalPw,
        $PriorityScoreMultiplier = $psm,
        $Buildstorage = $bs,
        $Stations = $st,
        $Aux = $ax,
        $Carrier = $cr,
        $EnabledAny = $enabledAny,
        $NoDeliveryTargets = $noDeliveryTargets,
        $SeededNulls = $seededNulls
      ]"/>
    </actions>
  </attention>
</aiscript>
