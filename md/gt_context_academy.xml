<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_Context_Academy" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <!--
    Fleet Academy context-menu integration.
    Spec: DOCS/Spec/FEATURE_FLEET_ACADEMY.md

    Flow:
      1. AddAcademyAction listens to Interact_Menu_API.Get_Actions and adds
         the top-level "Trading Academy" entry on player-owned GT-service ships
         whose pilot is below the highest course's target level.
      2. GT_AcademyAction publishes pilot/player context to the player NPC
         blackboard and raises gt.openAcademyContext for the Lua submenu.
      3. The Lua submenu computes personalized cost/duration with the
         quadratic curve + floors and signals back via
         gt_academy_course_chosen with locked-in numeric values.
      4. HandleAcademyCourseChosen overrides any in-flight training, stores
         $AcademyEnrollment, and queues manual training. The existing
         HandleTrainingNeeded pipeline finds a station and dispatches the
         DockAndTrain order; HandleStartTraining (and InitiateTraining for
         player-piloted ships) consumes $AcademyEnrollment to apply the
         locked-in cost and duration when the ship reaches the dock.
  -->
  <cues>

    <!-- ============================================================== -->
    <!-- Add "Trading Academy" entry to the right-click context menu     -->
    <!-- ============================================================== -->
    <cue name="AddAcademyAction" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Interact_Menu_API.Get_Actions"/>
      </conditions>
      <actions>
        <set_value name="$target" exact="event.param.$object"/>
        <set_value name="$useVanillaXPOnly" exact="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly"/>

        <!-- Early exit for non-player ships / vanilla XP mode (matches AddRenameAction pattern) -->
        <do_if value="$target.isclass.{class.ship} and $target.isplayerowned and not $useVanillaXPOnly and global.$GT_Config? and global.$GT_Config.$Academy? and global.$GT_Config.$Academy.$Enabled">
          <run_actions ref="md.GLX_Lib_Orders.GLX_ShipIsInGTService" result="$isGTService">
            <param name="ship" value="$target"/>
          </run_actions>
          <do_if value="$isGTService and $target.pilot?">
            <set_value name="$pilot" exact="$target.pilot"/>
            <set_value name="$pilotLevel" exact="1"/>
            <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$pilot}? and global.$GT_Pilots.{$pilot}.$Level?">
              <set_value name="$pilotLevel" exact="global.$GT_Pilots.{$pilot}.$Level"/>
            </do_if>

            <!-- Find the highest target level across all configured courses.
                 Hide the entire menu entry if the pilot already meets/exceeds it
                 (no point showing a menu where every course is filtered out). -->
            <set_value name="$maxCourseLevel" exact="0"/>
            <do_all exact="global.$GT_Config.$Academy.$Courses.count" counter="$i">
              <do_if value="global.$GT_Config.$Academy.$Courses.{$i}.$TargetLevel gt $maxCourseLevel">
                <set_value name="$maxCourseLevel" exact="global.$GT_Config.$Academy.$Courses.{$i}.$TargetLevel"/>
              </do_if>
            </do_all>

            <do_if value="$pilotLevel lt $maxCourseLevel">
              <signal_cue_instantly
                cue="md.Interact_Menu_API.Add_Action"
                param="table[
                  $id       = 'gt_mk3_academy',
                  $text     = {77000,9910},
                  $section  = 'gt_actions',
                  $callback = GT_AcademyAction
                ]"/>
              <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                <debug_text text="'[GT Academy] Added context entry for ship ' + $target.idcode + ' (pilot lvl ' + $pilotLevel + ', max course lvl ' + $maxCourseLevel + ')'" chance="100"/>
              </do_if>
            </do_if>
          </do_if>
        </do_if>
      </actions>
    </cue>

    <!-- ============================================================== -->
    <!-- Player clicked "Trading Academy" - publish context, open Lua    -->
    <!-- ============================================================== -->
    <cue name="GT_AcademyAction" instantiate="true" namespace="this">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$component" exact="event.param.$object"/>
        <!-- MD requires <return/> at top level of <actions>; use do_if/do_else to early-out. -->
        <do_if value="not $component? or not $component.pilot?">
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT Academy] GT_AcademyAction aborted: missing component or pilot'" chance="100"/>
          </do_if>
        </do_if>
        <do_else>
          <set_value name="$pilot" exact="$component.pilot"/>
          <set_value name="$pilotLevel" exact="1"/>
          <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$pilot}? and global.$GT_Pilots.{$pilot}.$Level?">
            <set_value name="$pilotLevel" exact="global.$GT_Pilots.{$pilot}.$Level"/>
          </do_if>

          <!-- Stash everything Lua needs on the player NPC blackboard -->
          <set_value name="player.entity.$GT_Academy_PilotLevel"  exact="$pilotLevel"/>
          <set_value name="player.entity.$GT_Academy_PlayerMoney" exact="player.money"/>
          <set_value name="player.entity.$GT_Academy_PilotName"   exact="$pilot.name"/>
          <set_value name="player.entity.$GT_Academy_ShipName"    exact="$component.knownname"/>

          <!-- Build a serializable course list (Lua-friendly: no nested tables of objects) -->
          <create_list name="$courseList"/>
          <do_all exact="global.$GT_Config.$Academy.$Courses.count" counter="$i">
            <set_value name="$course" exact="global.$GT_Config.$Academy.$Courses.{$i}"/>
            <append_to_list name="$courseList" exact="table[
              $Index          = $i,
              $TargetLevel    = $course.$TargetLevel,
              $ListedCost     = $course.$ListedCost,
              $ListedDuration = $course.$ListedDuration,
              $TextId         = $course.$TextId
            ]"/>
          </do_all>
          <set_value name="player.entity.$GT_Academy_Courses" exact="$courseList"/>
          <set_value name="player.entity.$GT_Academy_MinCostPercent" exact="global.$GT_Config.$Academy.$MinCostPercent"/>
          <set_value name="player.entity.$GT_Academy_MinDuration"    exact="global.$GT_Config.$Academy.$MinDuration"/>
          <set_value name="player.entity.$GT_Academy_CostExponent"   exact="global.$GT_Config.$Academy.$CostExponent"/>

          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT Academy] Opening academy submenu for pilot ' + $pilot.name + ' (lvl ' + $pilotLevel + ', courses=' + $courseList.count + ')'" chance="100"/>
          </do_if>

          <raise_lua_event name="'gt.openAcademyContext'" param="$component"/>
        </do_else>
      </actions>
    </cue>

    <!-- ============================================================== -->
    <!-- Lua signals back the chosen course - process the enrollment.    -->
    <!-- ============================================================== -->
    <!-- The Lua side writes the selection to the player NPC blackboard:   -->
    <!--   $GT_Academy_ChosenIndex     = course index in $GT_Config.$Academy.$Courses -->
    <!--   $GT_Academy_ChosenLevel     = target level                       -->
    <!--   $GT_Academy_ChosenCost      = locked-in cost (Cr in raw units)   -->
    <!--   $GT_Academy_ChosenDuration  = locked-in duration in seconds      -->
    <!-- and signals 'gt_academy_course_chosen' with the ship as event.param2. -->
    <cue name="HandleAcademyCourseChosen" instantiate="true">
      <conditions>
        <event_object_signalled object="player.entity" param="'gt_academy_course_chosen'"/>
      </conditions>
      <actions>
        <!-- MD requires <return/> at top level of <actions>; we use a $abort flag
             (set inside guards) and gate every subsequent step on "not $abort"
             so failed validations short-circuit cleanly without nested <return/>s. -->
        <set_value name="$ship" exact="event.param2"/>
        <set_value name="$abort" exact="false"/>

        <do_if value="not $ship? or not $ship.pilot?">
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT Academy] HandleAcademyCourseChosen aborted: missing ship or pilot'" chance="100"/>
          </do_if>
          <set_value name="$abort" exact="true"/>
        </do_if>

        <do_if value="not $abort">
          <set_value name="$pilot"          exact="$ship.pilot"/>
          <set_value name="$targetLevel"    exact="player.entity.$GT_Academy_ChosenLevel"/>
          <set_value name="$lockedCost"     exact="player.entity.$GT_Academy_ChosenCost"/>
          <set_value name="$lockedDuration" exact="player.entity.$GT_Academy_ChosenDuration"/>

          <!-- Defensive validation: verify the ship is still a GT service candidate -->
          <run_actions ref="md.GLX_Lib_Orders.GLX_ShipIsInGTService" result="$isGTService">
            <param name="ship" value="$ship"/>
          </run_actions>
          <do_if value="not $isGTService">
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT Academy] Enrollment rejected: ship ' + $ship.idcode + ' is no longer in GT service'" chance="100"/>
            </do_if>
            <set_value name="$abort" exact="true"/>
          </do_if>
        </do_if>

        <do_if value="not $abort">
          <!-- Make sure the pilot has a registry entry; create one if missing -->
          <do_if value="not global.$GT_Pilots? or not global.$GT_Pilots.{$pilot}?">
            <run_actions ref="md.GT_Ship_Management.Register_Pilot">
              <param name="pilot" value="$pilot"/>
              <param name="ship"  value="$ship"/>
            </run_actions>
          </do_if>
          <do_if value="not global.$GT_Pilots.{$pilot}?">
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT Academy] Enrollment aborted: pilot registry missing for ' + $pilot.name + ' even after register call'" chance="100"/>
            </do_if>
            <set_value name="$abort" exact="true"/>
          </do_if>
        </do_if>

        <do_if value="not $abort">
          <!-- Validate target-level vs current level (defense in depth; Lua already filters) -->
          <set_value name="$pilotLevel" exact="1"/>
          <do_if value="global.$GT_Pilots.{$pilot}.$Level?">
            <set_value name="$pilotLevel" exact="global.$GT_Pilots.{$pilot}.$Level"/>
          </do_if>
          <do_if value="$targetLevel le $pilotLevel">
            <show_notification text="{77000,9922}.[$pilot.name]" timeout="6s" priority="6"/>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT Academy] Enrollment rejected: target lvl ' + $targetLevel + ' le pilot lvl ' + $pilotLevel" chance="100"/>
            </do_if>
            <set_value name="$abort" exact="true"/>
          </do_if>
        </do_if>

        <do_if value="not $abort">
          <!-- Validate funds (player may have spent credits between menu open and click) -->
          <do_if value="player.money lt $lockedCost">
            <show_notification text="{77000,9921}.[$lockedCost / 100, player.money / 100]" timeout="6s" priority="7"/>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT Academy] Enrollment rejected: insufficient funds (need ' + ($lockedCost / 100) + ' Cr, have ' + (player.money / 100) + ' Cr)'" chance="100"/>
            </do_if>
            <set_value name="$abort" exact="true"/>
          </do_if>
        </do_if>

        <do_if value="not $abort">
          <!-- Override any in-flight training (override-policy choice) -->
          <do_if value="global.$GT_Pilots.{$pilot}.$TrainingState? and global.$GT_Pilots.{$pilot}.$TrainingState == 'training_in_progress'">
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT Academy] Overriding in-flight training for pilot ' + $pilot.name" chance="100"/>
            </do_if>
            <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
              $Pilot  = $pilot,
              $Ship   = $ship,
              $Reason = 'academy_override'
            ]"/>
          </do_if>

          <!-- Stamp academy markers so HandleStartTraining (canonical path
               via the AI script's GT_Start_Training signal) and the legacy
               InitiateTraining cue (player-avatar dock) both consume the
               locked-in cost/duration instead of the natural ladder. -->
          <set_value name="global.$GT_Pilots.{$pilot}.$AcademyEnrollment" exact="table[
            $Level    = $targetLevel,
            $Cost     = $lockedCost,
            $Duration = $lockedDuration,
            $StartedAt = player.age
          ]"/>

          <!-- The completion handler reads $PendingSkillLevel to actually apply
               the new skill rank (see HandleCompleteTraining / ProcessTrainingEvents). -->
          <set_value name="global.$GT_Pilots.{$pilot}.$PendingSkillLevel" exact="$targetLevel"/>

          <!-- Mark the pilot as needing training at the academy target level
               (this is what the existing pipeline reads to know what to do). -->
          <run_actions ref="md.GT_Libraries_General.GT_SetTrainingBlocked">
            <param name="pilot"         value="$pilot"/>
            <param name="level"         value="$targetLevel"/>
            <param name="set_xpblocked" value="true"/>
          </run_actions>

          <set_value name="global.$GT_Pilots.{$pilot}.$ManualTrainingRequested" exact="true"/>
          <set_value name="global.$GT_Pilots.{$pilot}.$TrainingState" exact="'manual_training_queued'"/>
          <remove_value name="global.$GT_Pilots.{$pilot}.$NextTrainingRetryAt"/>

          <!-- User-facing notification + logbook -->
          <show_notification text="{77000,9920}.[$pilot.name, $targetLevel]" timeout="8s" priority="7"/>

          <run_actions ref="md.GT_Libraries_General.GT_IsLogbookEnabled" result="$logbookEnabled">
            <param name="ship" value="$ship"/>
          </run_actions>
          <do_if value="$logbookEnabled">
            <!-- $lockedCost arrived from the Lua blackboard as a plain
                 centi-credits number, but the WriteLogbookMessage library
                 forwards $Money straight into <write_to_logbook money=...>
                 which demands datatype.money. Promote the value with
                 `n * 1Cr / 100` (preserves magnitude, attaches money type)
                 into a separate local so $lockedCost stays usable for the
                 `/ 100` math in the user-facing message above. -->
            <set_value name="$lockedCostMoney" exact="($lockedCost * 1Cr) / 100"/>
            <run_actions ref="md.GT_Libraries_General.WriteLogbookMessage">
              <param name="Message"     value="{77000,9923}.[$pilot.name, $targetLevel, $lockedCost / 100, $lockedDuration / 60s, $ship.knownname]"/>
              <param name="Category"    value="'upkeep'"/>
              <param name="Title"       value="'Trading Academy: ' + $pilot.name + ' (' + $ship.knownname + ')'"/>
              <param name="Object"      value="$ship"/>
              <param name="Interaction" value="'showonmap'"/>
              <param name="Money"       value="-$lockedCostMoney"/>
              <param name="CheckGlobalSettings" value="false"/>
            </run_actions>
          </do_if>

          <!-- Kick the existing training-needed pipeline immediately rather than
               waiting for the next monitoring loop iteration. -->
          <signal_objects object="player.galaxy" param="'GT_Training_Needed'" param2="table[
            $Ship  = $ship,
            $Pilot = $pilot
          ]" delay="500ms"/>

          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT Academy] Enrolled pilot ' + $pilot.name + ' (ship ' + $ship.idcode + ') in lvl ' + $targetLevel + ' course (cost: ' + ($lockedCost / 100) + ' Cr, duration: ' + ($lockedDuration / 60s) + ' min)'" chance="100"/>
          </do_if>
        </do_if>
      </actions>
    </cue>

  </cues>
</mdscript>
