<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.commander_order.resolve" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Returns the GalaxyTrader defaultorder table subordinates should inherit from:
      - null when ship is standalone, has no GT commander, or commander is a station
      - commander.defaultorder when its id is in validOrderIds
      - commander.defaultorder.$baseorder when commander runs vanilla Assist over a GT baseorder

    Mirrors md/gt_context_diagnose.xml Order Source resolution and lib.gt.priority_wares.resolve.xml.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="validOrderIds" default="['GalaxyTraderMK3']"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists or not $ship.commander? or not @$ship.commander.exists or $ship.commander == $ship or @$ship.commander.isclass.station">
        <return value="null"/>
      </do_if>
      <set_value name="$cmdOrder" exact="$ship.commander.defaultorder"/>
      <do_if value="not $cmdOrder?">
        <return value="null"/>
      </do_if>
      <do_if value="$validOrderIds? and $validOrderIds.indexof.{@$cmdOrder.id}">
        <return value="$cmdOrder"/>
      </do_if>
      <do_if value="@$cmdOrder.id == 'Assist' and $cmdOrder.$baseorder? and $validOrderIds? and $validOrderIds.indexof.{@$cmdOrder.$baseorder.id}">
        <return value="$cmdOrder.$baseorder"/>
      </do_if>
      <return value="null"/>
    </actions>
  </attention>
</aiscript>
