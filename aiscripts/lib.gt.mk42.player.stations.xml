<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.mk42.player.stations" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="homeSector" default="null"/>
    <param name="maxDistance" default="0" comment="Supplier coverage (pilot jump distance). 0 = unlimited."/>
    <param name="maxDistanceSell" default="0" comment="Delivery buyer coverage (jumpDistanceCoverage). 0 = use maxDistance."/>
    <param name="includePlayerSuppliers" default="true"/>
    <param name="debugchance" default="0"/>
    <param name="ship" default="null" comment="Optional idcode for debug logging."/>
  </params>
  <attention min="unknown">
    <actions>
      <create_list name="$buyersInRange"/>
      <create_list name="$suppliersInRange"/>
      <set_value name="$deliveryCoverageMax" exact="if $maxDistanceSell? and $maxDistanceSell gt 0 then $maxDistanceSell else $maxDistance"/>
      <set_value name="$supplierCoverageMax" exact="$maxDistance"/>
      <set_value name="$stationsFound" exact="0"/>
      <set_value name="$buyersSeen" exact="table[]"/>

      <do_if value="$homeSector? and @$homeSector.exists">
        <find_station_by_true_owner name="$allPlayerStations" faction="faction.player" space="player.galaxy" checkoperational="true" multiple="true"/>
        <do_if value="$allPlayerStations? and $allPlayerStations.count gt 0">
          <do_all exact="$allPlayerStations.count" counter="$psi">
            <set_value name="$pst" exact="$allPlayerStations.{$psi}"/>
            <do_if value="not $pst? or not @$pst.exists">
              <continue/>
            </do_if>
            <set_value name="$stationsFound" operation="add"/>
            <set_value name="$pstSector" exact="if $pst.sector? then @$pst.sector else null"/>
            <do_if value="not $pstSector? or not @$pstSector.exists">
              <continue/>
            </do_if>
            <set_value name="$pstGateDist" exact="$homeSector.gatedistance.{$pstSector}"/>
            <do_if value="$pstGateDist lt 0">
              <continue/>
            </do_if>
            <set_value name="$pstInDeliveryRange" exact="$deliveryCoverageMax le 0 or $pstGateDist le $deliveryCoverageMax"/>
            <set_value name="$pstInSupplierRange" exact="$supplierCoverageMax le 0 or $pstGateDist le $supplierCoverageMax"/>
            <do_if value="$pstInSupplierRange and $includePlayerSuppliers">
              <append_to_list name="$suppliersInRange" exact="$pst"/>
            </do_if>
            <do_if value="$pstInDeliveryRange">
              <do_if value="not $buyersSeen.{$pst}?">
                <set_value name="$buyersSeen.{$pst}" exact="true"/>
                <append_to_list name="$buyersInRange" exact="$pst"/>
              </do_if>
              <do_if value="$pst.buildstorage? and @$pst.buildstorage.exists and not $buyersSeen.{$pst.buildstorage}?">
                <set_value name="$buyersSeen.{$pst.buildstorage}" exact="true"/>
                <append_to_list name="$buyersInRange" exact="$pst.buildstorage"/>
              </do_if>
            </do_if>
          </do_all>
        </do_if>
        <find_object name="$standaloneBuildStorages" class="class.buildstorage" space="player.galaxy" owner="faction.player" multiple="true"/>
        <do_if value="$standaloneBuildStorages? and $standaloneBuildStorages.count gt 0">
          <do_all exact="$standaloneBuildStorages.count" counter="$bsi">
            <set_value name="$bs" exact="$standaloneBuildStorages.{$bsi}"/>
            <do_if value="not $bs? or not @$bs.exists or $buyersSeen.{$bs}?">
              <continue/>
            </do_if>
            <set_value name="$bsSector" exact="if $bs.sector? then @$bs.sector else null"/>
            <do_if value="not $bsSector? or not @$bsSector.exists">
              <continue/>
            </do_if>
            <set_value name="$bsGateDist" exact="$homeSector.gatedistance.{$bsSector}"/>
            <do_if value="$bsGateDist lt 0">
              <continue/>
            </do_if>
            <do_if value="$deliveryCoverageMax le 0 or $bsGateDist le $deliveryCoverageMax">
              <set_value name="$buyersSeen.{$bs}" exact="true"/>
              <append_to_list name="$buyersInRange" exact="$bs"/>
            </do_if>
          </do_all>
        </do_if>
      </do_if>

      <do_if value="$debugchance gt 0 and $ship?">
        <debug_text text="'[GT-LiveSearch] ' + $ship.idcode + ': player-station discovery home=' + (if $homeSector? then @$homeSector.knownname else '?') + ' stations=' + $stationsFound + ' buyersInRange=' + $buyersInRange.count + ' suppliersInRange=' + $suppliersInRange.count + ' deliveryMax=' + $deliveryCoverageMax + 'j supplierMax=' + $supplierCoverageMax + 'j'" chance="$debugchance"/>
      </do_if>

      <return value="table[
        $BuyersInRange = $buyersInRange,
        $SuppliersInRange = $suppliersInRange,
        $DeliveryCoverageMax = $deliveryCoverageMax,
        $SupplierCoverageMax = $supplierCoverageMax
      ]"/>
    </actions>
  </attention>
</aiscript>
