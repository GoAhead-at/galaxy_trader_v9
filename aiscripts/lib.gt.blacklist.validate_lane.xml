<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.blacklist.validate_lane" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    MK2/MK1 lane blacklist preflight (parity with MK3 trade_found partner checks).
    buyStation = pickup source; sellStation = delivery destination.
    Whitelist overrides sector blacklist (matches GT_IsSectorBlacklisted).
    Escape: selling from a blacklisted sector the ship is already in is allowed unless the station is object-blacklisted.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="buyStation" default="null"/>
    <param name="sellStation" default="null"/>
    <param name="blacklistGroup" default="null"/>
    <param name="sectorWhitelist" default="[]"/>
    <param name="checkThreat" default="true"/>
    <param name="checkPath" default="false"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$yieldMs" exact="1"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Performance? and global.$GT_GlobalSettings.$Performance.$AIYieldInterval?">
        <set_value name="$yieldMs" exact="[1, @global.$GT_GlobalSettings.$Performance.$AIYieldInterval].max"/>
      </do_if>

      <set_value name="$result" exact="table[$Blocked = false, $Reason = '', $Leg = '']"/>
      <set_value name="$resolvedBlacklistGroup" exact="$blacklistGroup"/>
      <do_if value="not $resolvedBlacklistGroup? or $resolvedBlacklistGroup == null">
        <set_value name="$resolvedBlacklistGroup" exact="blacklistgroup.civilian"/>
        <do_if value="(@$ship.primarypurpose == purpose.fight) or (@$ship.primarypurpose == purpose.auxiliary)">
          <set_value name="$resolvedBlacklistGroup" exact="blacklistgroup.military"/>
        </do_if>
      </do_if>

      <set_value name="$validationWhitelist" exact="[]"/>
      <do_if value="$sectorWhitelist? and $sectorWhitelist != null and $sectorWhitelist.count gt 0">
        <set_value name="$validationWhitelist" exact="$sectorWhitelist"/>
      </do_if>

      <do_if value="not $buyStation? or not $buyStation.exists or not $sellStation? or not $sellStation.exists">
        <set_value name="$result.$Blocked" exact="true"/>
        <set_value name="$result.$Reason" exact="'invalid_station'"/>
        <set_value name="$result.$Leg" exact="'station'"/>
        <wait exact="$yieldMs * 1ms"/>
        <return value="$result"/>
      </do_if>

      <set_value name="$currentSector" exact="$ship.sector"/>
      <set_value name="$buySector" exact="$buyStation.sector"/>
      <set_value name="$sellSector" exact="$sellStation.sector"/>

      <!-- GT dynamic threat sectors (both legs) -->
      <do_if value="$checkThreat and global.$GT_ThreatIntelligence? and global.$GT_ThreatIntelligence.$BlacklistedSectors? and global.$GT_ThreatIntelligence.$BlacklistedSectors.count gt 0">
        <do_all exact="global.$GT_ThreatIntelligence.$BlacklistedSectors.count" counter="$bli">
          <set_value name="$threatSector" exact="global.$GT_ThreatIntelligence.$BlacklistedSectors.{$bli}"/>
          <do_if value="$threatSector == $buySector or $threatSector == $sellSector">
            <set_value name="$sectorWhitelisted" exact="false"/>
            <do_if value="$validationWhitelist.count gt 0">
              <do_all exact="$validationWhitelist.count" counter="$swi">
                <do_if value="$validationWhitelist.{$swi} == $threatSector">
                  <set_value name="$sectorWhitelisted" exact="true"/>
                  <break/>
                </do_if>
              </do_all>
            </do_if>
            <do_if value="not $sectorWhitelisted">
              <set_value name="$result.$Blocked" exact="true"/>
              <set_value name="$result.$Reason" exact="'threat_sector'"/>
              <set_value name="$result.$Leg" exact="if $threatSector == $buySector then 'buy_threat' else 'sell_threat'"/>
              <wait exact="$yieldMs * 1ms"/>
              <return value="$result"/>
            </do_if>
          </do_if>
        </do_all>
      </do_if>

      <!-- BUY partner blacklist -->
      <set_value name="$buyBlacklisted" exact="false"/>
      <set_value name="$buyStationBlacklisted" exact="@$buyStation.isblacklisted.{blacklisttype.objectactivity}.{$resolvedBlacklistGroup}.{$ship}"/>
      <set_value name="$buySectorWhitelisted" exact="false"/>
      <do_if value="$validationWhitelist.count gt 0">
        <do_all exact="$validationWhitelist.count" counter="$swIdx">
          <do_if value="$validationWhitelist.{$swIdx} == $buySector">
            <set_value name="$buySectorWhitelisted" exact="true"/>
            <break/>
          </do_if>
        </do_all>
      </do_if>
      <set_value name="$buySectorActivityBlacklisted" exact="false"/>
      <set_value name="$buySectorTravelBlacklisted" exact="false"/>
      <do_if value="not $buySectorWhitelisted">
        <set_value name="$buySectorActivityBlacklisted" exact="@$buySector.isblacklisted.{blacklisttype.sectoractivity}.{$resolvedBlacklistGroup}.{$ship}"/>
        <set_value name="$buySectorTravelBlacklisted" exact="@$buySector.isblacklisted.{blacklisttype.sectortravel}.{$resolvedBlacklistGroup}.{$ship}"/>
      </do_if>
      <do_if value="$buySectorActivityBlacklisted or $buySectorTravelBlacklisted">
        <set_value name="$buyBlacklisted" exact="true"/>
      </do_if>
      <do_else>
        <set_value name="$buyBlacklisted" exact="$buyStationBlacklisted"/>
      </do_else>
      <do_if value="$buyBlacklisted">
        <set_value name="$result.$Blocked" exact="true"/>
        <set_value name="$result.$Reason" exact="'buy_blacklisted'"/>
        <set_value name="$result.$Leg" exact="'buy'"/>
        <wait exact="$yieldMs * 1ms"/>
        <return value="$result"/>
      </do_if>

      <!-- SELL partner blacklist (escape-aware) -->
      <set_value name="$sellBlacklisted" exact="false"/>
      <set_value name="$sellStationBlacklisted" exact="@$sellStation.isblacklisted.{blacklisttype.objectactivity}.{$resolvedBlacklistGroup}.{$ship}"/>
      <set_value name="$sellSectorWhitelisted" exact="false"/>
      <do_if value="$validationWhitelist.count gt 0">
        <do_all exact="$validationWhitelist.count" counter="$swIdx">
          <do_if value="$validationWhitelist.{$swIdx} == $sellSector">
            <set_value name="$sellSectorWhitelisted" exact="true"/>
            <break/>
          </do_if>
        </do_all>
      </do_if>
      <set_value name="$sellSectorActivityBlacklisted" exact="false"/>
      <set_value name="$sellSectorTravelBlacklisted" exact="false"/>
      <do_if value="not $sellSectorWhitelisted">
        <set_value name="$sellSectorActivityBlacklisted" exact="@$sellSector.isblacklisted.{blacklisttype.sectoractivity}.{$resolvedBlacklistGroup}.{$ship}"/>
        <set_value name="$sellSectorTravelBlacklisted" exact="@$sellSector.isblacklisted.{blacklisttype.sectortravel}.{$resolvedBlacklistGroup}.{$ship}"/>
      </do_if>
      <do_if value="$sellSectorActivityBlacklisted or $sellSectorTravelBlacklisted">
        <do_if value="$sellSector == $currentSector">
          <set_value name="$sellBlacklisted" exact="$sellStationBlacklisted"/>
        </do_if>
        <do_else>
          <set_value name="$sellBlacklisted" exact="true"/>
        </do_else>
      </do_if>
      <do_else>
        <set_value name="$sellBlacklisted" exact="$sellStationBlacklisted"/>
      </do_else>
      <do_if value="$sellBlacklisted">
        <set_value name="$result.$Blocked" exact="true"/>
        <set_value name="$result.$Reason" exact="'sell_blacklisted'"/>
        <set_value name="$result.$Leg" exact="'sell'"/>
        <wait exact="$yieldMs * 1ms"/>
        <return value="$result"/>
      </do_if>

      <!-- Optional blacklist-aware path reachability (ship -> buy -> sell) -->
      <do_if value="$checkPath">
        <set_value name="$currentSectorIsBlacklisted" exact="false"/>
        <set_value name="$currentSectorWhitelisted" exact="false"/>
        <do_if value="$validationWhitelist.count gt 0">
          <do_all exact="$validationWhitelist.count" counter="$swIdx">
            <do_if value="$validationWhitelist.{$swIdx} == $currentSector">
              <set_value name="$currentSectorWhitelisted" exact="true"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>
        <do_if value="not $currentSectorWhitelisted">
          <set_value name="$curActBL" exact="@$currentSector.isblacklisted.{blacklisttype.sectoractivity}.{$resolvedBlacklistGroup}.{$ship}"/>
          <set_value name="$curTrvBL" exact="@$currentSector.isblacklisted.{blacklisttype.sectortravel}.{$resolvedBlacklistGroup}.{$ship}"/>
          <set_value name="$currentSectorIsBlacklisted" exact="$curActBL or $curTrvBL"/>
        </do_if>

        <set_value name="$buyDistance" exact="-1"/>
        <do_if value="$buySector == $currentSector">
          <set_value name="$buyDistance" exact="0"/>
        </do_if>
        <do_elseif value="$currentSectorIsBlacklisted">
          <set_value name="$buyDistance" exact="$ship.gatedistance.{$buySector}"/>
        </do_elseif>
        <do_else>
          <set_value name="$buyDistance" exact="$ship.gatedistance.{$buySector}.{$resolvedBlacklistGroup}.{$ship}"/>
        </do_else>
        <do_if value="$buyDistance lt 0">
          <set_value name="$result.$Blocked" exact="true"/>
          <set_value name="$result.$Reason" exact="'path_buy'"/>
          <set_value name="$result.$Leg" exact="'path'"/>
          <wait exact="$yieldMs * 1ms"/>
          <return value="$result"/>
        </do_if>

        <set_value name="$sellDistance" exact="-1"/>
        <do_if value="$sellSector == $buySector">
          <set_value name="$sellDistance" exact="0"/>
        </do_if>
        <do_elseif value="$buySector == $currentSector">
          <do_if value="$currentSectorIsBlacklisted">
            <set_value name="$sellDistance" exact="$ship.gatedistance.{$sellSector}"/>
          </do_if>
          <do_else>
            <set_value name="$sellDistance" exact="$ship.gatedistance.{$sellSector}.{$resolvedBlacklistGroup}.{$ship}"/>
          </do_else>
        </do_elseif>
        <do_else>
          <set_value name="$sellDistance" exact="$buySector.gatedistance.{$sellSector}.{$resolvedBlacklistGroup}.{$ship}"/>
        </do_else>
        <do_if value="$sellDistance lt 0">
          <set_value name="$result.$Blocked" exact="true"/>
          <set_value name="$result.$Reason" exact="'path_sell'"/>
          <set_value name="$result.$Leg" exact="'path'"/>
          <wait exact="$yieldMs * 1ms"/>
          <return value="$result"/>
        </do_if>
      </do_if>

      <wait exact="$yieldMs * 1ms"/>
      <return value="$result"/>
    </actions>
  </attention>
</aiscript>
