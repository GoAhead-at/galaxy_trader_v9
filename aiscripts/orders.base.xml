<?xml version="1.0" encoding="utf-8"?>
<diff>

  <!-- Prevent undocking for GalaxyTrader DockAndTrain / DockAndPilotExchange orders -->
  <add sel="//aiscript[@name='orders.base']/attention/actions/do_if[@value='$undock?']" pos="before">
    <do_if value="@$undock and (($object.order.id == 'DockAndTrain') or ($object.order.id == 'DockAndPilotExchange') or ($object.order.id == 'DockAndWait' and (@$object.order.$callerid.id == 'DockAndTrain' or @$object.order.$callerid.id == 'DockAndPilotExchange')))">
      <remove_value name="$undock"/>
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT ORDER PATCH] Preventing undock for GT dock wrapper order on ship: ' + $object.knownname + ' order=' + @$object.order.id" chance="if $object.isplayerowned then 100 else 0"/>
      </do_if>
    </do_if>
  </add>

</diff> 