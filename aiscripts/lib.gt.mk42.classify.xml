<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.mk42.classify — single trade-object classification + priority helper for MK4-2 supply (OPEN_GALAXYTRADER_MK4-2_SUPPLY_ORDER.md §2). -->
<aiscript name="lib.gt.mk42.classify" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="customer" default="null" comment="Delivery target (buy-offer owner / need customer)"/>
    <param name="priorities" default="table[]" comment="table[$Buildstorage=N, $Stations=N, $Aux=N, $Carrier=N]"/>
    <param name="mode" default="'classify'" comment="classify | multiplier | both"/>
  </params>
  <attention min="unknown">
    <actions>
      <!-- Class enum strings: Buildstorage | Stations | Carrier | Aux | None -->
      <set_value name="$class" exact="'None'"/>
      <set_value name="$multiplier" exact="0"/>
      <set_value name="$eligible" exact="false"/>

      <do_if value="not $customer? or not @$customer.exists">
        <return value="table[$Class = 'None', $Multiplier = 0, $Eligible = false]"/>
      </do_if>

      <!-- Precedence: Buildstorage > Stations > Carrier > Aux (§2.1) -->
      <do_if value="@$customer.isclass.buildstorage and @$customer.isplayerowned">
        <set_value name="$class" exact="'Buildstorage'"/>
      </do_if>
      <do_elseif value="@$customer.isclass.station and @$customer.isplayerowned">
        <set_value name="$class" exact="'Stations'"/>
      </do_elseif>
      <do_elseif value="@$customer.isclass.ship and @$customer.type == shiptype.carrier">
        <set_value name="$class" exact="'Carrier'"/>
      </do_elseif>
      <do_elseif value="@$customer.isclass.ship and @$customer.primarypurpose == purpose.auxiliary">
        <set_value name="$class" exact="'Aux'"/>
      </do_elseif>
      <do_elseif value="@$customer.isclass.buildstorage and $customer.base? and @$customer.base.isplayerowned">
        <set_value name="$class" exact="'Buildstorage'"/>
      </do_elseif>

      <do_if value="$class != 'None' and $priorities?">
        <do_if value="$class == 'Buildstorage'">
          <set_value name="$multiplier" exact="if $priorities.$Buildstorage? then $priorities.$Buildstorage else 0"/>
        </do_if>
        <do_elseif value="$class == 'Stations'">
          <set_value name="$multiplier" exact="if $priorities.$Stations? then $priorities.$Stations else 0"/>
        </do_elseif>
        <do_elseif value="$class == 'Aux'">
          <set_value name="$multiplier" exact="if $priorities.$Aux? then $priorities.$Aux else 0"/>
        </do_elseif>
        <do_elseif value="$class == 'Carrier'">
          <set_value name="$multiplier" exact="if $priorities.$Carrier? then $priorities.$Carrier else 0"/>
        </do_elseif>
      </do_if>

      <set_value name="$eligible" exact="$class != 'None' and $multiplier gt 0"/>

      <return value="table[$Class = $class, $Multiplier = $multiplier, $Eligible = $eligible]"/>
    </actions>
  </attention>
</aiscript>
