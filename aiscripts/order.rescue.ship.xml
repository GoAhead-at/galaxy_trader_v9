<?xml version="1.0" encoding="utf-8"?>
<diff>
  <!-- GalaxyTrader MK3: notify MD when a stranded pilot is transferred aboard via create_npc_template. -->
  <replace sel="//aiscript[@name='order.rescue.ship']//do_if[@value='$target.exists and not $target.hascontext.{this.assignedcontrolled} and $targetentity != player.entity']/do_if[@value='this.trueowner == $target.trueowner']/create_npc_template">
    <create_npc_template name="$gt_sar_crew_template" entity="$targetentity" object="this.assignedcontrolled" role="entityrole.unassigned" force="true"/>
    <set_value name="$gt_sar_stable" exact="''"/>
    <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? and global.$GT_Pilots.{$targetentity}.$StableIdentity?">
      <set_value name="$gt_sar_stable" exact="global.$GT_Pilots.{$targetentity}.$StableIdentity"/>
    </do_if>
    <do_elseif value="$targetentity.seed?">
      <set_value name="$gt_sar_stable" exact="'s:' + $targetentity.seed"/>
    </do_elseif>
    <set_value name="$gt_sar_registry_key" exact="if global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? then $targetentity else null"/>
    <!-- Split the uint64 npctemplate id into 32-bit halves here: modulo works on npctemplate in AI, not in MD.
         PeopleSeed and the live crew entity are resolved MD-side (they lag at create_npc_template time). -->
    <set_value name="$gt_sar_wire_lo" exact="$gt_sar_crew_template % 4294967296L"/>
    <do_if value="$gt_sar_wire_lo lt 0">
      <set_value name="$gt_sar_wire_lo" exact="$gt_sar_wire_lo + 4294967296L"/>
    </do_if>
    <set_value name="$gt_sar_wire_hi" exact="(($gt_sar_crew_template - $gt_sar_wire_lo) / 4294967296L)i"/>
    <do_if value="not global.$GT_SarCrewTemplateScratch?">
      <set_value name="global.$GT_SarCrewTemplateScratch" exact="table[]"/>
    </do_if>
    <do_if value="this.assignedcontrolled? and this.assignedcontrolled.exists">
      <set_value name="global.$GT_SarCrewTemplateScratch.{this.assignedcontrolled}" exact="table[
        $Template = $gt_sar_crew_template,
        $Stable = $gt_sar_stable,
        $WireHi = $gt_sar_wire_hi,
        $WireLo = $gt_sar_wire_lo
      ]"/>
    </do_if>
    <signal_objects object="player.galaxy"
                    param="'gt_sar_pilot_transferred'"
                    param2="table[
                      $StrandedPilot = $targetentity,
                      $RescueShip = this.assignedcontrolled,
                      $Spacesuit = $target,
                      $CrewTemplate = $gt_sar_crew_template,
                      $StableIdentity = $gt_sar_stable,
                      $RegistryKeyHint = $gt_sar_registry_key
                    ]"/>
  </replace>
</diff>
