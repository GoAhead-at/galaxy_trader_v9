<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.mk42.customer.funds — player-customer funds gate for MK4-2 cache/diagnose.
     FreeDelivery (buyfree OR player supplier) → Ok.
     Else require sellStation.money >= unitPrice (one unit).
     No <wait>. Inlines free-supplier rules (no nested run_script). -->
<aiscript name="lib.gt.mk42.customer.funds" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="sellStation" default="null"/>
    <param name="sellOffer" default="null"/>
    <param name="buyStation" default="null"/>
    <param name="buyOffer" default="null"/>
    <param name="unitPrice" default="0" comment="Customer cost per unit; default from sellOffer.unitprice"/>
    <param name="trade" default="null"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bs" exact="$buyStation"/>
      <set_value name="$bo" exact="$buyOffer"/>
      <set_value name="$ss" exact="$sellStation"/>
      <set_value name="$so" exact="$sellOffer"/>
      <do_if value="$trade? and $trade != null">
        <do_if value="(not $bs? or not @$bs.exists) and $trade.$BuyStation? and @$trade.$BuyStation.exists">
          <set_value name="$bs" exact="$trade.$BuyStation"/>
        </do_if>
        <do_if value="(not $bo? or not @$bo.exists) and $trade.$BuyOffer?">
          <set_value name="$bo" exact="$trade.$BuyOffer"/>
        </do_if>
        <do_if value="(not $ss? or not @$ss.exists) and $trade.$SellStation? and @$trade.$SellStation.exists">
          <set_value name="$ss" exact="$trade.$SellStation"/>
        </do_if>
        <do_if value="(not $so? or not @$so.exists) and $trade.$SellOffer?">
          <set_value name="$so" exact="$trade.$SellOffer"/>
        </do_if>
      </do_if>

      <set_value name="$playerFreeSupplier" exact="false"/>
      <do_if value="$trade? and $trade.$PlayerFreeSupplier? and $trade.$PlayerFreeSupplier">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_if>
      <do_elseif value="$bs? and @$bs.exists and @$bs.isplayerowned">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_elseif>
      <do_elseif value="$bo? and @$bo.exists and $bo.owner? and @$bo.owner.exists and @$bo.owner.isplayerowned">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_elseif>

      <set_value name="$freeDelivery" exact="false"/>
      <do_if value="$so? and @$so.exists">
        <do_if value="@$so.buyfree">
          <set_value name="$freeDelivery" exact="true"/>
        </do_if>
        <do_elseif value="$ss? and @$ss.exists and @$so.buyfree.{$ss}">
          <set_value name="$freeDelivery" exact="true"/>
        </do_elseif>
      </do_if>
      <do_if value="not $freeDelivery and $playerFreeSupplier">
        <set_value name="$freeDelivery" exact="true"/>
      </do_if>

      <set_value name="$price" exact="if $unitPrice? and $unitPrice gt 0 then $unitPrice else 0"/>
      <do_if value="$price le 0 and $so? and @$so.exists and $so.unitprice?">
        <set_value name="$price" exact="@$so.unitprice"/>
      </do_if>

      <set_value name="$customerIsPlayer" exact="false"/>
      <do_if value="$ss? and @$ss.exists">
        <do_if value="@$ss.isplayerowned">
          <set_value name="$customerIsPlayer" exact="true"/>
        </do_if>
        <do_elseif value="@$ss.isclass.buildstorage and $ss.base? and @$ss.base.exists and @$ss.base.isplayerowned">
          <set_value name="$customerIsPlayer" exact="true"/>
        </do_elseif>
      </do_if>

      <set_value name="$ok" exact="true"/>
      <set_value name="$reason" exact="''"/>
      <do_if value="$customerIsPlayer and $price gt 0">
        <do_if value="$freeDelivery">
          <set_value name="$ok" exact="true"/>
        </do_if>
        <do_elseif value="not $ss? or not @$ss.exists">
          <set_value name="$ok" exact="false"/>
          <set_value name="$reason" exact="'customer_missing'"/>
        </do_elseif>
        <do_elseif value="@$ss.money lt $price">
          <set_value name="$ok" exact="false"/>
          <set_value name="$reason" exact="'customer_no_funds'"/>
        </do_elseif>
      </do_if>

      <!-- Prefer inlining this gate in hot cache-scan loops instead of run_script.
           No <wait>: callers may be mid-order construction; yielding breaks LIFO queueing. -->
      <return value="table[
        $Ok = $ok,
        $Reason = $reason,
        $FreeDelivery = $freeDelivery,
        $PlayerFreeSupplier = $playerFreeSupplier,
        $CustomerIsPlayer = $customerIsPlayer,
        $UnitPrice = $price,
        $CustomerMoney = if $ss? and @$ss.exists then @$ss.money else 0
      ]"/>
    </actions>
  </attention>
</aiscript>
