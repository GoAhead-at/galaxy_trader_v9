<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.route.registry" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Per-ship active route registry + sector reverse index for threat notification.
    global.$GT_Ships.{ship}.$ActiveRoute - remaining sector path for current trade leg
    global.$GT_SectorRouteIndex.{sector} - list of ships whose remaining path includes sector
  -->
  <params>
    <param name="mode" default="'register'"/>
    <param name="ship" default="this.ship"/>
    <param name="destinationSector" default="null"/>
    <param name="leg" default="'buy'"/>
    <param name="sellSector" default="null"/>
    <param name="blacklistGroup" default="null"/>
    <param name="newSector" default="null"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists">
        <return/>
      </do_if>

      <do_if value="not global.$GT_Ships?">
        <set_value name="global.$GT_Ships" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_Ships.{$ship}?">
        <set_value name="global.$GT_Ships.{$ship}" exact="table[]"/>
      </do_if>
      <do_if value="not global.$GT_SectorRouteIndex?">
        <set_value name="global.$GT_SectorRouteIndex" exact="table[]"/>
      </do_if>

      <!-- ================================================================= -->
      <!-- MODE: clear - remove ship from index and drop ActiveRoute           -->
      <!-- ================================================================= -->
      <do_if value="$mode == 'clear'">
        <do_if value="global.$GT_Ships.{$ship}.$ActiveRoute? and global.$GT_Ships.{$ship}.$ActiveRoute.$RemainingSectors?">
          <set_value name="$oldSectors" exact="global.$GT_Ships.{$ship}.$ActiveRoute.$RemainingSectors"/>
          <do_all exact="$oldSectors.count" counter="$osi">
            <set_value name="$osec" exact="$oldSectors.{$osi}"/>
            <do_if value="$osec != null and @$osec.exists and global.$GT_SectorRouteIndex.{$osec}?">
              <set_value name="$idxList" exact="global.$GT_SectorRouteIndex.{$osec}"/>
              <set_value name="$removeAt" exact="0"/>
              <do_all exact="$idxList.count" counter="$oii" reverse="true">
                <do_if value="$idxList.{$oii} == $ship">
                  <remove_from_list name="global.$GT_SectorRouteIndex.{$osec}" exact="$ship"/>
                </do_if>
              </do_all>
              <do_if value="global.$GT_SectorRouteIndex.{$osec}.count == 0">
                <remove_value name="global.$GT_SectorRouteIndex.{$osec}"/>
              </do_if>
            </do_if>
          </do_all>
        </do_if>
        <do_if value="global.$GT_Ships.{$ship}.$ActiveRoute?">
          <remove_value name="global.$GT_Ships.{$ship}.$ActiveRoute"/>
        </do_if>
        <return/>
      </do_if>

      <!-- ================================================================= -->
      <!-- MODE: trim - sector crossed; drop passed hops from index          -->
      <!-- ================================================================= -->
      <do_if value="$mode == 'trim'">
        <do_if value="not $newSector? or $newSector == null or not @$newSector.exists or not global.$GT_Ships.{$ship}.$ActiveRoute?">
          <return/>
        </do_if>
        <set_value name="$activeRoute" exact="global.$GT_Ships.{$ship}.$ActiveRoute"/>
        <set_value name="$remaining" exact="if $activeRoute.$RemainingSectors? then $activeRoute.$RemainingSectors else []"/>
        <do_if value="$remaining.count == 0">
          <return/>
        </do_if>

        <set_value name="$foundIdx" exact="0"/>
        <do_all exact="$remaining.count" counter="$tri">
          <do_if value="$foundIdx == 0 and $remaining.{$tri} == $newSector">
            <set_value name="$foundIdx" exact="$tri"/>
          </do_if>
        </do_all>

        <set_value name="$trimmed" exact="[]"/>
        <do_if value="$foundIdx gt 0">
          <do_all exact="$remaining.count - $foundIdx + 1" counter="$tai">
            <append_to_list name="$trimmed" exact="$remaining.{$foundIdx + $tai - 1}"/>
          </do_all>
        </do_if>
        <do_elseif value="$foundIdx == 0">
          <!-- Current sector not in cached path; rebuild on next register -->
          <return/>
        </do_elseif>

        <!-- Remove ship from sectors dropped off the remaining path -->
        <do_all exact="$remaining.count" counter="$dri">
          <set_value name="$dropSec" exact="$remaining.{$dri}"/>
          <set_value name="$stillOnPath" exact="false"/>
          <do_all exact="$trimmed.count" counter="$kei">
            <do_if value="$trimmed.{$kei} == $dropSec">
              <set_value name="$stillOnPath" exact="true"/>
              <break/>
            </do_if>
          </do_all>
          <do_if value="not $stillOnPath and $dropSec != null and @$dropSec.exists and global.$GT_SectorRouteIndex.{$dropSec}?">
            <set_value name="$dList" exact="global.$GT_SectorRouteIndex.{$dropSec}"/>
            <do_all exact="$dList.count" counter="$dii" reverse="true">
              <do_if value="$dList.{$dii} == $ship">
                <remove_from_list name="global.$GT_SectorRouteIndex.{$dropSec}" exact="$ship"/>
              </do_if>
            </do_all>
            <do_if value="global.$GT_SectorRouteIndex.{$dropSec}.count == 0">
              <remove_value name="global.$GT_SectorRouteIndex.{$dropSec}"/>
            </do_if>
          </do_if>
        </do_all>

        <set_value name="global.$GT_Ships.{$ship}.$ActiveRoute.$RemainingSectors" exact="$trimmed"/>
        <do_if value="global.$GT_Ships.{$ship}.$RoutePathCache? and global.$GT_Ships.{$ship}.$RoutePathCache.$RemainingSectors?">
          <set_value name="global.$GT_Ships.{$ship}.$RoutePathCache.$RemainingSectors" exact="$trimmed"/>
        </do_if>
        <return/>
      </do_if>

      <!-- ================================================================= -->
      <!-- MODE: sync_cache - copy RoutePathCache into ActiveRoute + index     -->
      <!-- ================================================================= -->
      <do_if value="$mode == 'sync_cache'">
        <do_if value="not global.$GT_Ships.{$ship}.$RoutePathCache?">
          <return/>
        </do_if>
        <set_value name="$cache" exact="global.$GT_Ships.{$ship}.$RoutePathCache"/>
        <set_value name="$syncSectors" exact="if $cache.$RemainingSectors? then $cache.$RemainingSectors else []"/>
        <do_if value="$syncSectors.count == 0">
          <return/>
        </do_if>
        <set_value name="$savedLeg" exact="'move'"/>
        <do_if value="global.$GT_Ships.{$ship}.$ActiveRoute? and global.$GT_Ships.{$ship}.$ActiveRoute.$Leg?">
          <set_value name="$savedLeg" exact="global.$GT_Ships.{$ship}.$ActiveRoute.$Leg"/>
        </do_if>
        <run_script name="'lib.gt.route.registry'">
          <param name="mode" value="'clear'"/>
          <param name="ship" value="$ship"/>
        </run_script>
        <set_value name="global.$GT_Ships.{$ship}.$ActiveRoute" exact="table[
          $DestinationSector = if $cache.$DestinationSector? then $cache.$DestinationSector else $syncSectors.{$syncSectors.count},
          $RemainingSectors = $syncSectors,
          $Leg = $savedLeg,
          $BlacklistGroup = if $cache.$BlacklistGroup? then $cache.$BlacklistGroup else blacklistgroup.civilian,
          $BlacklistEpoch = if $cache.$BlacklistEpoch? then $cache.$BlacklistEpoch else (if global.$GT_BlacklistEpoch? then global.$GT_BlacklistEpoch else 0),
          $UpdatedAt = player.age
        ]"/>
        <do_all exact="$syncSectors.count" counter="$sxi">
          <set_value name="$ssec" exact="$syncSectors.{$sxi}"/>
          <do_if value="$ssec != null and @$ssec.exists">
            <do_if value="not global.$GT_SectorRouteIndex.{$ssec}?">
              <set_value name="global.$GT_SectorRouteIndex.{$ssec}" exact="[]"/>
            </do_if>
            <set_value name="$alreadyListed" exact="false"/>
            <do_all exact="global.$GT_SectorRouteIndex.{$ssec}.count" counter="$sli">
              <do_if value="global.$GT_SectorRouteIndex.{$ssec}.{$sli} == $ship">
                <set_value name="$alreadyListed" exact="true"/>
                <break/>
              </do_if>
            </do_all>
            <do_if value="not $alreadyListed">
              <append_to_list name="global.$GT_SectorRouteIndex.{$ssec}" exact="$ship"/>
            </do_if>
          </do_if>
        </do_all>
        <return/>
      </do_if>

      <!-- ================================================================= -->
      <!-- MODE: register - build path to destination and publish index        -->
      <!-- ================================================================= -->
      <do_if value="$mode != 'register'">
        <return/>
      </do_if>
      <do_if value="not $destinationSector? or $destinationSector == null or not @$destinationSector.exists">
        <return/>
      </do_if>

      <set_value name="$resolvedBlacklistGroup" exact="$blacklistGroup"/>
      <do_if value="$resolvedBlacklistGroup == null">
        <set_value name="$resolvedBlacklistGroup" exact="blacklistgroup.civilian"/>
        <do_if value="$ship.isclass.[class.ship_m, class.ship_l, class.ship_xl]">
          <set_value name="$resolvedBlacklistGroup" exact="blacklistgroup.military"/>
        </do_if>
      </do_if>

      <set_value name="$startSector" exact="$ship.sector"/>
      <set_value name="$remainingSectors" exact="[]"/>
      <set_value name="$useLocalHighways" exact="true"/>
      <do_if value="$ship.isclass.ship_l or $ship.isclass.ship_xl">
        <set_value name="$useLocalHighways" exact="false"/>
      </do_if>
      <set_value name="$lastRouteSector" exact="null"/>
      <do_if value="$startSector != null and @$startSector.exists">
        <append_to_list name="$remainingSectors" exact="$startSector"/>
        <set_value name="$lastRouteSector" exact="$startSector"/>
      </do_if>

      <do_if value="$startSector != null and @$startSector.exists and $startSector != $destinationSector">
        <set_value name="$jumppath" exact="[]"/>
        <get_jump_path component="$jumppath" multiple="true" uselocalhighways="$useLocalHighways" useblacklist="$resolvedBlacklistGroup" refobject="$ship" useknownpath="$ship.isplayerowned">
          <start object="$ship"/>
          <end object="$destinationSector"/>
        </get_jump_path>
        <do_if value="$jumppath.count lt 2">
          <get_jump_path component="$jumppath" multiple="true" uselocalhighways="false" useblacklist="$resolvedBlacklistGroup" refobject="$ship" useknownpath="$ship.isplayerowned">
            <start object="$ship"/>
            <end object="$destinationSector"/>
          </get_jump_path>
        </do_if>

        <set_value name="$lastRouteSector" exact="$startSector"/>
        <do_all exact="$jumppath.count" counter="$jpidx">
          <set_value name="$pathComponent" exact="$jumppath.{$jpidx}"/>
          <do_if value="$pathComponent? and @$pathComponent.sector != null">
            <set_value name="$pathSector" exact="@$pathComponent.sector"/>
            <do_if value="$pathSector != null and @$pathSector.exists and ($lastRouteSector == null or $pathSector != $lastRouteSector)">
              <append_to_list name="$remainingSectors" exact="$pathSector"/>
              <set_value name="$lastRouteSector" exact="$pathSector"/>
            </do_if>
          </do_if>
        </do_all>
        <do_if value="$lastRouteSector != $destinationSector">
          <append_to_list name="$remainingSectors" exact="$destinationSector"/>
          <set_value name="$lastRouteSector" exact="$destinationSector"/>
        </do_if>
      </do_if>
      <do_elseif value="$remainingSectors.count == 0 or $remainingSectors.{$remainingSectors.count} != $destinationSector">
        <append_to_list name="$remainingSectors" exact="$destinationSector"/>
        <set_value name="$lastRouteSector" exact="$destinationSector"/>
      </do_elseif>

      <!-- Extend with sell leg when provided (full trade route for threat index) -->
      <set_value name="$finalDestination" exact="$destinationSector"/>
      <do_if value="$sellSector != null and @$sellSector.exists and $sellSector != $destinationSector">
        <set_value name="$pathToSell" exact="[]"/>
        <get_jump_path component="$pathToSell" multiple="true" uselocalhighways="$useLocalHighways" useblacklist="$resolvedBlacklistGroup" refobject="$ship" useknownpath="$ship.isplayerowned">
          <start object="$destinationSector"/>
          <end object="$sellSector"/>
        </get_jump_path>
        <do_if value="$pathToSell.count lt 2">
          <get_jump_path component="$pathToSell" multiple="true" uselocalhighways="false" useblacklist="$resolvedBlacklistGroup" refobject="$ship" useknownpath="$ship.isplayerowned">
            <start object="$destinationSector"/>
            <end object="$sellSector"/>
          </get_jump_path>
        </do_if>
        <do_all exact="$pathToSell.count" counter="$psidx">
          <set_value name="$psComponent" exact="$pathToSell.{$psidx}"/>
          <do_if value="$psComponent? and @$psComponent.sector != null">
            <set_value name="$psSector" exact="@$psComponent.sector"/>
            <do_if value="$psSector != null and @$psSector.exists and ($lastRouteSector == null or $psSector != $lastRouteSector)">
              <append_to_list name="$remainingSectors" exact="$psSector"/>
              <set_value name="$lastRouteSector" exact="$psSector"/>
            </do_if>
          </do_if>
        </do_all>
        <do_if value="$lastRouteSector != $sellSector">
          <append_to_list name="$remainingSectors" exact="$sellSector"/>
          <set_value name="$lastRouteSector" exact="$sellSector"/>
        </do_if>
        <set_value name="$finalDestination" exact="$sellSector"/>
      </do_if>
      <do_elseif value="$sellSector != null and @$sellSector.exists">
        <set_value name="$finalDestination" exact="$sellSector"/>
      </do_elseif>

      <run_script name="'lib.gt.route.registry'">
        <param name="mode" value="'clear'"/>
        <param name="ship" value="$ship"/>
      </run_script>

      <set_value name="$currentEpoch" exact="if global.$GT_BlacklistEpoch? then global.$GT_BlacklistEpoch else 0"/>
      <set_value name="global.$GT_Ships.{$ship}.$ActiveRoute" exact="table[
        $DestinationSector = $finalDestination,
        $RemainingSectors = $remainingSectors,
        $Leg = $leg,
        $BlacklistGroup = $resolvedBlacklistGroup,
        $BlacklistEpoch = $currentEpoch,
        $UpdatedAt = player.age
      ]"/>
      <set_value name="global.$GT_Ships.{$ship}.$RoutePathCache" exact="table[
        $DestinationSector = $destinationSector,
        $BlacklistGroup = $resolvedBlacklistGroup,
        $BlacklistEpoch = $currentEpoch,
        $RemainingSectors = $remainingSectors
      ]"/>

      <do_all exact="$remainingSectors.count" counter="$rsi">
        <set_value name="$rsec" exact="$remainingSectors.{$rsi}"/>
        <do_if value="$rsec != null and @$rsec.exists">
          <do_if value="not global.$GT_SectorRouteIndex.{$rsec}?">
            <set_value name="global.$GT_SectorRouteIndex.{$rsec}" exact="[]"/>
          </do_if>
          <set_value name="$shipListed" exact="false"/>
          <do_all exact="global.$GT_SectorRouteIndex.{$rsec}.count" counter="$sii">
            <do_if value="global.$GT_SectorRouteIndex.{$rsec}.{$sii} == $ship">
              <set_value name="$shipListed" exact="true"/>
              <break/>
            </do_if>
          </do_all>
          <do_if value="not $shipListed">
            <append_to_list name="global.$GT_SectorRouteIndex.{$rsec}" exact="$ship"/>
          </do_if>
        </do_if>
      </do_all>

      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <set_value name="$pathText" exact="''"/>
        <do_all exact="[$remainingSectors.count, 12].min" counter="$pti">
          <set_value name="$pname" exact="@$remainingSectors.{$pti}.knownname"/>
          <set_value name="$pathText" exact="if $pathText == '' then $pname else $pathText + ' -> ' + $pname"/>
        </do_all>
        <debug_text text="'[GT-RouteRegistry] ' + $ship.idcode + ': registered ' + $leg + ' route (' + $remainingSectors.count + ' sectors): ' + $pathText" chance="100"/>
      </do_if>
    </actions>
  </attention>
</aiscript>
