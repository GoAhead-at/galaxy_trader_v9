<?xml version="1.0" encoding="utf-8"?>
<diff>
  <!-- GalaxyTrader MK3: notify MD when a stranded pilot is transferred aboard via create_npc_template. -->
  <replace sel="//aiscript[@name='order.rescue.ship']//do_if[@value='$target.exists and not $target.hascontext.{this.assignedcontrolled} and $targetentity != player.entity']/do_if[@value='this.trueowner == $target.trueowner']/create_npc_template">
    <create_npc_template name="$gt_sar_crew_template" entity="$targetentity" object="this.assignedcontrolled" role="entityrole.unassigned" force="true"/>
    <set_value name="$gt_sar_stable" exact="''"/>
    <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? and global.$GT_Pilots.{$targetentity}.$StableIdentity?">
      <set_value name="$gt_sar_stable" exact="global.$GT_Pilots.{$targetentity}.$StableIdentity"/>
    </do_if>
    <do_elseif value="$targetentity.seed?">
      <set_value name="$gt_sar_stable" exact="'s:' + $targetentity.seed"/>
    </do_elseif>
    <set_value name="$gt_sar_registry_key" exact="if global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? then $targetentity else null"/>
    <set_value name="$gt_sar_people_seed" exact="null"/>
    <do_if value="this.assignedcontrolled.people.{$gt_sar_crew_template}? and this.assignedcontrolled.people.{$gt_sar_crew_template}.exists and this.assignedcontrolled.people.{$gt_sar_crew_template}.seed?">
      <set_value name="$gt_sar_people_seed" exact="this.assignedcontrolled.people.{$gt_sar_crew_template}.seed"/>
    </do_if>
    <set_value name="$gt_sar_wire_lo" exact="null"/>
    <set_value name="$gt_sar_wire_hi" exact="null"/>
    <set_value name="$gt_sar_wire_lo" exact="$gt_sar_crew_template % 4294967296"/>
    <do_if value="$gt_sar_wire_lo lt 0">
      <set_value name="$gt_sar_wire_lo" exact="$gt_sar_wire_lo + 4294967296"/>
    </do_if>
    <set_value name="$gt_sar_wire_hi" exact="(($gt_sar_crew_template - $gt_sar_wire_lo) / 4294967296)i"/>
    <do_if value="not global.$GT_SarCrewTemplateScratch?">
      <set_value name="global.$GT_SarCrewTemplateScratch" exact="table[]"/>
    </do_if>
    <do_if value="this.assignedcontrolled? and this.assignedcontrolled.exists">
      <set_value name="global.$GT_SarCrewTemplateScratch.{this.assignedcontrolled}" exact="table[
        $Template = $gt_sar_crew_template,
        $PeopleSeed = $gt_sar_people_seed,
        $Stable = $gt_sar_stable,
        $WireHi = $gt_sar_wire_hi,
        $WireLo = $gt_sar_wire_lo
      ]"/>
    </do_if>
    <!-- Prefer the new crew entity on the rescue hull; never pass the stranded spacesuit entity as LiveCrewPilot. -->
    <set_value name="$gt_sar_live_crew" exact="null"/>
    <do_if value="this.assignedcontrolled.roleentity? and this.assignedcontrolled.roleentity.{$gt_sar_crew_template}? and this.assignedcontrolled.roleentity.{$gt_sar_crew_template}.exists">
      <set_value name="$gt_sar_live_crew" exact="this.assignedcontrolled.roleentity.{$gt_sar_crew_template}"/>
    </do_if>
    <do_if value="not ($gt_sar_live_crew and $gt_sar_live_crew.exists) and $gt_sar_people_seed? and this.assignedcontrolled.roleentity? and this.assignedcontrolled.roleentity.{$gt_sar_people_seed}? and this.assignedcontrolled.roleentity.{$gt_sar_people_seed}.exists">
      <set_value name="$gt_sar_live_crew" exact="this.assignedcontrolled.roleentity.{$gt_sar_people_seed}"/>
    </do_if>
    <signal_objects object="player.galaxy"
                    param="'gt_sar_pilot_transferred'"
                    param2="table[
                      $StrandedPilot = $targetentity,
                      $RescueShip = this.assignedcontrolled,
                      $Spacesuit = $target,
                      $CrewTemplate = $gt_sar_crew_template,
                      $PeopleSeed = $gt_sar_people_seed,
                      $StableIdentity = $gt_sar_stable,
                      $RegistryKeyHint = $gt_sar_registry_key,
                      $LiveCrewPilot = $gt_sar_live_crew
                    ]"/>
  </replace>
</diff>
