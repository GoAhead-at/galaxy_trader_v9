<?xml version="1.0" encoding="utf-8"?>
<aiscript name="order.dock.train" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <order id="DockAndTrain" name="{77000, 10003}" description="{77000, 10103}" category="navigation" infinite="false">
    <params>
      <param name="destination" type="object" text="{1041, 10141}" comment="Training station to dock at">
        <input_param name="class" value="[class.station]"/>
      </param>
      <param name="debugchance" default="100" type="number" text="{1041, 10086}" comment="Chance to show debug output">
        <input_param name="min" value="0"/>
        <input_param name="max" value="100"/>
        <input_param name="step" value="10"/>
      </param>
    </params>
    <requires>
      <match shiptype="shiptype.lasertower" negate="true"/>
    </requires>
    <location object="$destination" condition="@$destination.exists"/>
  </order>
  
  <interrupts>
    <handler ref="TargetInvalidHandler"/>
    <handler ref="AttackHandler"/>
  </interrupts>
  
  <init>
    <set_order_syncpoint_reached order="this.ship.order"/>
    
    <!-- Validate parameters (component.{0x0L} is truthy for "not $destination" - use .exists) -->
    <do_if value="not $destination? or not $destination.exists or not this.ship.pilot">
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': ABORT: Invalid destination or no pilot'" chance="$debugchance"/>
      </do_if>
      <do_if value="this.ship.order.state == orderstate.started">
        <set_order_state order="this.ship.order" state="orderstate.critical"/>
      </do_if>
      <do_if value="this.ship.pilot">
        <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
          $Pilot = this.ship.pilot,
          $Ship = this.ship,
          $Reason = 'Invalid destination'
        ]"/>
      </do_if>
      <signal_objects object="this.ship" param="'training_aborted'" param2="'Invalid parameters'"/>
      <cancel_order order="this.ship.order"/>
      <return/>
    </do_if>
    
    <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
      <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Starting training at ' + @$destination.knownname + ' for pilot ' + this.ship.pilot.name" chance="$debugchance"/>
    </do_if>
    
    <!-- Signal MD system that training script is starting -->
    <signal_objects object="player.galaxy" param="'GT_Training_Script_Starting'" param2="table[
      $Ship = this.ship,
      $Pilot = this.ship.pilot,
      $Station = $destination
    ]"/>
    
  </init>
  
  <attention min="unknown">
    <actions>
      
      <!-- ========================================================================= -->
      <!-- HIGH-PERFORMANCE EVENT-DRIVEN TRAINING ORDER (NO POLLING)               -->
      <!-- ========================================================================= -->
      
      <do_if value="not $destination? or not $destination.exists or not this.ship.pilot">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': ABORT: Invalid destination or no pilot (attention)'" chance="$debugchance"/>
        </do_if>
        <do_if value="this.ship.order.state == orderstate.started">
          <set_order_state order="this.ship.order" state="orderstate.critical"/>
        </do_if>
        <do_if value="this.ship.pilot">
          <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
            $Pilot = this.ship.pilot,
            $Ship = this.ship,
            $Reason = 'Invalid destination'
          ]"/>
        </do_if>
        <signal_objects object="this.ship" param="'training_aborted'" param2="'Invalid parameters'"/>
        <cancel_order order="this.ship.order"/>
        <return/>
      </do_if>

      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Event-driven training started at ' + @$destination.knownname" chance="$debugchance"/>
      </do_if>
      
      <!-- Get training requirements directly from global data (instant, no signals) -->
      <set_value name="$trainingRequired" exact="false"/>
      <set_value name="$requiredLevel" exact="1"/>
      
      <do_if value="this.ship.pilot and global.$GT_Pilots.{this.ship.pilot}?">
        <do_if value="global.$GT_Pilots.{this.ship.pilot}.$XPBlocked?">
          <set_value name="$trainingRequired" exact="true"/>
          <set_value name="$requiredLevel" exact="global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel"/>
        </do_if>
        <do_elseif value="global.$GT_Pilots.{this.ship.pilot}.$TrainingState? and global.$GT_Pilots.{this.ship.pilot}.$TrainingState == 'training_in_progress'">
          <set_value name="$trainingRequired" exact="true"/>
          <do_if value="global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel? and global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel gt 0">
            <set_value name="$requiredLevel" exact="global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel"/>
          </do_if>
        </do_elseif>
        <do_elseif value="global.$GT_Pilots.{this.ship.pilot}.$AcademyEnrollment? or (global.$GT_Pilots.{this.ship.pilot}.$ManualTrainingRequested? and global.$GT_Pilots.{this.ship.pilot}.$ManualTrainingRequested)">
          <set_value name="$trainingRequired" exact="true"/>
          <do_if value="global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel? and global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel gt 0">
            <set_value name="$requiredLevel" exact="global.$GT_Pilots.{this.ship.pilot}.$BlockedLevel"/>
          </do_if>
          <do_elseif value="global.$GT_Pilots.{this.ship.pilot}.$AcademyEnrollment.$Level?">
            <set_value name="$requiredLevel" exact="global.$GT_Pilots.{this.ship.pilot}.$AcademyEnrollment.$Level"/>
          </do_elseif>
        </do_elseif>
      </do_if>
      
      <!-- Validate training requirements -->
      <do_if value="not $trainingRequired">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': No training required - completing immediately'" chance="$debugchance"/>
        </do_if>
        <signal_objects object="this.ship" param="'GT_Training_Complete'" param2="table[
          $Level = 0,
          $Station = $destination,
          $Reason = 'No training needed'
        ]"/>
        <return/>
      </do_if>
      
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training required for level ' + $requiredLevel" chance="$debugchance"/>
      </do_if>
      
      <!-- STEP 1: High-Performance Docking (VALIDATED AGAINST WORKING REFERENCE) -->
      <do_if value="(this.ship.dock and (this.ship.dock.container == $destination)) or (this.ship.parkedat and ((this.ship.parkedat == $destination) or this.ship.parkedat.hascontext.{$destination}))">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Already docked at ' + @$destination.knownname + ' - proceeding directly to training'" chance="$debugchance"/>
        </do_if>
      </do_if>
      <do_else>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Not docked at target (dock: ' + @this.ship.dock + ', parked: ' + @this.ship.parkedat + ', target: ' + $destination + ') - initiating dock sequence'" chance="$debugchance"/>
        </do_if>
        
        <!-- Event-driven docking (no polling wait) -->
        <!-- Only pass debugchance > 0 if GT debug logging is enabled globally -->
        <set_value name="$dockDebugChance" exact="0"/>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <set_value name="$dockDebugChance" exact="$debugchance"/>
        </do_if>
        <!-- Parent DockAndTrain pauses while DockAndWait runs; flag handoff so on_abort does not treat this as failure. -->
        <set_value name="this.$trainingDockHandoff" exact="true"/>
        <create_order name="$trainingDockOrder" id="'DockAndWait'" object="this.ship" immediate="true">
          <param name="destination" value="$destination"/>
          <param name="building" value="false"/>
          <param name="trading" value="false"/>
          <param name="dockfollowers" value="$destination.isclass.station"/>
          <param name="callerid" value="this.ship.order"/>
          <param name="debugchance" value="$dockDebugChance"/>
        </create_order>
        
        <!-- Event-driven wait for docking completion -->
        <wait>
          <interrupt>
            <conditions>
              <event_object_order_ready object="this.ship" order="$trainingDockOrder"/>
            </conditions>
          </interrupt>
        </wait>
        
        <remove_value name="this.$trainingDockHandoff"/>
        <remove_value name="this.$trainingDockOrder"/>
        
        <!-- Validate docking success (VALIDATED AGAINST WORKING REFERENCE) -->
        <do_if value="not ((this.ship.dock and (this.ship.dock.container == $destination)) or (this.ship.parkedat and ((this.ship.parkedat == $destination) or this.ship.parkedat.hascontext.{$destination})))">
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT-Training] ' + this.ship.idcode + ': CRITICAL: Docking failed (dock: ' + @this.ship.dock + ', parked: ' + @this.ship.parkedat + ', target: ' + $destination + ') - aborting training'" chance="$debugchance"/>
          </do_if>
          
          <!-- Notify MD system: Training failed -->
          <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
            $Pilot = this.ship.pilot,
            $Ship = this.ship,
            $Reason = 'Docking failed'
          ]"/>
          
          <signal_objects object="this.ship" param="'GT_Training_Failed'" param2="table[
            $Reason = 'Docking failed',
            $Station = $destination
          ]"/>
          <cancel_order order="this.ship.order"/>
          <return/>
        </do_if>
        
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Docking successful - training can proceed'" chance="$debugchance"/>
        </do_if>
      </do_else>
      
      <!-- STEP 2: Commit training at dock (payment + duration live in MD).
           GT_Start_Training MUST fire only after a successful dock so academy
           fees are not debited while the ship is still in transit. -->
      <signal_objects object="player.galaxy" param="'GT_Start_Training'" param2="table[
        $Ship = this.ship,
        $Pilot = this.ship.pilot,
        $TrainingLevel = $requiredLevel,
        $TrainingStation = $destination
      ]"/>
      <!-- Yield so HandleStartTraining commits payment + $TrainingDuration
           before this script reads registry timer fields (signal_objects is
           queued across AI/MD boundaries). -->
      <wait exact="1ms"/>
      
      <!-- Send immersive training message to logbook - only if enabled -->
      <do_if value="@this.ship.commander.defaultorder.$logbookentries or @this.ship.defaultorder.$logbookentries">
        <set_value name="$actualDuration" exact="@global.$GT_Pilots.{this.ship.pilot}.$TrainingDuration"/>
        
        <signal_objects object="player.galaxy" param="'GT_TradeLogging_LogTrainingStarted'" param2="table[
          $Ship = this.ship,
          $Pilot = this.ship.pilot,
          $Station = $destination,
          $TrainingLevel = $requiredLevel,
          $Duration = $actualDuration
        ]"/>
      </do_if>
      
       <!-- STEP 3: Training Simulation - Get duration calculated by MD script (PRODUCTION MODE) -->
       <set_value name="$trainingDuration" exact="@global.$GT_Pilots.{this.ship.pilot}.$TrainingDuration"/>
       
       <!-- Fallback to 10 minutes if duration not set (should never happen) -->
       <do_if value="not $trainingDuration?">
         <set_value name="$trainingDuration" exact="600s"/>
         <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
           <debug_text text="'[GT-Training] ' + this.ship.idcode + ': WARNING - Training duration not set, using fallback 10 minutes'" chance="100"/>
         </do_if>
       </do_if>
       
       <!-- CRITICAL FIX: Ensure duration is a time value, not an integer -->
       <!-- Match against datatype.time (vanilla pattern) so values arriving
            as long-fixed / float (e.g. via the Lua-written academy
            blackboard) are promoted too, not only literal integers. -->
       <do_if value="$trainingDuration and typeof $trainingDuration != datatype.time">
         <set_value name="$trainingDuration" exact="$trainingDuration * 1s"/>
         <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
           <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Converted integer duration to time: ' + ($trainingDuration / 1s) + 's'" chance="100"/>
         </do_if>
       </do_if>
       <!-- Rebuild a fresh local time literal for <wait>. Registry reads can
            keep datatype.time while still using the engine's 1/12-second raw
            unit count; (x / 1s) * 1s normalizes to whole seconds (e.g. 600s
            was completing in ~50s game time when passed straight to wait max). -->
       <set_value name="$trainingWaitTime" exact="($trainingDuration / 1s) * 1s"/>
       
       <!-- Save/load: continue from remaining course time when the timer was
            already started before the save (HandleStartTraining stamps both).
            Ignore the stub stamp HandleStartTraining sets in the same frame as
            a fresh dock commit (elapsed le 1s). -->
       <set_value name="$skipTrainingWait" exact="false"/>
       <do_if value="global.$GT_Pilots.{this.ship.pilot}.$TrainingStarted?">
         <set_value name="$elapsedTraining" exact="player.age - global.$GT_Pilots.{this.ship.pilot}.$TrainingStarted"/>
         <do_if value="$elapsedTraining gt 1s">
           <set_value name="$remainingTraining" exact="$trainingWaitTime - $elapsedTraining"/>
           <do_if value="$remainingTraining le 0s">
             <set_value name="$skipTrainingWait" exact="true"/>
             <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
               <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training timer expired during save/load - completing immediately'" chance="100"/>
             </do_if>
           </do_if>
           <do_else>
             <set_value name="$trainingWaitTime" exact="($remainingTraining / 1s) * 1s"/>
             <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
               <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Resuming training with ' + ($trainingWaitTime / 1s) + 's remaining'" chance="100"/>
             </do_if>
           </do_else>
         </do_if>
       </do_if>
       
       <set_value name="this.$trainingEndsAt" exact="player.age + $trainingWaitTime"/>
       
       <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
         <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Level ' + $requiredLevel + ' training duration: ' + ($trainingWaitTime / 1s) + 's (ends at ' + this.$trainingEndsAt + ')'" chance="$debugchance"/>
       </do_if>
      
       <!-- Event-driven training wait (no polling) -->
       <!-- min=max keeps the full course length while still allowing the
            GT_Abort_Training interrupt to fire immediately (vanilla/GT pattern). -->
       <do_if value="not $skipTrainingWait">
       <wait min="$trainingWaitTime" max="$trainingWaitTime">
         <interrupt>
           <conditions>
             <event_object_signalled object="this.ship" param="'GT_Abort_Training'"/>
           </conditions>
           <actions>
             <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
               <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training interrupted by abort signal'" chance="$debugchance"/>
             </do_if>
      
             <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
               $Pilot = this.ship.pilot,
               $Ship = this.ship,
               $Reason = 'Training interrupted'
             ]"/>
             
             <signal_objects object="this.ship" param="'GT_Training_Failed'" param2="table[
               $Reason = 'Training interrupted',
               $Station = $destination
             ]"/>
             <return/>
           </actions>
         </interrupt>
       </wait>
       </do_if>
       
       <!-- STEP 4: Complete Training -->
       <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
         <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training completed - processing results'" chance="$debugchance"/>
       </do_if>
      
       <!-- Notify MD system: Training completed -->
      <signal_objects object="player.galaxy" param="'GT_Complete_Training'" param2="table[
        $Pilot = this.ship.pilot,
        $Ship = this.ship,
         $Level = $requiredLevel
      ]"/>
      
       <!-- Send training completion message to logbook - only if enabled -->
       <do_if value="@this.ship.commander.defaultorder.$logbookentries or @this.ship.defaultorder.$logbookentries">
         <signal_objects object="player.galaxy" param="'GT_TradeLogging_LogTrainingCompleted'" param2="table[
           $Ship = this.ship,
           $Pilot = this.ship.pilot,
           $Level = $requiredLevel
         ]"/>
       </do_if>
      
      <!-- STEP 5: Event-Driven Undocking -->
      <do_if value="@this.ship.dockingbay.container">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Initiating undock sequence'" chance="$debugchance"/>
        </do_if>
        
        <create_order object="this.ship" id="'Undock'" immediate="true"/>
        
        <!-- Event-driven undocking wait -->
        <wait>
          <interrupt>
            <conditions>
              <event_object_order_ready object="this.ship"/>
            </conditions>
          </interrupt>
        </wait>
        
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Undocking completed'" chance="$debugchance"/>
        </do_if>
      </do_if>
      
      <!-- STEP 6: Signal Completion -->
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training sequence completed successfully for level ' + $requiredLevel" chance="$debugchance"/>
      </do_if>
      
      <signal_objects object="this.ship" param="'GT_Training_Complete'" param2="table[
        $Level = $requiredLevel,
        $Station = $destination,
        $Duration = $trainingWaitTime
      ]"/>
      
    </actions>
  </attention>
  
  <on_abort>
    <!-- DockAndWait child pauses this script while the ship flies to the station.
         That engine pause fires on_abort; it is NOT a player cancel or failure. -->
    <set_value name="$isDockTransitHandoff" exact="false"/>
    <do_if value="this.$trainingDockOrder? and this.$trainingDockOrder.exists">
      <set_value name="$isDockTransitHandoff" exact="true"/>
    </do_if>
    <do_if value="not $isDockTransitHandoff and this.ship.order? and @this.ship.order.id == 'DockAndWait' and this.ship.order.$callerid? and @this.ship.order.$callerid.id == 'DockAndTrain'">
      <set_value name="$isDockTransitHandoff" exact="true"/>
    </do_if>
    <do_if value="not $isDockTransitHandoff and this.ship.orders? and this.ship.orders.count gt 0">
      <do_all exact="this.ship.orders.count" counter="$toai">
        <set_value name="$toOrder" exact="this.ship.orders.{$toai}"/>
        <do_if value="@$toOrder.id == 'DockAndWait' and $toOrder.$callerid? and @$toOrder.$callerid.id == 'DockAndTrain'">
          <set_value name="$isDockTransitHandoff" exact="true"/>
          <break/>
        </do_if>
      </do_all>
    </do_if>
    <do_if value="$isDockTransitHandoff">
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': on_abort skipped (DockAndWait transit handoff - training still in progress)'" chance="$debugchance"/>
      </do_if>
      <return/>
    </do_if>
    
    <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
      <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training order cancelled'" chance="$debugchance"/>
    </do_if>
    
    <!-- CRITICAL: Check if GT order is still active before sending signals -->
    <!-- Training order can abort normally (completion) - only send signals if GT order is still active -->
    <set_value name="$trainAbortDefaultOrder" exact="null"/>
    <do_if value="this.ship.defaultorder?">
      <set_value name="$trainAbortDefaultOrder" exact="@this.ship.defaultorder.id"/>
    </do_if>
    <set_value name="$hasDirectGTOrder" exact="false"/>
    <set_value name="$hasGTCommander" exact="false"/>
    <do_if value="$trainAbortDefaultOrder? and global.$GT_ProtectedOrderIDs? and global.$GT_ProtectedOrderIDs.indexof.{$trainAbortDefaultOrder}">
      <set_value name="$hasDirectGTOrder" exact="true"/>
    </do_if>
    <do_elseif value="$trainAbortDefaultOrder == 'Assist' and this.ship.defaultorder? and this.ship.defaultorder.$baseorder? and global.$GT_ProtectedOrderIDs? and global.$GT_ProtectedOrderIDs.indexof.{@this.ship.defaultorder.$baseorder.id}">
      <set_value name="$hasDirectGTOrder" exact="true"/>
    </do_elseif>
    <do_if value="not $hasDirectGTOrder and this.ship.commander? and this.ship.commander.exists and this.ship.commander != this.ship and this.ship.commander.defaultorder? and global.$GT_ProtectedOrderIDs? and global.$GT_ProtectedOrderIDs.indexof.{@this.ship.commander.defaultorder.id}">
      <set_value name="$hasGTCommander" exact="true"/>
    </do_if>
    <do_elseif value="not $hasDirectGTOrder and this.ship.commander? and this.ship.commander.exists and this.ship.commander != this.ship and this.ship.commander.defaultorder? and @this.ship.commander.defaultorder.id == 'Assist' and this.ship.commander.defaultorder.$baseorder? and global.$GT_ProtectedOrderIDs? and global.$GT_ProtectedOrderIDs.indexof.{@this.ship.commander.defaultorder.$baseorder.id}">
      <set_value name="$hasGTCommander" exact="true"/>
    </do_elseif>
    
    <!-- Only send signals if GT order is still active (direct or via commander) -->
    <do_if value="$hasDirectGTOrder or $hasGTCommander">
      <!-- Notify MD system about training abortion -->
      <signal_objects object="player.galaxy" param="'GT_Abort_Training'" param2="table[
        $Pilot = this.ship.pilot,
        $Ship = this.ship,
        $Reason = 'Training order cancelled'
      ]"/>
      
      <!-- Signal abortion to main trading script -->
      <signal_objects object="this.ship" param="'training_aborted'" param2="'Training order cancelled'"/>
    </do_if>
    <do_else>
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-Training] ' + this.ship.idcode + ': Training order aborted but GT order no longer active - skipping signals'" chance="$debugchance"/>
      </do_if>
    </do_else>
  </on_abort>
  
</aiscript> 