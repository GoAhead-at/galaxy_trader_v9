<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.miner_same_fleet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Non-blocking interrupt library: sets $fleetMatch (bool) from caller-scoped $shipA and $shipB.
    Named X4 fleet first; unfleeted Assist subordinates fall back to the same direct commander.
    Solo miners (no fleet name, no commander) only match themselves.
    Must not have blocking actions — use include_interrupt_actions instead of run_script in loops.
  -->
  <interrupts>
    <library>
      <actions name="MinerSameFleetMatch">
        <set_value name="$fleetMatch" exact="false"/>
        <do_if value="not $shipA? or not $shipA.exists or not $shipB? or not $shipB.exists">
          <return/>
        </do_if>
        <do_if value="$shipA == $shipB">
          <set_value name="$fleetMatch" exact="true"/>
          <return/>
        </do_if>
        <set_value name="$fleetKeyA" exact="null"/>
        <set_value name="$fleetKeyB" exact="null"/>
        <do_if value="$shipA.fleet? and $shipA.fleet.commander? and $shipA.fleet.commander.fleet? and $shipA.fleet.commander.fleet.name? and $shipA.fleet.commander.fleet.name != ''">
          <set_value name="$fleetKeyA" exact="$shipA.fleet.commander.fleet.name"/>
        </do_if>
        <do_elseif value="$shipA.fleet? and $shipA.fleet.name? and $shipA.fleet.name != ''">
          <set_value name="$fleetKeyA" exact="$shipA.fleet.name"/>
        </do_elseif>
        <do_elseif value="$shipA.commander? and $shipA.commander.exists and $shipA.commander != $shipA">
          <set_value name="$fleetKeyA" exact="$shipA.commander"/>
        </do_elseif>
        <do_if value="$shipB.fleet? and $shipB.fleet.commander? and $shipB.fleet.commander.fleet? and $shipB.fleet.commander.fleet.name? and $shipB.fleet.commander.fleet.name != ''">
          <set_value name="$fleetKeyB" exact="$shipB.fleet.commander.fleet.name"/>
        </do_if>
        <do_elseif value="$shipB.fleet? and $shipB.fleet.name? and $shipB.fleet.name != ''">
          <set_value name="$fleetKeyB" exact="$shipB.fleet.name"/>
        </do_elseif>
        <do_elseif value="$shipB.commander? and $shipB.commander.exists and $shipB.commander != $shipB">
          <set_value name="$fleetKeyB" exact="$shipB.commander"/>
        </do_elseif>
        <do_if value="$fleetKeyA? and $fleetKeyB? and $fleetKeyA == $fleetKeyB">
          <set_value name="$fleetMatch" exact="true"/>
        </do_if>
        <remove_value name="$fleetKeyA"/>
        <remove_value name="$fleetKeyB"/>
      </actions>
    </library>
  </interrupts>
</aiscript>
