<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.offer.filters — shared per-offer validation used by MK3 live/cached workers.
     NOTE: Explicitly selected warebasket wares are always allowed, including illegal wares
     when allowIllegal is false (player intent override). -->
<aiscript name="lib.gt.offer.filters" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="offer" default="null"/>
    <param name="wareBasket" default="[]"/>
    <param name="allowIllegal" default="false"/>
    <param name="ignoreBuildStorage" default="false"/>
    <param name="ignoreCarrierAux" default="false"/>
    <param name="ignoreMK1Supply" default="false"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$pass" exact="true"/>
      <set_value name="$reason" exact="'ok'"/>
      <set_value name="$wareMatch" exact="false"/>
      <set_value name="$hasExplicitBasket" exact="false"/>

      <do_if value="not $offer? or not $offer.exists or not $offer.ware?">
        <set_value name="$pass" exact="false"/>
        <set_value name="$reason" exact="'invalid_offer'"/>
      </do_if>

      <!-- Ware basket gate (if configured). -->
      <do_if value="$pass and $wareBasket? and $wareBasket.count gt 0">
        <set_value name="$hasExplicitBasket" exact="true"/>
        <set_value name="$wareMatch" exact="false"/>
        <do_all exact="$wareBasket.count" counter="$wi">
          <do_if value="$wareBasket.{$wi} == $offer.ware">
            <set_value name="$wareMatch" exact="true"/>
            <break/>
          </do_if>
        </do_all>
        <do_if value="not $wareMatch">
          <set_value name="$pass" exact="false"/>
          <set_value name="$reason" exact="'warebasket'"/>
        </do_if>
      </do_if>

      <!-- Illegal gate. Explicit warebasket match overrides allowIllegal=false. -->
      <do_if value="$pass and not $allowIllegal and not ($hasExplicitBasket and $wareMatch)">
        <do_if value="$offer.ware != null and @$offer.ware.illegal gt 0">
          <set_value name="$pass" exact="false"/>
          <set_value name="$reason" exact="'illegal'"/>
        </do_if>
      </do_if>

      <set_value name="$station" exact="null"/>
      <do_if value="$offer.owner?">
        <set_value name="$station" exact="$offer.owner"/>
      </do_if>

      <!-- Build storage / carrier-aux station type gates. -->
      <do_if value="$pass and $station? and $ignoreBuildStorage and $station.isbuildstorage">
        <set_value name="$pass" exact="false"/>
        <set_value name="$reason" exact="'buildstorage'"/>
      </do_if>

      <do_if value="$pass and $station? and $ignoreCarrierAux">
        <do_if value="$station.isclass.ship and ($station.type == shiptype.carrier or $station.type == shiptype.resupplier)">
          <set_value name="$pass" exact="false"/>
          <set_value name="$reason" exact="'carrier_aux'"/>
        </do_if>
      </do_if>

      <!-- MK1-supplied station gate. -->
      <do_if value="$pass and $station? and $ignoreMK1Supply and global.$GT_MK1SuppliedStations? and global.$GT_MK1SuppliedStations.{$station}?">
        <set_value name="$pass" exact="false"/>
        <set_value name="$reason" exact="'mk1_supply'"/>
      </do_if>

      <return value="table[$Pass = $pass, $Reason = $reason, $WareMatch = $wareMatch]"/>
    </actions>
  </attention>
</aiscript>
