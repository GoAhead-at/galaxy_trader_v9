<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GLX_Lib_Orders" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../ORIGINAL_MODS_DO NOT_MODIFY/X4 Foundations/libraries/md.xsd">
  <cues>
    <!-- Centralized checks against global.$GT_ProtectedOrderIDs (see gt_core_system.xml). -->
    <!-- Use md.GLX_Lib_Orders.GLX_ShipIsInGTService from run_actions, or inline indexof in hot do_if conditions. -->

    <!-- True if ship's default order is a protected GT id, OR Assist under a GT commander. -->
    <library name="GLX_ShipIsInGTService" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to test"/>
      </params>
      <actions>
        <do_if value="$ship? and $ship.exists and global.$GT_ProtectedOrderIDs? and $ship.defaultorder? and global.$GT_ProtectedOrderIDs.indexof.{@$ship.defaultorder.id}">
          <return value="true"/>
        </do_if>
        <do_if value="$ship? and $ship.exists and $ship.defaultorder? and @$ship.defaultorder.id == 'Assist' and $ship.commander? and $ship.commander.exists and $ship.commander.defaultorder? and global.$GT_ProtectedOrderIDs? and global.$GT_ProtectedOrderIDs.indexof.{@$ship.commander.defaultorder.id}">
          <return value="true"/>
        </do_if>
        <return value="false"/>
      </actions>
    </library>
  </cues>
</mdscript>
