<?xml version="1.0" encoding="utf-8"?>
<!-- MK4-2 supply scoring: MK4-Spec urgency × ship-agnostic amount ÷ route distance; class slider + ware bonus (§3–4). -->
<aiscript name="lib.gt.mk42.score.trades" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="priorities" default="table[]" comment="table[$Buildstorage, $Stations, $Aux, $Carrier]"/>
    <param name="priorityWares" default="[]"/>
    <param name="priorityScoreMultiplier" default="1" comment="1=no ware bonus; 2-10 additive on baseSupplyScore"/>
    <param name="distancePenalty" default="0.5" comment="Runtime multiplier (UI 0-100% converted by caller)"/>
    <param name="diversifyByWare" default="false"/>
    <param name="priorityFirstInDiversify" default="false"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bestTrade" exact="null"/>
      <set_value name="$bestScore" exact="0"/>
      <create_list name="$sortedTrades"/>
      <set_value name="$safePriorityWares" exact="if $priorityWares? and $priorityWares != null then $priorityWares else []"/>
      <set_value name="$wareMult" exact="if $priorityScoreMultiplier? then $priorityScoreMultiplier else 1"/>
      <do_if value="$wareMult lt 1"><set_value name="$wareMult" exact="1"/></do_if>
      <do_if value="$wareMult gt 10"><set_value name="$wareMult" exact="10"/></do_if>

      <do_if value="not $tradeList? or $tradeList.count == 0">
        <wait exact="1ms"/>
        <return value="table[$Found = false, $BestTrade = null, $BestScore = 0, $SortedTrades = $sortedTrades]"/>
      </do_if>

      <do_all exact="$tradeList.count" counter="$i">
        <set_value name="$trade" exact="$tradeList.{$i}"/>
        <set_value name="$baseSupplyScore" exact="if $trade.$baseSupplyScore? then $trade.$baseSupplyScore else (if $trade.$Score? then $trade.$Score else 0)"/>
        <set_value name="$classMult" exact="if $trade.$ClassMultiplier? then $trade.$ClassMultiplier else 1"/>
        <do_if value="$classMult le 0">
          <continue/>
        </do_if>
        <set_value name="$typeScore" exact="$baseSupplyScore * $classMult"/>
        <set_value name="$wareBonus" exact="0"/>
        <do_if value="$wareMult gt 1 and $trade.$Ware? and $safePriorityWares.count gt 0">
          <do_all exact="$safePriorityWares.count" counter="$pw">
            <do_if value="$safePriorityWares.{$pw} == $trade.$Ware">
              <set_value name="$wareBonus" exact="$baseSupplyScore * ($wareMult - 1)"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>
        <set_value name="$finalScore" exact="$typeScore + $wareBonus"/>
        <set_value name="$trade.$baseSupplyScore" exact="$baseSupplyScore"/>
        <set_value name="$trade.$finalScore" exact="$finalScore"/>
        <set_value name="$trade.$Score" exact="$finalScore"/>
        <append_to_list name="$sortedTrades" exact="$trade"/>
        <do_if value="$finalScore gt $bestScore">
          <set_value name="$bestScore" exact="$finalScore"/>
          <set_value name="$bestTrade" exact="$trade"/>
        </do_if>
      </do_all>

      <sort_list list="$sortedTrades" sortbyvalue="loop.element.$Score" sortdescending="true"/>

      <do_if value="$diversifyByWare and $sortedTrades.count gt 1">
        <create_list name="$diversifiedTrades"/>
        <set_value name="$diversifyPicked" exact="table[]"/>
        <set_value name="$usePriorityFirst" exact="$priorityFirstInDiversify and $safePriorityWares.count gt 0"/>
        <do_while value="$diversifiedTrades.count lt $sortedTrades.count">
          <set_value name="$diversifyRoundServed" exact="table[]"/>
          <set_value name="$diversifyRoundAdded" exact="0"/>
          <do_if value="$usePriorityFirst">
            <do_all exact="$safePriorityWares.count" counter="$dpp">
              <set_value name="$dpw" exact="$safePriorityWares.{$dpp}"/>
              <do_if value="not $dpw? or $dpw == null or $diversifyRoundServed.{$dpw}?">
                <continue/>
              </do_if>
              <do_all exact="$sortedTrades.count" counter="$dpwi">
                <do_if value="not $diversifyPicked.{$dpwi}? and $sortedTrades.{$dpwi}.$Ware? and $sortedTrades.{$dpwi}.$Ware == $dpw">
                  <append_to_list name="$diversifiedTrades" exact="$sortedTrades.{$dpwi}"/>
                  <set_value name="$diversifyPicked.{$dpwi}" exact="true"/>
                  <set_value name="$diversifyRoundServed.{$dpw}" exact="true"/>
                  <set_value name="$diversifyRoundAdded" operation="add"/>
                  <break/>
                </do_if>
              </do_all>
            </do_all>
          </do_if>
          <do_all exact="$sortedTrades.count" counter="$dwi">
            <do_if value="not $diversifyPicked.{$dwi}?">
              <set_value name="$dwTrade" exact="$sortedTrades.{$dwi}"/>
              <set_value name="$dwWare" exact="if $dwTrade.$Ware? then $dwTrade.$Ware else null"/>
              <do_if value="$dwWare? and not $diversifyRoundServed.{$dwWare}?">
                <append_to_list name="$diversifiedTrades" exact="$dwTrade"/>
                <set_value name="$diversifyPicked.{$dwi}" exact="true"/>
                <set_value name="$diversifyRoundServed.{$dwWare}" exact="true"/>
                <set_value name="$diversifyRoundAdded" operation="add"/>
              </do_if>
            </do_if>
          </do_all>
          <do_if value="$diversifyRoundAdded == 0">
            <break/>
          </do_if>
        </do_while>
        <do_all exact="$sortedTrades.count" counter="$dwt">
          <do_if value="not $diversifyPicked.{$dwt}?">
            <append_to_list name="$diversifiedTrades" exact="$sortedTrades.{$dwt}"/>
          </do_if>
        </do_all>
        <set_value name="$sortedTrades" exact="$diversifiedTrades"/>
        <set_value name="$bestTrade" exact="if $sortedTrades.count gt 0 then $sortedTrades.{1} else null"/>
        <set_value name="$bestScore" exact="if $bestTrade? and $bestTrade.$Score? then $bestTrade.$Score else 0"/>
      </do_if>

      <wait exact="1ms"/>
      <return value="table[$Found = ($bestTrade != null), $BestTrade = $bestTrade, $BestScore = $bestScore, $SortedTrades = $sortedTrades]"/>
    </actions>
  </attention>
</aiscript>
