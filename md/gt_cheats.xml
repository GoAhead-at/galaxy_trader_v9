<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_Cheats" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <cues>

    <library name="GT_Cheat_GetScope" purpose="run_actions">
      <actions>
        <set_value name="$scope" exact="'off'"/>
        <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Cheats? and global.$GT_GlobalSettings.$Cheats.$InvulnerabilityScope?">
          <set_value name="$scope" exact="global.$GT_GlobalSettings.$Cheats.$InvulnerabilityScope"/>
        </do_if>
        <do_if value="$scope != 'off' and $scope != 'gt' and $scope != 'all'">
          <set_value name="$scope" exact="'off'"/>
        </do_if>
        <return value="$scope"/>
      </actions>
    </library>

    <library name="GT_Cheat_ApplyShip" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to protect"/>
      </params>
      <actions>
        <do_if value="$ship? and $ship.exists and $ship.isclass.{class.ship}">
          <set_object_min_hull object="$ship" exact="100"/>
          <set_object_min_shield object="$ship" exact="100"/>
        </do_if>
      </actions>
    </library>

    <library name="GT_Cheat_ClearShip" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to restore normal damage rules"/>
      </params>
      <actions>
        <do_if value="$ship? and $ship.exists and $ship.isclass.{class.ship}">
          <set_object_min_hull object="$ship" exact="0"/>
          <set_object_min_shield object="$ship" exact="0"/>
        </do_if>
      </actions>
    </library>

    <cue name="Init" instantiate="true" version="1">
      <conditions>
        <check_any>
          <event_game_loaded/>
          <event_player_created/>
        </check_any>
      </conditions>
      <actions>
        <do_if value="not global.$GT_CheatProtectedShips?">
          <set_value name="global.$GT_CheatProtectedShips" exact="[]"/>
        </do_if>
        <signal_cue_instantly cue="GT_Cheat_Reconcile"/>
      </actions>
    </cue>

    <cue name="PeriodicRefresh" instantiate="true" checktime="player.age + 5s" checkinterval="60s">
      <actions>
        <run_actions ref="GT_Cheat_GetScope" result="$scope"/>
        <do_if value="$scope != 'off'">
          <signal_cue_instantly cue="GT_Cheat_Reconcile"/>
        </do_if>
      </actions>
    </cue>

    <cue name="GT_Cheat_Reconcile" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <run_actions ref="GT_Cheat_GetScope" result="$scope"/>
        <do_if value="not global.$GT_CheatProtectedShips?">
          <set_value name="global.$GT_CheatProtectedShips" exact="[]"/>
        </do_if>

        <set_value name="$targetTable" exact="table[]"/>

        <do_if value="$scope == 'gt'">
          <do_if value="global.$GT_Ships?">
            <set_value name="$shipKeys" exact="global.$GT_Ships.keys.list"/>
            <do_all exact="$shipKeys.count" counter="$sk">
              <set_value name="$ship" exact="$shipKeys.{$sk}"/>
              <do_if value="$ship? and $ship.exists and $ship.isclass.{class.ship}">
                <run_actions ref="md.GLX_Lib_Orders.GLX_ShipIsInGTService" result="$isGTService">
                  <param name="ship" value="$ship"/>
                </run_actions>
                <do_if value="$isGTService">
                  <set_value name="$targetTable.{$ship}" exact="true"/>
                </do_if>
              </do_if>
            </do_all>
          </do_if>
        </do_if>
        <do_elseif value="$scope == 'all'">
          <find_ship_by_true_owner name="$allShips" faction="faction.player" space="player.galaxy" multiple="true" unit="false"/>
          <do_all exact="$allShips.count" counter="$as">
            <set_value name="$ship" exact="$allShips.{$as}"/>
            <do_if value="$ship? and $ship.exists and $ship.isclass.{class.ship}">
              <set_value name="$targetTable.{$ship}" exact="true"/>
            </do_if>
          </do_all>
        </do_elseif>

        <set_value name="$newProtected" exact="[]"/>
        <do_all exact="global.$GT_CheatProtectedShips.count" counter="$pi">
          <set_value name="$ship" exact="global.$GT_CheatProtectedShips.{$pi}"/>
          <do_if value="$ship? and $ship.exists">
            <do_if value="$scope == 'off' or not $targetTable.{$ship}?">
              <run_actions ref="GT_Cheat_ClearShip">
                <param name="ship" value="$ship"/>
              </run_actions>
            </do_if>
            <do_else>
              <append_to_list name="$newProtected" exact="$ship"/>
            </do_else>
          </do_if>
        </do_all>

        <set_value name="$targetKeys" exact="$targetTable.keys.list"/>
        <do_all exact="$targetKeys.count" counter="$ti">
          <set_value name="$ship" exact="$targetKeys.{$ti}"/>
          <do_if value="$ship? and $ship.exists">
            <set_value name="$alreadyListed" exact="false"/>
            <do_all exact="$newProtected.count" counter="$np">
              <do_if value="$newProtected.{$np} == $ship">
                <set_value name="$alreadyListed" exact="true"/>
              </do_if>
            </do_all>
            <run_actions ref="GT_Cheat_ApplyShip">
              <param name="ship" value="$ship"/>
            </run_actions>
            <do_if value="not $alreadyListed">
              <append_to_list name="$newProtected" exact="$ship"/>
            </do_if>
          </do_if>
        </do_all>

        <set_value name="global.$GT_CheatProtectedShips" exact="$newProtected"/>

        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Cheats] Reconcile scope=' + $scope + ' protected=' + global.$GT_CheatProtectedShips.count" chance="100"/>
        </do_if>
      </actions>
    </cue>

    <!-- One-shot: reveal fog of war, stations, and faction trade subscriptions (vanilla Test_Trade pattern). -->
    <cue name="GT_Cheat_RevealUniverse" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not global.$GT_GlobalSettings.$Cheats?">
          <set_value name="global.$GT_GlobalSettings.$Cheats" exact="table[]"/>
        </do_if>

        <do_for_each name="$faction" in="lookup.faction.list">
          <!-- Visitor factions have no md.$FactionData entry; relation bumps trigger vanilla PromotionInstant errors. -->
          <do_if value="$faction.isactive and $faction != faction.player and $faction != faction.ownerless and not $faction.isvisitor and md.$FactionData.{$faction}?">
            <set_faction_known faction="$faction" known="true"/>
            <do_if value="@$faction.relationto.{faction.player} lt 0.32">
              <set_faction_relation faction="$faction" otherfaction="faction.player" value="0.32"/>
            </do_if>
            <do_all exact="$faction.licences.count" counter="$li">
              <set_value name="$licence" exact="$faction.licences.{$li}"/>
              <do_if value="$licence.type == 'tradesubscription' and not faction.player.haslicence.{$licence}">
                <add_licence licence="$licence"/>
              </do_if>
            </do_all>
          </do_if>
        </do_for_each>

        <find_cluster name="$clusters" multiple="true"/>
        <do_all exact="$clusters.count" counter="$ci">
          <set_value name="$cluster" exact="$clusters.{$ci}"/>
          <set_known object="$cluster" known="true"/>
          <find_sector name="$sectors" space="$cluster" multiple="true"/>
          <do_all exact="$sectors.count" counter="$si">
            <set_value name="$sector" exact="$sectors.{$si}"/>
            <set_known object="$sector" known="true"/>
            <clear_fog_of_war sector="$sector" range="2500km">
              <position x="0" y="0" z="0"/>
            </clear_fog_of_war>
            <find_object name="$gates" class="class.gate" space="$sector" multiple="true"/>
            <do_for_each name="$gate" in="$gates">
              <set_known object="$gate" known="true"/>
            </do_for_each>
            <find_station name="$stations" space="$sector" multiple="true"/>
            <do_all exact="$stations.count" counter="$sti">
              <set_value name="$station" exact="$stations.{$sti}"/>
              <set_known object="$station" known="true" updatesnapshot="true"/>
              <do_if value="not @$station.haspermanenttradesubscription">
                <add_trade_subscription object="$station"/>
              </do_if>
            </do_all>
          </do_all>
        </do_all>

        <set_value name="global.$GT_GlobalSettings.$Cheats.$UniverseRevealed" exact="true"/>

        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Cheats] Universe reveal applied (' + $clusters.count + ' clusters)'" chance="100"/>
        </do_if>
      </actions>
    </cue>

    <!-- One-shot: max XP and level 15 for every registered GT pilot (no training). -->
    <cue name="GT_Cheat_MaxPilotXP" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not global.$GT_GlobalSettings.$Cheats?">
          <set_value name="global.$GT_GlobalSettings.$Cheats" exact="table[]"/>
        </do_if>

        <set_value name="$useVanillaXPOnly" exact="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly"/>
        <set_value name="$maxLevel" exact="15"/>
        <set_value name="$maxXP" exact="6000"/>
        <do_if value="global.$GT_Config? and global.$GT_Config.$XP? and global.$GT_Config.$XP.$SkillThresholds? and global.$GT_Config.$XP.$SkillThresholds.{$maxLevel}?">
          <set_value name="$maxXP" exact="global.$GT_Config.$XP.$SkillThresholds.{$maxLevel}"/>
        </do_if>

        <set_value name="$processed" exact="0"/>
        <do_if value="not $useVanillaXPOnly and global.$GT_Pilots? and global.$GT_Pilots.keys.count gt 0">
          <do_all exact="global.$GT_Pilots.keys.count" counter="$pi">
            <set_value name="$pilot" exact="global.$GT_Pilots.keys.{$pi}"/>
            <do_if value="$pilot? and $pilot.exists and global.$GT_Pilots.{$pilot}?">
              <set_value name="global.$GT_Pilots.{$pilot}.$XP" exact="$maxXP"/>
              <set_value name="global.$GT_Pilots.{$pilot}.$Level" exact="$maxLevel"/>

              <set_value name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="[]"/>
              <do_if value="global.$GT_Config? and global.$GT_Config.$Training? and global.$GT_Config.$Training.$RequiredLevels?">
                <do_for_each name="$reqLevel" in="global.$GT_Config.$Training.$RequiredLevels">
                  <append_to_list name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="$reqLevel"/>
                </do_for_each>
              </do_if>
              <do_else>
                <append_to_list name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="3"/>
                <append_to_list name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="6"/>
                <append_to_list name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="9"/>
                <append_to_list name="global.$GT_Pilots.{$pilot}.$TrainingCompleted" exact="12"/>
              </do_else>

              <run_actions ref="md.GT_Libraries_General.GT_ClearTrainingBlocked">
                <param name="pilot" value="$pilot"/>
              </run_actions>
              <remove_value name="global.$GT_Pilots.{$pilot}.$BlockedXPPending"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$PendingSkillLevel"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$TrainingStarted"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$TrainingDuration"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$TrainingStation"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$ManualTrainingRequested"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$NextTrainingRetryAt"/>
              <remove_value name="global.$GT_Pilots.{$pilot}.$AcademyEnrollment"/>

              <set_skill entity="$pilot" type="skilltype.management" exact="$maxLevel"/>
              <set_skill entity="$pilot" type="skilltype.piloting" exact="9"/>

              <do_if value="global.$GT_Pilots.{$pilot}.$Ship? and global.$GT_Pilots.{$pilot}.$Ship.exists">
                <run_actions ref="md.GT_Ship_Management.Update_Pilot_Ship_Name">
                  <param name="pilot" value="$pilot"/>
                  <param name="ship" value="global.$GT_Pilots.{$pilot}.$Ship"/>
                </run_actions>
              </do_if>

              <set_value name="$processed" operation="add"/>
            </do_if>
          </do_all>
        </do_if>

        <set_value name="global.$GT_GlobalSettings.$Cheats.$PilotsMaxed" exact="true"/>

        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Cheats] Max pilot XP applied to ' + $processed + ' registered pilots (vanilla XP only=' + $useVanillaXPOnly + ')'" chance="100"/>
        </do_if>
      </actions>
    </cue>

  </cues>
</mdscript>
