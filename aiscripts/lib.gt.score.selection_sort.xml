<?xml version="1.0" encoding="utf-8"?>
<!-- Per-ship validation sort: selectionScore = adjustedScore / (1 + ship→buy × shipProximityWeight).
     adjustedScore is trade.$Score (already includes priority-ware multiplier from lib.gt.score.trades).
     Does not mutate cache semantics — $Score unchanged; $SelectionScore is sort key only. -->
<aiscript name="lib.gt.score.selection_sort" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="ship"/>
    <param name="blacklistGroup" default="blacklistgroup.civilian"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $tradeList? or $tradeList.count == 0">
        <wait exact="1ms" comment="Cooperative yield before immediate return (wake-loop guard)"/>
        <return value="table[$SortedTrades = if $tradeList? then $tradeList else []]"/>
      </do_if>

      <set_value name="$proxWeight" exact="0.04"/>
      <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Trading? and global.$GT_GlobalSettings.$Trading.$ShipProximityWeight?">
        <set_value name="$tmpWeight" exact="@global.$GT_GlobalSettings.$Trading.$ShipProximityWeight"/>
        <do_if value="$tmpWeight? and $tmpWeight ge 0">
          <set_value name="$proxWeight" exact="$tmpWeight"/>
        </do_if>
      </do_if>

      <do_all exact="$tradeList.count" counter="$i">
        <set_value name="$trade" exact="$tradeList.{$i}"/>
        <do_if value="not $trade? or $trade == null">
          <continue/>
        </do_if>

        <!-- Cache/live ship-route: keep priority-adjusted $SelectionScore from lib.gt.score.trades when set. -->
        <do_if value="$trade.$ShipRouteScored? and $trade.$ShipRouteScored">
          <set_value name="$selectionScore" exact="if $trade.$SelectionScore? then $trade.$SelectionScore else (if $trade.$ShipScore? then $trade.$ShipScore else 0)"/>
          <set_value name="$trade.$SelectionScore" exact="$selectionScore"/>
        </do_if>
        <do_else>
        <set_value name="$adjustedScore" exact="if $trade.$Score? then $trade.$Score else 0"/>
        <set_value name="$selectionScore" exact="$adjustedScore"/>

        <do_if value="$proxWeight gt 0 and not ($trade.$IsSellOnly? and $trade.$IsSellOnly)">
          <set_value name="$buySector" exact="null"/>
          <do_if value="$trade.$BuySector? and @$trade.$BuySector.exists">
            <set_value name="$buySector" exact="$trade.$BuySector"/>
          </do_if>
          <do_elseif value="$trade.$BuyStation? and @$trade.$BuyStation.exists and $trade.$BuyStation.sector? and @$trade.$BuyStation.sector.exists">
            <set_value name="$buySector" exact="$trade.$BuyStation.sector"/>
          </do_elseif>
          <do_elseif value="$trade.$BuyOffer? and @$trade.$BuyOffer.exists and $trade.$BuyOffer.owner? and @$trade.$BuyOffer.owner.exists and $trade.$BuyOffer.owner.sector? and @$trade.$BuyOffer.owner.sector.exists">
            <set_value name="$buySector" exact="$trade.$BuyOffer.owner.sector"/>
          </do_elseif>

          <set_value name="$shipToBuy" exact="-1"/>
          <do_if value="$buySector != null and @$buySector.exists and $ship? and @$ship.exists and $ship.sector? and @$ship.sector.exists">
            <do_if value="$buySector == $ship.sector">
              <set_value name="$shipToBuy" exact="0"/>
            </do_if>
            <do_elseif value="$blacklistGroup? and $blacklistGroup != null">
              <set_value name="$shipToBuy" exact="$ship.gatedistance.{$buySector}.{$blacklistGroup}.{$ship}"/>
            </do_elseif>
            <do_else>
              <set_value name="$shipToBuy" exact="$ship.gatedistance.{$buySector}"/>
            </do_else>
          </do_if>

          <do_if value="$shipToBuy ge 0">
            <set_value name="$proxFactor" exact="1.0 + ($shipToBuy * $proxWeight)"/>
            <do_if value="$proxFactor gt 0">
              <set_value name="$selectionScore" exact="$adjustedScore / $proxFactor"/>
            </do_if>
          </do_if>
        </do_if>

        <set_value name="$trade.$SelectionScore" exact="$selectionScore"/>
        </do_else>
      </do_all>

      <!-- Drop null holes before sort (sort_list errors on loop.element == null). -->
      <create_list name="$sortableTrades"/>
      <do_all exact="$tradeList.count" counter="$si">
        <set_value name="$sortCand" exact="$tradeList.{$si}"/>
        <do_if value="$sortCand? and $sortCand != null">
          <do_if value="not $sortCand.$SelectionScore?">
            <set_value name="$sortCand.$SelectionScore" exact="if $sortCand.$Score? then $sortCand.$Score else 0"/>
          </do_if>
          <append_to_list name="$sortableTrades" exact="$sortCand"/>
        </do_if>
      </do_all>
      <do_if value="$sortableTrades.count gt 0">
        <sort_list list="$sortableTrades" sortbyvalue="loop.element.$SelectionScore" sortdescending="true"/>
      </do_if>

      <wait exact="1ms" comment="Cooperative yield before return (wake-loop guard)"/>
      <return value="table[$SortedTrades = $sortableTrades]"/>
    </actions>
  </attention>
</aiscript>
