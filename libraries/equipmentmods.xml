<?xml version="1.0" encoding="utf-8"?>
<diff xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <!-- GT Ship Modifications - Ship Mods (mass/drag/radar as clean % steps). -->
  <add sel="/equipmentmods/ship">
    <!-- Level 1: -10% mass/drag, +20% radar -->
    <maxhull ware="mod_ship_gt_level1" quality="1" min="1.0" max="1.0">
      <bonus chance="1.0" max="3">
        <mass min="0.90" max="0.90" weight="1"/>
        <drag min="0.90" max="0.90" weight="1"/>
        <radarrange min="1.20" max="1.20" weight="1"/>
      </bonus>
    </maxhull>

    <!-- Level 2: -15% mass/drag, +20% radar -->
    <maxhull ware="mod_ship_gt_level2" quality="2" min="1.0" max="1.0">
      <bonus chance="1.0" max="3">
        <mass min="0.85" max="0.85" weight="1"/>
        <drag min="0.85" max="0.85" weight="1"/>
        <radarrange min="1.20" max="1.20" weight="1"/>
      </bonus>
    </maxhull>

    <!-- Level 3: -20% mass/drag, +20% radar -->
    <maxhull ware="mod_ship_gt_level3" quality="3" min="1.0" max="1.0">
      <bonus chance="1.0" max="3">
        <mass min="0.80" max="0.80" weight="1"/>
        <drag min="0.80" max="0.80" weight="1"/>
        <radarrange min="1.20" max="1.20" weight="1"/>
      </bonus>
    </maxhull>
  </add>

  <!-- Engine: forward/travel/boost = vanilla ceilings; rotation/strafe keep GT values. -->
  <add sel="/equipmentmods/engine">
    <!-- Level 1: +10% forward, +20% travel/boost (vanilla mk1 max), +20% rotation, +10% strafe -->
    <forwardthrust ware="mod_engine_gt_level1" quality="1" min="1.10" max="1.10">
      <bonus chance="1.0" max="4">
        <travelthrust min="1.20" max="1.20"/>
        <boostthrust min="1.20" max="1.20"/>
        <rotationthrust min="1.20" max="1.20"/>
        <strafethrust min="1.10" max="1.10"/>
      </bonus>
    </forwardthrust>

    <!-- Level 2: +20% forward, +25% travel/boost (vanilla mk2 tradeoff max), +50% rotation, +25% strafe -->
    <forwardthrust ware="mod_engine_gt_level2" quality="2" min="1.20" max="1.20">
      <bonus chance="1.0" max="4">
        <travelthrust min="1.25" max="1.25"/>
        <boostthrust min="1.25" max="1.25"/>
        <rotationthrust min="1.50" max="1.50"/>
        <strafethrust min="1.25" max="1.25"/>
      </bonus>
    </forwardthrust>

    <!-- Level 3: +30% forward, +50% travel/boost (vanilla mk3 fast-mod bonus max), +120% rotation, +60% strafe -->
    <forwardthrust ware="mod_engine_gt_level3" quality="3" min="1.30" max="1.30">
      <bonus chance="1.0" max="4">
        <travelthrust min="1.50" max="1.50"/>
        <boostthrust min="1.50" max="1.50"/>
        <rotationthrust min="2.20" max="2.20"/>
        <strafethrust min="1.60" max="1.60"/>
      </bonus>
    </forwardthrust>
  </add>

</diff>
