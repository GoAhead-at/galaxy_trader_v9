<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.priority_wares.resolve" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Priority-ware resolver shared by GalaxyTrader MK3 / MK4.

    Walks the priority-ware source chain in this fixed order and returns the
    first non-empty list found:
      1) `instanceWares` (typically `this.$effectivePriorityWares` from the caller)
      2) `localWares`    (typically a workunit-local `$effectivePriorityWares`)
      3) `ship.commander.defaultorder.$prioritywares`
         - direct, when commander.defaultorder.id is in `validOrderIds`
         - via `defaultorder.$baseorder.$prioritywares` when the commander runs
           the vanilla `Assist` order over a GalaxyTrader baseorder
      4) `[]` (no priority wares anywhere)

    Replaces the ~1.5 KB nested ternary previously inlined at order.trade.galaxytrader:3843
    and order.trade.galaxytradermk4:4190 (see DOCS/MK3_PIPELINE_REFACTOR.md §3.8).
    The single-pass walk also guarantees that callers never see a "?-true but null"
    handle for a priority-wares property — every step here applies the
    `<existence>? and != null and .count gt 0` triple guard.
  -->
  <params>
    <param name="instanceWares" default="null"/>
    <param name="localWares" default="null"/>
    <param name="ship" default="this.ship"/>
    <param name="validOrderIds" default="['GalaxyTraderMK3']"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="$instanceWares? and $instanceWares != null and $instanceWares.count gt 0">
        <return value="$instanceWares"/>
      </do_if>
      <do_if value="$localWares? and $localWares != null and $localWares.count gt 0">
        <return value="$localWares"/>
      </do_if>
      <do_if value="$ship? and $ship.commander? and $ship.commander.defaultorder?">
        <set_value name="$cmdOrder" exact="$ship.commander.defaultorder"/>
        <do_if value="$validOrderIds? and $validOrderIds.indexof.{@$cmdOrder.id} and $cmdOrder.$prioritywares? and $cmdOrder.$prioritywares != null and $cmdOrder.$prioritywares.count gt 0">
          <return value="$cmdOrder.$prioritywares"/>
        </do_if>
        <do_if value="@$cmdOrder.id == 'Assist' and $cmdOrder.$baseorder? and $validOrderIds? and $validOrderIds.indexof.{@$cmdOrder.$baseorder.id} and $cmdOrder.$baseorder.$prioritywares? and $cmdOrder.$baseorder.$prioritywares != null and $cmdOrder.$baseorder.$prioritywares.count gt 0">
          <return value="$cmdOrder.$baseorder.$prioritywares"/>
        </do_if>
      </do_if>
      <return value="[]"/>
    </actions>
  </attention>
</aiscript>
