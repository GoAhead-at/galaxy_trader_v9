<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_Ship_Naming_Pattern" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <cues>

    <!-- Shared op-state flag detection for legacy + pattern naming -->
    <library name="GT_Collect_Ship_OpState_Flags" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to inspect"/>
      </params>
      <actions>
        <set_value name="$flags" exact="table[
          $ShowCustomBlacklist = false,
          $Escape = false,
          $Reroute = false,
          $Clearance = false,
          $Unreachable = false,
          $PilotExchange = false,
          $HasRepair = false,
          $HasResupply = false
        ]"/>

        <set_value name="$mk3BlacklistOwnerForTag" exact="$ship"/>
        <set_value name="$isShipAffectedByCustomBlacklist" exact="false"/>
        <do_if value="$ship.commander? and $ship.commander.exists">
          <do_if value="$ship.commander.defaultorder?">
            <do_if value="@$ship.commander.defaultorder.id == 'GalaxyTraderMK3'">
              <set_value name="$mk3BlacklistOwnerForTag" exact="$ship.commander"/>
              <set_value name="$isShipAffectedByCustomBlacklist" exact="true"/>
            </do_if>
          </do_if>
        </do_if>
        <do_elseif value="$ship.defaultorder? and @$ship.defaultorder.id == 'GalaxyTraderMK3'">
          <set_value name="$mk3BlacklistOwnerForTag" exact="$ship"/>
          <set_value name="$isShipAffectedByCustomBlacklist" exact="true"/>
        </do_elseif>
        <do_if value="$isShipAffectedByCustomBlacklist and global.$GT_MK3FactionBlacklist? and global.$GT_MK3FactionBlacklist.$ShipSelections? and global.$GT_MK3FactionBlacklist.$ShipSelections.{$mk3BlacklistOwnerForTag}? and global.$GT_MK3FactionBlacklist.$ShipSelections.{$mk3BlacklistOwnerForTag}.keys.count gt 0">
          <set_value name="$flags.$ShowCustomBlacklist" exact="true"/>
        </do_if>

        <do_if value="global.$GT_ResupplyOrders? and global.$GT_ResupplyOrders.{$ship}?">
          <set_value name="$flags.$HasResupply" exact="true"/>
        </do_if>

        <set_value name="$isGTRelated" exact="false"/>
        <do_if value="global.$GT_Ships? and global.$GT_Ships.{$ship}?">
          <set_value name="$isGTRelated" exact="true"/>
        </do_if>
        <do_else>
          <set_value name="$commander" exact="@$ship.commander"/>
          <do_if value="$commander? and global.$GT_Ships? and global.$GT_Ships.{$commander}?">
            <set_value name="$isGTRelated" exact="true"/>
          </do_if>
        </do_else>

        <do_if value="$isGTRelated">
          <set_value name="$activeOrderId" exact="@$ship.order.id"/>
          <do_if value="$activeOrderId == 'Equip' or $activeOrderId == 'Resupply'">
            <set_value name="$flags.$HasResupply" exact="true"/>
          </do_if>
          <do_elseif value="$activeOrderId == 'Repair'">
            <set_value name="$flags.$HasRepair" exact="true"/>
          </do_elseif>
        </do_if>

        <do_if value="global.$GT_Ships? and global.$GT_Ships.{$ship}?">
          <set_value name="$shipData" exact="global.$GT_Ships.{$ship}"/>
          <do_if value="$shipData.$NeedsRepair? and $shipData.$NeedsRepair">
            <set_value name="$flags.$HasRepair" exact="true"/>
          </do_if>
          <do_if value="$shipData.$Escaping? and $shipData.$Escaping">
            <set_value name="$flags.$Escape" exact="true"/>
          </do_if>
          <do_if value="$shipData.$Rerouting? and $shipData.$Rerouting">
            <set_value name="$flags.$Reroute" exact="true"/>
          </do_if>
          <do_if value="$shipData.$CargoDisposal? and $shipData.$CargoDisposal">
            <set_value name="$flags.$Clearance" exact="true"/>
          </do_if>
          <do_if value="$shipData.$Unreachable? and $shipData.$Unreachable">
            <set_value name="$flags.$Unreachable" exact="true"/>
          </do_if>
          <set_value name="$showPilotExchangeState" exact="false"/>
          <do_if value="md.GT_Ship_State_Utilities.GT_CheckPilotExchangeStatus?">
            <run_actions ref="md.GT_Ship_State_Utilities.GT_CheckPilotExchangeStatus" result="$namePeStatus">
              <param name="ship" value="$ship"/>
            </run_actions>
            <do_if value="$namePeStatus.$ShouldKeepPE">
              <set_value name="$showPilotExchangeState" exact="true"/>
            </do_if>
          </do_if>
          <do_elseif value="$shipData.$PilotExchange? and $shipData.$PilotExchange">
            <set_value name="$showPilotExchangeState" exact="true"/>
          </do_elseif>
          <do_if value="$showPilotExchangeState">
            <set_value name="$flags.$PilotExchange" exact="true"/>
          </do_if>
        </do_if>

        <return value="$flags"/>
      </actions>
    </library>

    <!-- Canonical multi-label op-state list (pattern + legacy naming share this). -->
    <library name="GT_Build_OpState_Labels" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to inspect"/>
      </params>
      <actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Collect_Ship_OpState_Flags" result="$flags">
          <param name="ship" value="$ship"/>
        </run_actions>
        <set_value name="$labels" exact="[]"/>
        <set_value name="$abbr" exact="''"/>

        <do_if value="$flags.$ShowCustomBlacklist">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'CustomBlacklist'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'CustomBlacklist', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$Escape">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'Escape'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'Escape', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$Reroute and not $flags.$HasRepair and not $flags.$HasResupply">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'Reroute'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'Reroute', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$Clearance">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'Clearance'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'Clearance', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$Unreachable">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'Unreachable'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'Unreachable', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$PilotExchange">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'PilotExchange'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'PilotExchange', $Abbr = $abbr]"/>
        </do_if>
        <do_if value="$flags.$HasRepair and $flags.$HasResupply">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
            <param name="stateType" value="'Maintenance'"/>
          </run_actions>
          <append_to_list name="$labels" exact="table[$StateType = 'Maintenance', $Abbr = $abbr]"/>
        </do_if>
        <do_else>
          <do_if value="$flags.$HasRepair">
            <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
              <param name="stateType" value="'Repair'"/>
            </run_actions>
            <append_to_list name="$labels" exact="table[$StateType = 'Repair', $Abbr = $abbr]"/>
          </do_if>
          <do_if value="$flags.$HasResupply">
            <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$abbr">
              <param name="stateType" value="'Resupply'"/>
            </run_actions>
            <append_to_list name="$labels" exact="table[$StateType = 'Resupply', $Abbr = $abbr]"/>
          </do_if>
        </do_else>

        <return value="$labels"/>
      </actions>
    </library>

    <!-- Multi-flag OPSTATE string for pattern mode (plain abbreviations, space-separated) -->
    <library name="GT_Build_Pattern_OpState" purpose="run_actions">
      <params>
        <param name="ship" comment="Ship to inspect"/>
      </params>
      <actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_OpState_Labels" result="$labels">
          <param name="ship" value="$ship"/>
        </run_actions>
        <set_value name="$result" exact="''"/>
        <do_all exact="$labels.count" counter="$i">
          <set_value name="$labelRow" exact="$labels.{$i}"/>
          <do_if value="$labelRow? and $labelRow.$Abbr? and $labelRow.$Abbr != ''">
            <do_if value="$result != ''">
              <set_value name="$result" exact="$result + ' '"/>
            </do_if>
            <set_value name="$result" exact="$result + $labelRow.$Abbr"/>
          </do_if>
        </do_all>
        <return value="$result"/>
      </actions>
    </library>

    <!-- STATUS token for pattern mode -->
    <library name="GT_Build_Pattern_Status" purpose="run_actions">
      <params>
        <param name="nameType" default="'trader'"/>
      </params>
      <actions>
        <set_value name="$result" exact="''"/>
        <do_if value="$nameType == 'blocked'">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$result">
            <param name="stateType" value="'Blocked'"/>
          </run_actions>
        </do_if>
        <do_elseif value="$nameType == 'training'">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$result">
            <param name="stateType" value="'Training'"/>
          </run_actions>
        </do_elseif>
        <do_elseif value="$nameType == 'fallback'">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$result">
            <param name="stateType" value="'Fallback'"/>
          </run_actions>
        </do_elseif>
        <do_elseif value="$nameType == 'isolated'">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$result">
            <param name="stateType" value="'Isolated'"/>
          </run_actions>
        </do_elseif>
        <return value="$result"/>
      </actions>
    </library>

    <!-- Atomic state token from collected flags -->
    <library name="GT_Build_Pattern_Atomic_State" purpose="run_actions">
      <params>
        <param name="flags"/>
        <param name="stateType" comment="State key for Get_State_Abbreviation"/>
        <param name="active" default="false"/>
      </params>
      <actions>
        <set_value name="$result" exact="''"/>
        <do_if value="$active">
          <run_actions ref="md.GT_Ship_Management.Get_State_Abbreviation" result="$result">
            <param name="stateType" value="$stateType"/>
          </run_actions>
        </do_if>
        <return value="$result"/>
      </actions>
    </library>

    <library name="GT_Collapse_Pattern_Whitespace" purpose="run_actions">
      <params>
        <param name="text"/>
      </params>
      <actions>
        <set_value name="$result" exact="$text"/>
        <do_all exact="8" counter="$wsPass">
          <substitute_text source="$result" text="$result">
            <replace string="'  '" with="' '"/>
          </substitute_text>
        </do_all>
        <return value="$result"/>
      </actions>
    </library>

    <library name="GT_Pattern_ReplaceToken" purpose="run_actions">
      <params>
        <param name="text"/>
        <param name="token" comment="Token including braces, e.g. {MODEL}"/>
        <param name="value"/>
      </params>
      <actions>
        <set_value name="$result" exact="$text"/>
        <substitute_text source="$result" text="$result">
          <replace string="$token" with="$value"/>
        </substitute_text>
        <return value="$result"/>
      </actions>
    </library>

    <!-- Resolve $NamePattern into a display ship name -->
    <library name="GT_Resolve_Ship_Name_Pattern" purpose="run_actions">
      <params>
        <param name="ship"/>
        <param name="pilot" default="null"/>
        <param name="nameType" default="'trader'"/>
        <param name="currentXP" default="0"/>
        <param name="currentLevel" default="1"/>
        <param name="rankTitle" default="''"/>
      </params>
      <actions>
        <set_value name="$pattern" exact="'{OPSTATE} {STATUS} {MODEL} ({RANK} {LVL_LABEL} XP:{XP})'"/>
        <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$ShipNaming? and global.$GT_GlobalSettings.$ShipNaming.$NamePattern? and global.$GT_GlobalSettings.$ShipNaming.$NamePattern != ''">
          <set_value name="$pattern" exact="global.$GT_GlobalSettings.$ShipNaming.$NamePattern"/>
        </do_if>

        <do_if value="not $pilot? or $pilot == null">
          <set_value name="$pilot" exact="@$ship.pilot"/>
        </do_if>

        <!-- Precompute token values -->
        <set_value name="$vMODEL" exact="@$ship.macro.name"/>
        <run_actions ref="md.GT_Ship_Management.Extract_Base_Ship_Name" result="$vMODELBASE">
          <param name="macroName" value="@$ship.macro.name"/>
        </run_actions>
        <set_value name="$vTYPENAME" exact="@$ship.typename"/>
        <do_if value="not $vTYPENAME? or $vTYPENAME == ''">
          <set_value name="$vTYPENAME" exact="$vMODEL"/>
        </do_if>
        <set_value name="$vBASE" exact="''"/>
        <do_if value="global.$GT_Ships? and global.$GT_Ships.{$ship}? and global.$GT_Ships.{$ship}.$OriginalShipName?">
          <set_value name="$vBASE" exact="global.$GT_Ships.{$ship}.$OriginalShipName"/>
        </do_if>
        <do_elseif value="global.$GT_Pilots? and $pilot? and global.$GT_Pilots.{$pilot}? and global.$GT_Pilots.{$pilot}.$OriginalShipName?">
          <set_value name="$vBASE" exact="global.$GT_Pilots.{$pilot}.$OriginalShipName"/>
        </do_elseif>
        <set_value name="$vID" exact="$ship.idcode"/>
        <run_actions ref="md.GT_Ship_Management.Detect_Ship_Class" result="$classInfo">
          <param name="ship" value="$ship"/>
        </run_actions>
        <set_value name="$vCLASS" exact="'M'"/>
        <set_value name="$vCLASSNAME" exact="'medium'"/>
        <do_if value="$classInfo?">
          <set_value name="$vCLASS" exact="$classInfo.$Size"/>
          <set_value name="$vCLASSNAME" exact="$classInfo.$Class"/>
        </do_if>

        <set_value name="$vXP" exact="$currentXP"/>
        <set_value name="$vLVL" exact="$currentLevel"/>
        <set_value name="$vLVL_LABEL" exact="'Lv.' + $currentLevel"/>
        <set_value name="$rankIndex" exact="($currentLevel / 3)i + 1"/>
        <do_if value="$rankIndex gt 6">
          <set_value name="$rankIndex" exact="6"/>
        </do_if>
        <set_value name="$vRANK" exact="$rankTitle"/>
        <do_if value="not $vRANK? or $vRANK == ''">
          <do_if value="$rankIndex == 1">
            <set_value name="$vRANK" exact="readtext.{77000}.{6001}"/>
          </do_if>
          <do_elseif value="$rankIndex == 2">
            <set_value name="$vRANK" exact="readtext.{77000}.{6002}"/>
          </do_elseif>
          <do_elseif value="$rankIndex == 3">
            <set_value name="$vRANK" exact="readtext.{77000}.{6003}"/>
          </do_elseif>
          <do_elseif value="$rankIndex == 4">
            <set_value name="$vRANK" exact="readtext.{77000}.{6004}"/>
          </do_elseif>
          <do_elseif value="$rankIndex == 5">
            <set_value name="$vRANK" exact="readtext.{77000}.{6005}"/>
          </do_elseif>
          <do_elseif value="$rankIndex == 6">
            <set_value name="$vRANK" exact="readtext.{77000}.{6006}"/>
          </do_elseif>
        </do_if>
        <set_value name="$vRANKNUM" exact="$rankIndex"/>
        <set_value name="$vSTARS" exact="[[($currentLevel / 3)i, 1].max, 5].min"/>

        <set_value name="$vMGMT" exact="''"/>
        <set_value name="$vPILOTSKILL" exact="''"/>
        <do_if value="$pilot? and $pilot.exists">
          <set_value name="$vMGMT" exact="$pilot.skill.management"/>
          <set_value name="$vPILOTSKILL" exact="$pilot.skill.piloting"/>
        </do_if>

        <run_actions ref="md.GT_Libraries_General.GT_GetHomeSector" result="$homeSectorObj">
          <param name="ship" value="$ship"/>
        </run_actions>
        <set_value name="$vHOME" exact="''"/>
        <do_if value="$homeSectorObj? and $homeSectorObj.exists">
          <run_actions ref="md.GT_Libraries_General.GT_GetSectorNameSafe" result="$vHOME">
            <param name="sector" value="$homeSectorObj"/>
          </run_actions>
        </do_if>

        <set_value name="$homeStationObj" exact="null"/>
        <do_if value="$ship.defaultorder? and $ship.defaultorder.$homeStation? and @$ship.defaultorder.$homeStation.exists">
          <set_value name="$homeStationObj" exact="$ship.defaultorder.$homeStation"/>
        </do_if>
        <do_elseif value="$ship.defaultorder? and $ship.defaultorder.$home? and @$ship.defaultorder.$home.exists and $ship.defaultorder.$home.isclass.station">
          <set_value name="$homeStationObj" exact="$ship.defaultorder.$home"/>
        </do_elseif>
        <set_value name="$vHOMESTATION" exact="''"/>
        <set_value name="$vHOMESTATIONID" exact="''"/>
        <do_if value="$homeStationObj? and $homeStationObj.exists">
          <set_value name="$vHOMESTATION" exact="$homeStationObj.knownname"/>
          <set_value name="$vHOMESTATIONID" exact="$homeStationObj.idcode"/>
        </do_if>

        <set_value name="$vPILOT" exact="''"/>
        <set_value name="$vPILOTID" exact="''"/>
        <do_if value="$pilot? and $pilot.exists">
          <set_value name="$vPILOT" exact="$pilot.name"/>
          <do_if value="$pilot.idcode?">
            <set_value name="$vPILOTID" exact="$pilot.idcode"/>
          </do_if>
        </do_if>

        <set_value name="$vFLEET" exact="'-'"/>
        <do_if value="$ship.fleet? and $ship.fleet.commander? and $ship.fleet.commander.fleet? and $ship.fleet.commander.fleet.name?">
          <set_value name="$vFLEET" exact="$ship.fleet.commander.fleet.name"/>
        </do_if>
        <do_elseif value="$ship.fleet? and $ship.fleet.name?">
          <set_value name="$vFLEET" exact="$ship.fleet.name"/>
        </do_elseif>

        <set_value name="$vCOMMANDER" exact="''"/>
        <set_value name="$vCOMMANDERID" exact="''"/>
        <do_if value="$ship.commander? and $ship.commander.exists and $ship.commander != $ship">
          <set_value name="$vCOMMANDER" exact="$ship.commander.knownname"/>
          <set_value name="$vCOMMANDERID" exact="$ship.commander.idcode"/>
        </do_if>

        <set_value name="$vORDER" exact="''"/>
        <do_if value="$ship.defaultorder?">
          <set_value name="$vORDER" exact="@$ship.defaultorder.id"/>
        </do_if>

        <set_value name="$vSECTOR" exact="''"/>
        <do_if value="$ship.sector? and $ship.sector.exists">
          <run_actions ref="md.GT_Libraries_General.GT_GetSectorNameSafe" result="$vSECTOR">
            <param name="sector" value="$ship.sector"/>
          </run_actions>
        </do_if>

        <set_value name="$vPROFIT" exact="''"/>
        <set_value name="$vTRADES" exact="''"/>
        <do_if value="$pilot? and global.$GT_Pilots? and global.$GT_Pilots.{$pilot}?">
          <do_if value="global.$GT_Pilots.{$pilot}.$TotalProfit?">
            <set_value name="$vPROFIT" exact="(global.$GT_Pilots.{$pilot}.$TotalProfit / 100)i"/>
          </do_if>
          <do_if value="global.$GT_Pilots.{$pilot}.$TotalTrades?">
            <set_value name="$vTRADES" exact="global.$GT_Pilots.{$pilot}.$TotalTrades"/>
          </do_if>
        </do_if>
        <set_value name="$vSHIPPROFIT" exact="''"/>
        <set_value name="$vSHIPTRADES" exact="''"/>
        <do_if value="global.$GT_Ships? and global.$GT_Ships.{$ship}?">
          <do_if value="global.$GT_Ships.{$ship}.$TotalProfit?">
            <set_value name="$vSHIPPROFIT" exact="(global.$GT_Ships.{$ship}.$TotalProfit / 100)i"/>
          </do_if>
          <do_if value="global.$GT_Ships.{$ship}.$TotalTrades?">
            <set_value name="$vSHIPTRADES" exact="global.$GT_Ships.{$ship}.$TotalTrades"/>
          </do_if>
        </do_if>

        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_OpState" result="$vOPSTATE">
          <param name="ship" value="$ship"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Status" result="$vSTATUS">
          <param name="nameType" value="$nameType"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Collect_Ship_OpState_Flags" result="$opFlags">
          <param name="ship" value="$ship"/>
        </run_actions>

        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vCB">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'CustomBlacklist'"/>
          <param name="active" value="$opFlags.$ShowCustomBlacklist"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vRS">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Resupply'"/>
          <param name="active" value="$opFlags.$HasResupply and not ($opFlags.$HasRepair and $opFlags.$HasResupply)"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vRP">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Repair'"/>
          <param name="active" value="$opFlags.$HasRepair and not ($opFlags.$HasRepair and $opFlags.$HasResupply)"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vMT">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Maintenance'"/>
          <param name="active" value="$opFlags.$HasRepair and $opFlags.$HasResupply"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vES">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Escape'"/>
          <param name="active" value="$opFlags.$Escape"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vRR">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Reroute'"/>
          <param name="active" value="$opFlags.$Reroute"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vCL">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Clearance'"/>
          <param name="active" value="$opFlags.$Clearance"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vUR">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Unreachable'"/>
          <param name="active" value="$opFlags.$Unreachable"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vPE">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'PilotExchange'"/>
          <param name="active" value="$opFlags.$PilotExchange"/>
        </run_actions>
        <run_actions ref="md.GT_Ship_Naming_Pattern.GT_Build_Pattern_Atomic_State" result="$vBL">
          <param name="flags" value="$opFlags"/>
          <param name="stateType" value="'Blocked'"/>
