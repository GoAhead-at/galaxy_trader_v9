<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_HomeFleetProfile" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <cues>
    <!-- Event-driven rebuild for MK3 home-sector fleet-min cargo profiles (cache-refresh totalvolume). -->
    <cue name="HandleProfileUpdate" instantiate="true">
      <conditions>
        <event_object_signalled object="player.galaxy" param="'GT_HomeFleetProfile_Update'"/>
      </conditions>
      <actions>
        <set_value name="$params" exact="event.param2"/>
        <run_actions ref="md.GT_HomeFleetProfile.GT_RebuildHomeFleetCargoProfile">
          <param name="homeSector" value="if $params? and $params.$HomeSector? then @$params.$HomeSector else null"/>
          <param name="alsoHomeSector" value="if $params? and $params.$AlsoHomeSector? then @$params.$AlsoHomeSector else null"/>
        </run_actions>
      </actions>
    </cue>

    <!-- One-shot rebuild after load so profiles match the full MK3 cohort (F13). -->
    <cue name="RebuildAllOnGameLoad" instantiate="true" version="1">
      <conditions>
        <check_any>
          <event_player_created/>
          <event_game_loaded/>
        </check_any>
      </conditions>
      <delay exact="2s"/>
      <actions>
        <run_actions ref="md.GT_HomeFleetProfile.GT_RebuildHomeFleetCargoProfile">
          <param name="homeSector" value="null"/>
          <param name="alsoHomeSector" value="null"/>
        </run_actions>
      </actions>
    </cue>

    <cue name="HandleProfileOnOrderAbort" instantiate="true">
      <conditions>
        <event_object_signalled object="player.galaxy" param="'GT_Ship_Order_Aborted'"/>
      </conditions>
      <actions>
        <set_value name="$abortShip" exact="if event.param2? and event.param2.$Ship? then @event.param2.$Ship else null"/>
        <set_value name="$abortHome" exact="null"/>
        <do_if value="$abortShip? and $abortShip.exists">
          <run_actions ref="md.GT_Libraries_General.GT_GetHomeSector" result="$abortHome">
            <param name="ship" value="$abortShip"/>
          </run_actions>
        </do_if>
        <run_actions ref="md.GT_HomeFleetProfile.GT_RebuildHomeFleetCargoProfile">
          <param name="homeSector" value="$abortHome"/>
          <param name="alsoHomeSector" value="null"/>
        </run_actions>
      </actions>
    </cue>

    <library name="GT_ShipIsMK3Service" purpose="run_actions">
    <params>
      <param name="ship"/>
    </params>
    <actions>
      <do_if value="not $ship? or not $ship.exists or not $ship.defaultorder?">
        <return value="false"/>
      </do_if>
      <do_if value="@$ship.defaultorder.id == 'GalaxyTraderMK3'">
        <return value="true"/>
      </do_if>
      <do_if value="@$ship.defaultorder.id == 'Assist' and $ship.commander? and $ship.commander.exists and $ship.commander.defaultorder?">
        <do_if value="@$ship.commander.defaultorder.id == 'GalaxyTraderMK3'">
          <return value="true"/>
        </do_if>
        <do_if value="@$ship.commander.defaultorder.id == 'Assist' and $ship.commander.defaultorder.$baseorder? and @$ship.commander.defaultorder.$baseorder.id == 'GalaxyTraderMK3'">
          <return value="true"/>
        </do_if>
      </do_if>
      <return value="false"/>
    </actions>
  </library>

  <library name="GT_GetMK3EffectiveCargoTarget" purpose="run_actions">
    <params>
      <param name="ship"/>
    </params>
    <actions>
      <set_value name="$pct" exact="80"/>
      <set_value name="$order" exact="if $ship? and $ship.defaultorder? then $ship.defaultorder else null"/>
      <do_if value="$ship? and $ship.commander? and $ship.commander.exists and $ship.commander != $ship and $ship.commander.defaultorder?">
        <set_value name="$order" exact="$ship.commander.defaultorder"/>
      </do_if>
      <do_if value="$order?">
        <do_if value="@$order.id == 'GalaxyTraderMK3' and $order.$cargotarget?">
          <set_value name="$pct" exact="$order.$cargotarget"/>
        </do_if>
        <do_elseif value="@$order.id == 'Assist' and $order.$baseorder? and @$order.$baseorder.id == 'GalaxyTraderMK3' and $order.$baseorder.$cargotarget?">
          <set_value name="$pct" exact="$order.$baseorder.$cargotarget"/>
        </do_elseif>
        <do_elseif value="@$order.id == 'Assist' and $order.$cargotarget?">
          <set_value name="$pct" exact="$order.$cargotarget"/>
        </do_elseif>
      </do_if>
      <set_value name="$pct" exact="[10, [$pct, 100].min].max"/>
      <return value="$pct"/>
    </actions>
  </library>

  <library name="GT_RebuildHomeFleetCargoProfile" purpose="run_actions">
    <params>
      <param name="homeSector" default="null" comment="Rebuild this home sector only; null = rebuild all cohort homes"/>
      <param name="alsoHomeSector" default="null" comment="Optional second home bucket (e.g. after home change)"/>
    </params>
    <actions>
      <do_if value="not global.$GT_HomeFleetCargoProfile?">
        <set_value name="global.$GT_HomeFleetCargoProfile" exact="table[]"/>
      </do_if>

      <set_value name="$homesToRebuild" exact="[]"/>
      <do_if value="$homeSector? and $homeSector.exists">
        <append_to_list name="$homesToRebuild" exact="$homeSector"/>
      </do_if>
      <do_if value="$alsoHomeSector? and $alsoHomeSector.exists">
        <set_value name="$alsoAlready" exact="false"/>
        <do_all exact="$homesToRebuild.count" counter="$hck">
          <do_if value="$homesToRebuild.{$hck} == $alsoHomeSector">
            <set_value name="$alsoAlready" exact="true"/>
            <break/>
          </do_if>
        </do_all>
        <do_if value="not $alsoAlready">
          <append_to_list name="$homesToRebuild" exact="$alsoHomeSector"/>
        </do_if>
      </do_if>

      <find_ship_by_true_owner name="$fleetShips" faction="faction.player" space="player.galaxy" class="[class.ship_s, class.ship_m, class.ship_l, class.ship_xl]" multiple="true" checkoperational="true"/>

      <do_if value="$homesToRebuild.count == 0">
        <set_value name="$homesSeen" exact="table[]"/>
        <do_all exact="$fleetShips.count" counter="$fsi">
          <set_value name="$fs" exact="$fleetShips.{$fsi}"/>
          <run_actions ref="md.GT_HomeFleetProfile.GT_ShipIsMK3Service" result="$fsIsMk3">
            <param name="ship" value="$fs"/>
          </run_actions>
          <do_if value="not $fsIsMk3">
            <continue/>
          </do_if>
          <run_actions ref="md.GT_Libraries_General.GT_GetHomeSector" result="$fsHome">
            <param name="ship" value="$fs"/>
          </run_actions>
          <do_if value="$fsHome? and $fsHome.exists and not $homesSeen.{$fsHome}?">
            <set_value name="$homesSeen.{$fsHome}" exact="true"/>
            <append_to_list name="$homesToRebuild" exact="$fsHome"/>
          </do_if>
        </do_all>
      </do_if>

      <do_all exact="$homesToRebuild.count" counter="$hi">
        <set_value name="$h" exact="$homesToRebuild.{$hi}"/>
        <set_value name="$minContainer" exact="null"/>
        <set_value name="$minSolid" exact="null"/>
        <set_value name="$minLiquid" exact="null"/>
        <set_value name="$shipCount" exact="0"/>

        <do_all exact="$fleetShips.count" counter="$si">
          <set_value name="$s" exact="$fleetShips.{$si}"/>
          <run_actions ref="md.GT_HomeFleetProfile.GT_ShipIsMK3Service" result="$isMk3">
            <param name="ship" value="$s"/>
          </run_actions>
          <do_if value="not $isMk3">
            <continue/>
          </do_if>
          <run_actions ref="md.GT_Libraries_General.GT_GetHomeSector" result="$sHome">
            <param name="ship" value="$s"/>
          </run_actions>
          <do_if value="not $sHome? or not $sHome.exists or $sHome != $h">
            <continue/>
          </do_if>

          <run_actions ref="md.GT_HomeFleetProfile.GT_GetMK3EffectiveCargoTarget" result="$pct">
            <param name="ship" value="$s"/>
          </run_actions>
          <set_value name="$shipCount" operation="add"/>

          <set_value name="$capContainer" exact="$s.cargo.capacity.container + $s.cargo.capacity.universal"/>
          <set_value name="$reqContainer" exact="($capContainer * $pct / 100)i"/>
          <do_if value="not $minContainer? or $reqContainer lt $minContainer">
            <set_value name="$minContainer" exact="$reqContainer"/>
          </do_if>

          <set_value name="$capSolid" exact="$s.cargo.capacity.solid + $s.cargo.capacity.universal"/>
          <set_value name="$reqSolid" exact="($capSolid * $pct / 100)i"/>
          <do_if value="not $minSolid? or $reqSolid lt $minSolid">
            <set_value name="$minSolid" exact="$reqSolid"/>
          </do_if>

          <set_value name="$capLiquid" exact="$s.cargo.capacity.liquid + $s.cargo.capacity.universal"/>
          <set_value name="$reqLiquid" exact="($capLiquid * $pct / 100)i"/>
          <do_if value="not $minLiquid? or $reqLiquid lt $minLiquid">
            <set_value name="$minLiquid" exact="$reqLiquid"/>
          </do_if>
        </do_all>

        <do_if value="$shipCount gt 0">
          <set_value name="global.$GT_HomeFleetCargoProfile.{$h}" exact="table[
            $MinRequired = table[
              $container = if $minContainer? then $minContainer else 1,
              $solid = if $minSolid? then $minSolid else 1,
              $liquid = if $minLiquid? then $minLiquid else 1
            ],
            $ShipCount = $shipCount,
            $UpdatedAt = player.age
          ]"/>
        </do_if>
        <do_else>
          <do_if value="global.$GT_HomeFleetCargoProfile.{$h}?">
            <remove_value name="global.$GT_HomeFleetCargoProfile.{$h}"/>
          </do_if>
        </do_else>
      </do_all>
    </actions>
  </library>

  </cues>

</mdscript>
