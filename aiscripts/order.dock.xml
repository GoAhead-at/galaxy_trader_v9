<?xml version="1.0" encoding="utf-8"?>
<diff>
  <!-- GalaxyTrader MK3: Capture dock failure reasons for trade orders -->
  
  <!-- CRITICAL: When dock fails due to "no path to destination", signal parent trade order -->
  <add sel="//aiscript[@name='order.dock']/attention/actions/label[@name='nodestination']" pos="after">
    
    <!-- GALAXYTRADER MK3: Signal dock failure to parent trade order -->
    <do_if value="@$callerid.id == 'TradePerform'">
      <!-- This dock order was created by a trade order - signal the failure reason -->
      <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$thisship.pilot}?">
        <!-- Only for GT-managed pilots -->
        
        <!-- Determine specific failure reason -->
        <set_value name="$gt_dock_failure" exact="'ERR_NO_PATH_TO_DESTINATION'"/>
        <set_value name="$failuretext" exact="{1045, 124}" comment="No path to destination"/>
        
        <!-- Check if it's a blacklist issue -->
        <include_interrupt_actions ref="GetBlacklistgroup"/>
        <do_if value="$internalorder and @$destination.exists">
          <!-- Check if destination is blacklisted -->
          <do_if value="$destination.isblacklisted.{blacklisttype.objectactivity}.{$blacklistgroup}.{$thisship}">
            <set_value name="$gt_dock_failure" exact="'ERR_DESTINATION_BLACKLISTED'"/>
            <set_value name="$failuretext" exact="{1045, 124}" comment="Destination is blacklisted"/>
          </do_if>
          <do_elseif value="@$destination.sector.isblacklisted.{blacklisttype.sectortravel}.{$blacklistgroup}.{$thisship}">
            <set_value name="$gt_dock_failure" exact="'ERR_SECTOR_BLACKLISTED'"/>
            <set_value name="$failuretext" exact="{1045, 124}" comment="Sector is blacklisted"/>
          </do_elseif>
        </do_if>
        
        <!-- Store failure reason in global table for parent trade order to check -->
        <do_if value="not global.$GT_DockFailures?">
          <set_value name="global.$GT_DockFailures" exact="table[]"/>
        </do_if>
        
        <set_value name="global.$GT_DockFailures.{$thisship}" exact="table[
          $Reason = $gt_dock_failure,
          $FailureText = $failuretext,
          $Destination = $destination,
          $Timestamp = player.age
        ]"/>
        
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-Dock] ⚠ Dock FAILED for ' + $thisship.idcode + ': ' + $gt_dock_failure + ' (destination: ' + @$destination.knownname + ')'" chance="100"/>
        </do_if>
      </do_if>
    </do_if>
    
  </add>

  <!-- GalaxyTrader MK3: same SAR transfer signal as order.rescue.ship (successful spacesuit dock path). -->
  <replace sel="//aiscript[@name='order.dock']//do_if[@value='$spacesuittransfer and $thisship.isclass.spacesuit']/do_if[@value='this.trueowner == $destination.trueowner']/create_npc_template">
    <create_npc_template name="$gt_sar_crew_template" entity="this" object="$destination" role="entityrole.unassigned" force="true"/>
    <set_value name="$gt_sar_stable" exact="''"/>
    <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{this}? and global.$GT_Pilots.{this}.$StableIdentity?">
      <set_value name="$gt_sar_stable" exact="global.$GT_Pilots.{this}.$StableIdentity"/>
    </do_if>
    <do_elseif value="this.seed?">
      <set_value name="$gt_sar_stable" exact="'s:' + this.seed"/>
    </do_elseif>
    <set_value name="$gt_sar_registry_key" exact="if global.$GT_Pilots? and global.$GT_Pilots.{this}? then this else null"/>
    <!-- Stash the exact crew npctemplate for MD to resolve the new crew entity + its people seed.
         The PilotIdMap wire is built MD-side from the numeric people seed (an npctemplate cannot be
         split into a u64 wire in any X4 expression engine, and the seed is what the crew UI matches on). -->
    <do_if value="not global.$GT_SarCrewTemplateScratch?">
      <set_value name="global.$GT_SarCrewTemplateScratch" exact="table[]"/>
    </do_if>
    <do_if value="$destination? and $destination.exists">
      <set_value name="global.$GT_SarCrewTemplateScratch.{$destination}" exact="table[
        $Template = $gt_sar_crew_template,
        $Stable = $gt_sar_stable
      ]"/>
    </do_if>
    <signal_objects object="player.galaxy"
                    param="'gt_sar_pilot_transferred'"
                    param2="table[
                      $StrandedPilot = this,
                      $RescueShip = $destination,
                      $Spacesuit = $thisship,
                      $CrewTemplate = $gt_sar_crew_template,
                      $StableIdentity = $gt_sar_stable,
                      $RegistryKeyHint = $gt_sar_registry_key
                    ]"/>
  </replace>
  
</diff>
