<?xml version="1.0" encoding="utf-8"?>
<!-- MK4-2 supply scoring: global batch norm (raw / maxRaw), linear class slider multiply.
     Close sliders (max/min mult lt 5): norm x mult - demand tips races (BS=5 ST=4).
     Wide gap (max/min mult ge 5): class tier dominates - all BS beat all ST at BS=10 ST=1. -->
<aiscript name="lib.gt.mk42.score.trades" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="priorities" default="table[]" comment="table[$Buildstorage, $Stations, $Aux] - when set, class mult is resolved from $CustomerClass for per-ship cache re-score"/>
    <param name="priorityWares" default="[]"/>
    <param name="priorityScoreMultiplier" default="1" comment="1=no ware bonus; 2-10 additive on normalised base"/>
    <param name="playerSupplierPriority" default="5" comment="buyFromPlayer slider (0-10); self-normalised supplier-side score weight"/>
    <param name="aiSupplierPriority" default="5" comment="buyFromFaction slider (0-10); self-normalised supplier-side score weight"/>
    <param name="distancePenalty" default="0.5" comment="Runtime multiplier (UI 0-100% converted by caller)"/>
    <param name="diversifyByWare" default="false"/>
    <param name="priorityFirstInDiversify" default="false"/>
    <param name="debugchance" default="0"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bestTrade" exact="null"/>
      <set_value name="$bestScore" exact="0"/>
      <create_list name="$sortedTrades"/>
      <set_value name="$safePriorityWares" exact="if $priorityWares? and $priorityWares != null then $priorityWares else []"/>
      <set_value name="$wareMult" exact="if $priorityScoreMultiplier? then $priorityScoreMultiplier else 1"/>
      <do_if value="$wareMult lt 1"><set_value name="$wareMult" exact="1"/></do_if>
      <do_if value="$wareMult gt 10"><set_value name="$wareMult" exact="10"/></do_if>

      <set_value name="$supPlayerPrio" exact="if $playerSupplierPriority? then $playerSupplierPriority else 5"/>
      <set_value name="$supAiPrio" exact="if $aiSupplierPriority? then $aiSupplierPriority else 5"/>
      <set_value name="$supPrioMax" exact="[$supPlayerPrio, $supAiPrio].max"/>

      <do_if value="not $tradeList? or $tradeList.count == 0">
        <wait exact="1ms"/>
        <return value="table[$Found = false, $BestTrade = null, $BestScore = 0, $SortedTrades = $sortedTrades]"/>
      </do_if>

      <!-- Urgency-first raw score (matches lib.gt.mk42.tradematch). Prefer live cargo on
           SellStation so cache hits re-rank empty Grand Exchange ahead of fuller HQ. -->
      <set_value name="$rfDistPenalty" exact="if $distancePenalty? then $distancePenalty else 0.5"/>
      <do_all exact="$tradeList.count" counter="$rfi">
        <set_value name="$rfTrade" exact="$tradeList.{$rfi}"/>
        <do_if value="not $rfTrade?">
          <continue/>
        </do_if>
        <set_value name="$rfSellStation" exact="if $rfTrade.$SellStation? then $rfTrade.$SellStation else null"/>
        <set_value name="$rfWare" exact="if $rfTrade.$Ware? then $rfTrade.$Ware else null"/>
        <set_value name="$rfUrgency" exact="if $rfTrade.$urgencyScore? then $rfTrade.$urgencyScore else 0"/>
        <do_if value="$rfSellStation? and $rfSellStation.exists and $rfWare?">
          <set_value name="$rfTarget" exact="[$rfSellStation.cargo.{$rfWare}.target, 1].max"/>
          <set_value name="$rfCurrent" exact="$rfSellStation.cargo.{$rfWare}.count"/>
          <set_value name="$rfDeficit" exact="[$rfTarget - $rfCurrent, 0].max"/>
          <set_value name="$rfFillRatio" exact="if $rfTarget gt 0 then ($rfCurrent / $rfTarget) else 0"/>
          <set_value name="$rfDeficitPct" exact="if $rfTarget gt 0 then (($rfDeficit * 100) / $rfTarget) else 0"/>
          <set_value name="$rfBuildBonus" exact="0"/>
          <do_if value="@$rfSellStation.isclass.buildstorage">
            <set_value name="$rfBuildBonus" exact="20"/>
          </do_if>
          <set_value name="$rfCriticalBonus" exact="0"/>
          <do_if value="$rfFillRatio lt 0.10">
            <set_value name="$rfCriticalBonus" exact="15"/>
          </do_if>
          <set_value name="$rfUrgency" exact="$rfDeficitPct + $rfBuildBonus + $rfCriticalBonus"/>
          <set_value name="$rfTrade.$urgencyScore" exact="$rfUrgency"/>
        </do_if>
        <do_if value="$rfUrgency gt 0">
          <set_value name="$rfDemand" exact="if $rfTrade.$StationDemandMax? then $rfTrade.$StationDemandMax else (if $rfTrade.$Amount? then $rfTrade.$Amount else 0)"/>
          <set_value name="$rfAmountTie" exact="[$rfDemand, 500].min"/>
          <set_value name="$rfDist" exact="if $rfTrade.$Distance? then $rfTrade.$Distance else 0"/>
          <set_value name="$rfDistFactor" exact="1.0 + ($rfDist * $rfDistPenalty)"/>
          <do_if value="$rfDistFactor le 0">
            <set_value name="$rfDistFactor" exact="1.0"/>
          </do_if>
          <set_value name="$rfStationEmptyBoost" exact="0"/>
          <do_if value="$rfSellStation? and $rfSellStation.exists and @$rfSellStation.isclass.buildstorage and $rfSellStation.cargo.capacity.all gt 0">
            <set_value name="$rfStationFreeRatio" exact="$rfSellStation.cargo.free.all / $rfSellStation.cargo.capacity.all"/>
            <do_if value="$rfStationFreeRatio lt 0">
              <set_value name="$rfStationFreeRatio" exact="0"/>
            </do_if>
            <do_if value="$rfStationFreeRatio gt 1">
              <set_value name="$rfStationFreeRatio" exact="1"/>
            </do_if>
            <set_value name="$rfStationEmptyBoost" exact="($rfStationFreeRatio * 2000000)i"/>
          </do_if>
          <set_value name="$rfRaw" exact="(($rfUrgency * 10000) + $rfStationEmptyBoost + $rfAmountTie) / $rfDistFactor"/>
          <set_value name="$rfTrade.$baseSupplyScore" exact="$rfRaw"/>
        </do_if>
      </do_all>

      <set_value name="$maxRawGlobal" exact="0"/>
      <set_value name="$prioMultMin" exact="0"/>
      <set_value name="$prioMultMax" exact="0"/>
      <set_value name="$dominantClassTag" exact="'None'"/>
      <set_value name="$strictClassTier" exact="false"/>
      <set_value name="$classTierScale" exact="1000000"/>
      <do_if value="$priorities?">
        <set_value name="$prioScanMult" exact="if $priorities.$Buildstorage? then $priorities.$Buildstorage else 0"/>
        <do_if value="$prioScanMult gt 0">
          <do_if value="$prioMultMin == 0 or $prioScanMult lt $prioMultMin"><set_value name="$prioMultMin" exact="$prioScanMult"/></do_if>
          <do_if value="$prioScanMult gt $prioMultMax"><set_value name="$prioMultMax" exact="$prioScanMult"/><set_value name="$dominantClassTag" exact="'Buildstorage'"/></do_if>
        </do_if>
        <set_value name="$prioScanMult" exact="if $priorities.$Stations? then $priorities.$Stations else 0"/>
        <do_if value="$prioScanMult gt 0">
          <do_if value="$prioMultMin == 0 or $prioScanMult lt $prioMultMin"><set_value name="$prioMultMin" exact="$prioScanMult"/></do_if>
          <do_if value="$prioScanMult gt $prioMultMax"><set_value name="$prioMultMax" exact="$prioScanMult"/><set_value name="$dominantClassTag" exact="'Stations'"/></do_if>
        </do_if>
        <set_value name="$prioScanMult" exact="if $priorities.$Aux? then $priorities.$Aux else 0"/>
        <do_if value="$prioScanMult gt 0">
          <do_if value="$prioMultMin == 0 or $prioScanMult lt $prioMultMin"><set_value name="$prioMultMin" exact="$prioScanMult"/></do_if>
          <do_if value="$prioScanMult gt $prioMultMax"><set_value name="$prioMultMax" exact="$prioScanMult"/><set_value name="$dominantClassTag" exact="'Aux'"/></do_if>
        </do_if>
        <do_if value="$prioMultMin gt 0 and $prioMultMax ge ($prioMultMin * 5)">
          <set_value name="$strictClassTier" exact="true"/>
        </do_if>
      </do_if>

      <!-- Pass 1: global max raw $baseSupplyScore across enabled classes (shared 0..1 scale for cross-class compare). -->
      <do_all exact="$tradeList.count" counter="$maxi">
        <set_value name="$maxTrade" exact="$tradeList.{$maxi}"/>
        <set_value name="$maxClassTag" exact="if $maxTrade.$CustomerClass? then @$maxTrade.$CustomerClass else 'None'"/>
        <set_value name="$maxRaw" exact="0"/>
        <do_if value="$maxClassTag != 'None'">
          <do_if value="$maxTrade.$baseSupplyScore?">
            <set_value name="$maxRaw" exact="$maxTrade.$baseSupplyScore"/>
          </do_if>
        </do_if>
        <do_else>
          <set_value name="$maxRaw" exact="if $maxTrade.$baseSupplyScore? then $maxTrade.$baseSupplyScore else (if $maxTrade.$Score? then $maxTrade.$Score else 0)"/>
        </do_else>
        <set_value name="$maxClassMult" exact="if $maxTrade.$ClassMultiplier? then $maxTrade.$ClassMultiplier else 1"/>
        <do_if value="$priorities? and $maxClassTag != 'None'">
          <do_if value="$maxClassTag == 'Buildstorage'">
            <set_value name="$maxClassMult" exact="if $priorities.$Buildstorage? then $priorities.$Buildstorage else 0"/>
          </do_if>
          <do_elseif value="$maxClassTag == 'Stations'">
            <set_value name="$maxClassMult" exact="if $priorities.$Stations? then $priorities.$Stations else 0"/>
          </do_elseif>
          <do_elseif value="$maxClassTag == 'Aux'">
            <set_value name="$maxClassMult" exact="if $priorities.$Aux? then $priorities.$Aux else 0"/>
          </do_elseif>
        </do_if>
        <do_if value="$maxClassMult gt 0 and $maxRaw gt 0">
          <do_if value="$maxRaw gt $maxRawGlobal">
            <set_value name="$maxRawGlobal" exact="$maxRaw"/>
          </do_if>
        </do_if>
      </do_all>

      <!-- Pass 2: normBase = rawBase / maxRawGlobal; final = normBase x classMult (+ ware bonus on normBase). -->
      <do_all exact="$tradeList.count" counter="$i">
        <set_value name="$trade" exact="$tradeList.{$i}"/>
        <set_value name="$classTag" exact="if $trade.$CustomerClass? then @$trade.$CustomerClass else 'None'"/>
        <set_value name="$rawBase" exact="0"/>
        <do_if value="$classTag != 'None'">
          <do_if value="$trade.$baseSupplyScore?">
            <set_value name="$rawBase" exact="$trade.$baseSupplyScore"/>
          </do_if>
        </do_if>
        <do_else>
          <set_value name="$rawBase" exact="if $trade.$baseSupplyScore? then $trade.$baseSupplyScore else (if $trade.$Score? then $trade.$Score else 0)"/>
        </do_else>
        <set_value name="$classMult" exact="if $trade.$ClassMultiplier? then $trade.$ClassMultiplier else 1"/>
        <do_if value="$priorities? and $classTag != 'None'">
          <do_if value="$classTag == 'Buildstorage'">
            <set_value name="$classMult" exact="if $priorities.$Buildstorage? then $priorities.$Buildstorage else 0"/>
          </do_if>
          <do_elseif value="$classTag == 'Stations'">
            <set_value name="$classMult" exact="if $priorities.$Stations? then $priorities.$Stations else 0"/>
          </do_elseif>
          <do_elseif value="$classTag == 'Aux'">
            <set_value name="$classMult" exact="if $priorities.$Aux? then $priorities.$Aux else 0"/>
          </do_elseif>
        </do_if>
        <do_if value="$classMult le 0 or $rawBase le 0">
          <continue/>
        </do_if>
        <set_value name="$normBase" exact="if $maxRawGlobal gt 0 then ($rawBase / ($maxRawGlobal * 1.0)) else 0"/>
        <do_if value="$normBase le 0">
          <continue/>
        </do_if>
        <set_value name="$typeScore" exact="$normBase * $classMult"/>
        <set_value name="$wareBonus" exact="0"/>
        <do_if value="$wareMult gt 1 and $trade.$Ware? and $safePriorityWares.count gt 0">
          <do_all exact="$safePriorityWares.count" counter="$pw">
            <do_if value="$safePriorityWares.{$pw} == $trade.$Ware">
              <set_value name="$wareBonus" exact="$normBase * ($wareMult - 1)"/>
              <break/>
            </do_if>
          </do_all>
        </do_if>
        <set_value name="$fineScore" exact="$typeScore + $wareBonus"/>
        <do_if value="$strictClassTier">
          <set_value name="$finalScore" exact="($classMult * $classTierScale) + $fineScore"/>
        </do_if>
        <do_else>
          <set_value name="$finalScore" exact="$fineScore"/>
        </do_else>
        <do_if value="$supPrioMax gt 0">
          <set_value name="$supThisPrio" exact="if $trade.$BuyStation? and @$trade.$BuyStation.exists and @$trade.$BuyStation.isplayerowned then $supPlayerPrio else $supAiPrio"/>
          <set_value name="$supFactor" exact="$supThisPrio / ($supPrioMax * 1.0)"/>
          <set_value name="$finalScore" exact="$finalScore * $supFactor"/>
        </do_if>
        <set_value name="$trade.$baseSupplyScore" exact="$rawBase"/>
        <set_value name="$trade.$normBase" exact="$normBase"/>
        <set_value name="$trade.$ClassMultiplier" exact="$classMult"/>
        <set_value name="$trade.$finalScore" exact="$finalScore"/>
        <set_value name="$trade.$Score" exact="$finalScore"/>
        <append_to_list name="$sortedTrades" exact="$trade"/>
        <do_if value="$finalScore gt $bestScore">
          <set_value name="$bestScore" exact="$finalScore"/>
          <set_value name="$bestTrade" exact="$trade"/>
        </do_if>
      </do_all>

      <sort_list list="$sortedTrades" sortbyvalue="loop.element.$Score" sortdescending="true"/>

      <do_if value="$diversifyByWare and $sortedTrades.count gt 1">
        <create_list name="$diversifiedTrades"/>
        <set_value name="$diversifyPicked" exact="table[]"/>
        <set_value name="$usePriorityFirst" exact="$priorityFirstInDiversify and $safePriorityWares.count gt 0"/>
        <do_while value="$diversifiedTrades.count lt $sortedTrades.count">
          <set_value name="$diversifyRoundServed" exact="table[]"/>
          <set_value name="$diversifyRoundAdded" exact="0"/>
          <do_if value="$usePriorityFirst">
            <do_all exact="$safePriorityWares.count" counter="$dpp">
              <set_value name="$dpw" exact="$safePriorityWares.{$dpp}"/>
              <do_if value="not $dpw? or $dpw == null or $diversifyRoundServed.{$dpw}?">
                <continue/>
              </do_if>
              <do_all exact="$sortedTrades.count" counter="$dpwi">
                <do_if value="not $diversifyPicked.{$dpwi}? and $sortedTrades.{$dpwi}.$Ware? and $sortedTrades.{$dpwi}.$Ware == $dpw">
                  <append_to_list name="$diversifiedTrades" exact="$sortedTrades.{$dpwi}"/>
                  <set_value name="$diversifyPicked.{$dpwi}" exact="true"/>
                  <set_value name="$diversifyRoundServed.{$dpw}" exact="true"/>
                  <set_value name="$diversifyRoundAdded" operation="add"/>
                  <break/>
                </do_if>
              </do_all>
            </do_all>
          </do_if>
          <do_all exact="$sortedTrades.count" counter="$dwi">
            <do_if value="not $diversifyPicked.{$dwi}?">
              <set_value name="$dwTrade" exact="$sortedTrades.{$dwi}"/>
              <set_value name="$dwWare" exact="if $dwTrade.$Ware? then $dwTrade.$Ware else null"/>
              <do_if value="$dwWare? and not $diversifyRoundServed.{$dwWare}?">
                <append_to_list name="$diversifiedTrades" exact="$dwTrade"/>
                <set_value name="$diversifyPicked.{$dwi}" exact="true"/>
                <set_value name="$diversifyRoundServed.{$dwWare}" exact="true"/>
                <set_value name="$diversifyRoundAdded" operation="add"/>
              </do_if>
            </do_if>
          </do_all>
          <do_if value="$diversifyRoundAdded == 0">
            <break/>
          </do_if>
        </do_while>
        <do_all exact="$sortedTrades.count" counter="$dwt">
          <do_if value="not $diversifyPicked.{$dwt}?">
            <append_to_list name="$diversifiedTrades" exact="$sortedTrades.{$dwt}"/>
          </do_if>
        </do_all>
        <set_value name="$sortedTrades" exact="$diversifiedTrades"/>
        <set_value name="$bestTrade" exact="if $sortedTrades.count gt 0 then $sortedTrades.{1} else null"/>
        <set_value name="$bestScore" exact="if $bestTrade? and $bestTrade.$Score? then $bestTrade.$Score else 0"/>
      </do_if>

      <wait exact="1ms"/>
      <return value="table[$Found = ($bestTrade != null), $BestTrade = $bestTrade, $BestScore = $bestScore, $SortedTrades = $sortedTrades, $StrictClassTier = $strictClassTier, $DominantClassTag = $dominantClassTag, $PrioMultMin = $prioMultMin, $PrioMultMax = $prioMultMax]"/>
    </actions>
  </attention>
</aiscript>
