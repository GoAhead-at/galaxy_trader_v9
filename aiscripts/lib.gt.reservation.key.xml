<?xml version="1.0" encoding="utf-8"?>
<!-- Stable fleet-reservation key (ORS R1). Destination-collision: one customer ware slot.
     Format: $dest_<DeliveryStationId>_<ware.id> (leading $ required for X4 string table keys)
     Prefer stamped $DeliveryStationId / $Ware on trade/cache rows; else derive from SellStation / SellOffer. -->
<aiscript name="lib.gt.reservation.key" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="sellOffer" default="null" comment="Customer buy offer (GT $SellOffer) — destination demand"/>
    <param name="sellStation" default="null" comment="Delivery station / buildstorage when known"/>
    <param name="deliveryStationId" default="null" comment="Pre-stamped station idcode (cache/trade row)"/>
    <param name="ware" default="null" comment="Ware object when known"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$destId" exact="''"/>
      <do_if value="$deliveryStationId? and $deliveryStationId != null and $deliveryStationId != ''">
        <set_value name="$destId" exact="'' + $deliveryStationId"/>
      </do_if>
      <do_if value="$destId == '' and $sellStation? and @$sellStation.exists">
        <do_if value="@$sellStation.isclass.buildstorage and $sellStation.base? and @$sellStation.base.exists and @$sellStation.base.idcode != null">
          <set_value name="$destId" exact="'' + @$sellStation.base.idcode"/>
        </do_if>
        <do_elseif value="@$sellStation.idcode != null">
          <set_value name="$destId" exact="'' + @$sellStation.idcode"/>
        </do_elseif>
      </do_if>
      <do_if value="$destId == '' and $sellOffer? and @$sellOffer.exists">
        <set_value name="$offerBuyer" exact="null"/>
        <do_if value="$sellOffer.buyer? and @$sellOffer.buyer.exists">
          <set_value name="$offerBuyer" exact="@$sellOffer.buyer"/>
        </do_if>
        <do_elseif value="$sellOffer.owner? and @$sellOffer.owner.exists">
          <set_value name="$offerBuyer" exact="@$sellOffer.owner"/>
        </do_elseif>
        <do_if value="$offerBuyer? and @$offerBuyer.exists">
          <do_if value="@$offerBuyer.isclass.buildstorage and $offerBuyer.base? and @$offerBuyer.base.exists and @$offerBuyer.base.idcode != null">
            <set_value name="$destId" exact="'' + @$offerBuyer.base.idcode"/>
          </do_if>
          <do_elseif value="@$offerBuyer.idcode != null">
            <set_value name="$destId" exact="'' + @$offerBuyer.idcode"/>
          </do_elseif>
        </do_if>
      </do_if>

      <set_value name="$wareId" exact="''"/>
      <do_if value="$ware? and $ware != null and $ware.id?">
        <set_value name="$wareId" exact="'' + @$ware.id"/>
      </do_if>
      <do_if value="$wareId == '' and $sellOffer? and @$sellOffer.exists and $sellOffer.ware? and @$sellOffer.ware != null">
        <set_value name="$wareId" exact="'' + @$sellOffer.ware.id"/>
      </do_if>

      <do_if value="$destId == '' or $wareId == ''">
        <return value="''"/>
      </do_if>
      <return value="'$dest_' + $destId + '_' + $wareId"/>
    </actions>
  </attention>
</aiscript>
