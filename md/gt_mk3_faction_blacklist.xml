<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_MK3_FactionBlacklist" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../ORIGINAL_MODS_DO NOT_MODIFY/X4 Foundations/libraries/md.xsd">
  <cues>
    <cue name="RegisterGTActionGroup" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'Interact_Menu_API'" control="'reloaded'"/>
      </conditions>
      <actions>
        <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Id'" param="'gt_actions'"/>
        <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Text'" param="'GalaxyTrader'"/>
      </actions>
    </cue>

    <cue name="Init" instantiate="true">
      <conditions>
        <check_any>
          <event_game_loaded/>
          <event_player_created/>
        </check_any>
      </conditions>
      <actions>
        <do_if value="not global.$GT_MK3FactionBlacklist?">
          <set_value name="global.$GT_MK3FactionBlacklist" exact="table[]"/>
        </do_if>
        <do_if value="not global.$GT_MK3FactionBlacklist.$ShipSelections?">
          <set_value name="global.$GT_MK3FactionBlacklist.$ShipSelections" exact="table[]"/>
        </do_if>
        <signal_cue cue="RefreshAvailableFactions"/>
      </actions>
    </cue>

    <cue name="OnFactionChanged" instantiate="true">
      <conditions>
        <check_any>
          <event_faction_activated/>
          <event_faction_deactivated/>
        </check_any>
      </conditions>
      <actions>
        <signal_cue cue="RefreshAvailableFactions"/>
      </actions>
    </cue>

    <cue name="RefreshAvailableFactions" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="not global.$GT_MK3FactionBlacklist?">
          <set_value name="global.$GT_MK3FactionBlacklist" exact="table[]"/>
        </do_if>
        <set_value name="$available" exact="[]"/>
        <set_value name="$availableByFaction" exact="table[]"/>
        <do_for_each name="$faction" in="lookup.faction.list">
          <!-- Keep list practical for MK3 trade use:
               known, active, economic factions that currently allow player docking. -->
          <do_if value="$faction.isactive and $faction.knowntoplayer and $faction.iseconomic and $faction != faction.player and not $faction.isvisitor and $faction.hasrelation.dock.{faction.player}">
            <set_value name="$factionName" exact="$faction.name"/>
            <do_if value="$factionName != '' and not $availableByFaction.{$faction}?">
              <append_to_list name="$available" exact="$faction"/>
              <set_value name="$availableByFaction.{$faction}" exact="true"/>
            </do_if>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT-MK3-FBL] Available faction: ' + $faction + ' name=' + (if $factionName != '' then $factionName else '[empty-name]')" chance="100"/>
            </do_if>
          </do_if>
        </do_for_each>
        <set_value name="global.$GT_MK3FactionBlacklist.$Available" exact="$available"/>
      </actions>
    </cue>

    <cue name="AddMK3BlacklistAction" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Interact_Menu_API.Get_Actions"/>
      </conditions>
      <actions>
        <set_value name="$target" exact="event.param.$object"/>
        <do_if value="$target.isclass.{class.ship} and $target.isplayerowned">
          <!-- Fleet commander only: ship must run MK3 directly and have subordinates. -->
          <do_if value="$target.defaultorder? and @$target.defaultorder.id == 'GalaxyTraderMK3' and $target.allsubordinates? and @$target.allsubordinates.count gt 0">
            <signal_cue_instantly cue="md.Interact_Menu_API.Add_Action" param="table[
              $id = 'gt_mk3_faction_blacklist',
              $text = 'MK3 Faction Blacklist',
              $section = 'gt_actions',
              $callback = GT_MK3FactionBlacklistAction,
            ]"/>
          </do_if>
        </do_if>
      </actions>
    </cue>

    <cue name="GT_MK3FactionBlacklistAction" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$ship" exact="event.param.$object"/>
        <set_value name="$canOpen" exact="true"/>
        <do_if value="not $ship? or not $ship.exists">
          <show_notification text="'[GT] MK3 faction blacklist unavailable: ship missing.'" timeout="5s"/>
          <set_value name="$canOpen" exact="false"/>
        </do_if>

        <do_if value="$canOpen">
          <do_if value="not global.$GT_MK3FactionBlacklist? or not global.$GT_MK3FactionBlacklist.$Available?">
            <signal_cue cue="RefreshAvailableFactions"/>
          </do_if>

          <set_value name="global.$GT_MK3FactionBlacklist.$UIShip" exact="$ship"/>
          <signal_cue cue="PublishUIData"/>
          <raise_lua_event name="'gt.openMK3FactionBlacklist'" param="$ship.idcode"/>
        </do_if>
      </actions>
    </cue>

    <cue name="PublishUIData" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <set_value name="$ship" exact="@global.$GT_MK3FactionBlacklist.$UIShip"/>
        <set_value name="$canPublish" exact="true"/>
        <do_if value="not $ship? or not $ship.exists">
          <set_value name="$canPublish" exact="false"/>
        </do_if>

        <do_if value="$canPublish">
          <set_value name="$data" exact="''"/>
          <set_value name="$available" exact="if global.$GT_MK3FactionBlacklist.$Available? then global.$GT_MK3FactionBlacklist.$Available else []"/>
          <do_all exact="$available.count" counter="$i">
            <set_value name="$faction" exact="$available.{$i}"/>
            <set_value name="$factionName" exact="$faction.name"/>
            <set_value name="$factionShort" exact="$faction.shortname"/>
            <set_value name="$factionDisplay" exact="$factionName"/>
            <do_if value="$factionShort? and $factionShort != null and $factionShort != '' and $factionName != ''">
              <set_value name="$factionDisplay" exact="$factionShort + ' - ' + $factionName"/>
            </do_if>
            <do_elseif value="$faction.id? and $faction.id != null and $faction.id != '' and $factionName != ''">
              <set_value name="$factionDisplay" exact="$faction.id + ' - ' + $factionName"/>
            </do_elseif>
            <do_if value="$factionName == ''">
              <set_value name="$factionName" exact="'Faction ' + $i"/>
              <set_value name="$factionDisplay" exact="$factionName"/>
            </do_if>
            <set_value name="$selected" exact="'0'"/>
            <do_if value="global.$GT_MK3FactionBlacklist.$ShipSelections? and global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}? and global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}.{$faction}?">
              <set_value name="$selected" exact="'1'"/>
            </do_if>
            <set_value name="$entry" exact="$i + '||' + $factionDisplay + '||' + $selected"/>
            <do_if value="$data == ''">
              <set_value name="$data" exact="$entry"/>
            </do_if>
            <do_else>
              <set_value name="$data" exact="$data + '@@' + $entry"/>
            </do_else>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging and $i le 60">
              <debug_text text="'[GT-MK3-FBL] UI row ' + $i + ': faction=' + $faction + ' short=' + (if $factionShort? and $factionShort != '' then $factionShort else '-') + ' name=' + $factionName + ' selected=' + $selected" chance="100"/>
            </do_if>
          </do_all>

          <set_value name="player.entity.$GT_MK3FBL_Data" exact="$data"/>
          <set_value name="player.entity.$GT_MK3FBL_ShipName" exact="$ship.knownname"/>
          <set_value name="player.entity.$GT_MK3FBL_ShipCode" exact="$ship.idcode"/>
          <set_value name="player.entity.$GT_MK3FBL_Total" exact="$available.count"/>

          <raise_lua_event name="'gt.refreshMK3FactionBlacklist'" param="$ship.idcode"/>
        </do_if>
      </actions>
    </cue>

    <cue name="HandleToggleFaction" instantiate="true">
      <conditions>
        <event_ui_triggered screen="'GT_MK3FactionBlacklist'" control="'ToggleFaction'"/>
      </conditions>
      <actions>
        <set_value name="$idx" exact="0"/>
        <set_value name="$p" exact="event.param3"/>
        <do_if value="$p? and $p.$index?">
          <set_value name="$idx" exact="$p.$index"/>
        </do_if>
        <do_elseif value="event.param2? and event.param2.$index?">
          <set_value name="$idx" exact="event.param2.$index"/>
        </do_elseif>
        <set_value name="$ship" exact="@global.$GT_MK3FactionBlacklist.$UIShip"/>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-MK3-FBL] Toggle request param=' + event.param + ' param2=' + event.param2 + ' param3=' + event.param3 + ' resolved_idx=' + $idx" chance="100"/>
        </do_if>

        <do_if value="$idx gt 0 and $ship? and $ship.exists and global.$GT_MK3FactionBlacklist.$Available? and global.$GT_MK3FactionBlacklist.$Available.{$idx}?">
          <set_value name="$faction" exact="global.$GT_MK3FactionBlacklist.$Available.{$idx}"/>

          <do_if value="not global.$GT_MK3FactionBlacklist.$ShipSelections?">
            <set_value name="global.$GT_MK3FactionBlacklist.$ShipSelections" exact="table[]"/>
          </do_if>
          <do_if value="not global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}?">
            <set_value name="global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}" exact="table[]"/>
          </do_if>

          <do_if value="global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}.{$faction}?">
            <remove_value name="global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}.{$faction}"/>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT-MK3-FBL] Unblocked faction idx=' + $idx + ' faction=' + $faction" chance="100"/>
            </do_if>
          </do_if>
          <do_else>
            <set_value name="global.$GT_MK3FactionBlacklist.$ShipSelections.{$ship}.{$faction}" exact="true"/>
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[GT-MK3-FBL] Blocked faction idx=' + $idx + ' faction=' + $faction" chance="100"/>
            </do_if>
          </do_else>

          <!-- Refresh names immediately for this blacklist owner + subordinates.
               Do not use GT_CoreSystem.UpdateAllShipNames here: that path rebuilds names with
               legacy logic and can delay/omit CustomBlacklist tag updates until order cycle. -->
          <run_actions ref="md.GT_Ship_Management.Update_Ship_Name">
            <param name="ship" value="$ship"/>
            <param name="pilot" value="$ship.pilot"/>
            <param name="forceUpdate" value="true"/>
          </run_actions>
          <do_if value="$ship.allsubordinates? and $ship.allsubordinates.count gt 0">
            <do_all exact="$ship.allsubordinates.count" counter="$si">
              <set_value name="$sub" exact="$ship.allsubordinates.{$si}"/>
              <do_if value="$sub? and $sub.exists and $sub.isclass.ship">
                <run_actions ref="md.GT_Ship_Management.Update_Ship_Name">
                  <param name="ship" value="$sub"/>
                  <param name="pilot" value="$sub.pilot"/>
                  <param name="forceUpdate" value="true"/>
                </run_actions>
              </do_if>
            </do_all>
          </do_if>
          <signal_cue cue="PublishUIData"/>
        </do_if>
      </actions>
    </cue>
  </cues>
</mdscript>
