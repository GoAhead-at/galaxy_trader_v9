<?xml version="1.0" encoding="utf-8"?>
<mdscript name="GT_Buy_Tracking" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/md.xsd">
  <cues>
    <!-- ========================================
         GALAXY TRADER MK3 - BUY TRACKING SYSTEM
         Tracks purchase costs for profit calculation
         ======================================== -->
    
    <!-- Initialize cargo cost tracking on game load (NO DELAY - must be immediate) -->
    <cue name="InitializeCargoCostTracking" instantiate="true" version="1">
      <conditions>
        <check_any>
          <event_game_loaded/>
          <event_player_created/>
        </check_any>
      </conditions>
      <actions>
      </actions>
    </cue>
    
    <!-- Process Buy Completion Queue -->
    <!-- Listen for signal instead of polling -->
    <cue name="ProcessBuyCompletion" instantiate="true">
      <conditions>
        <event_object_signalled object="player.galaxy" param="'GT_BuyComplete'"/>
        <!-- Only process if initialization has completed (table exists) -->
        <check_value value="global.$GT_CargoCostTracking?"/>
      </conditions>
      <actions>
        <!-- Ensure table exists before processing (handles cue instances created before initialization) -->
        <do_if value="not global.$GT_CargoCostTracking?">
          <set_value name="global.$GT_CargoCostTracking" exact="table[]"/>
        </do_if>
        
        <do_if value="global.$GT_BuyCompleteQueue? and global.$GT_BuyCompleteQueue.count gt 0">
          <do_while value="global.$GT_BuyCompleteQueue.count gt 0">
            <set_value name="$data" exact="global.$GT_BuyCompleteQueue.{1}"/>
            <remove_from_list name="global.$GT_BuyCompleteQueue" exact="$data"/>
            <set_value name="$ship" exact="@$data.$Ship"/>
            
            <do_if value="not $ship? or $ship == null">
              <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                <debug_text text="'[GT-BuyTracking] Skipping queue entry with missing ship payload'" chance="100"/>
              </do_if>
              <continue/>
            </do_if>
            
            <!-- Skip if ship no longer registered -->
            <do_if value="not global.$GT_Ships.{$ship}?">
              <!-- <debug_text text="'[GT-BuyTracking] ⚠ Skipping buy tracking for unregistered ship: ' + $ship.idcode" chance="100"/> -->
              <continue/>
            </do_if>
            
            <!-- Initialize ship's cargo cost tracking if not exists -->
            <do_if value="not global.$GT_CargoCostTracking.{$ship}?">
              <set_value name="global.$GT_CargoCostTracking.{$ship}" exact="table[]"/>
            </do_if>
            
            <!-- Calculate total purchase cost for this buy -->
            <set_value name="$ware" exact="$data.$ware"/>
            <set_value name="$amount" exact="$data.$amount"/>
            <set_value name="$unitPrice" exact="$data.$unitPrice"/>
            <set_value name="$totalCost" exact="$unitPrice * $amount"/>
            
            <!-- Track or update cargo cost for this ware -->
            <do_if value="not global.$GT_CargoCostTracking.{$ship}.{$ware}?">
              <!-- First purchase of this ware -->
              <set_value name="global.$GT_CargoCostTracking.{$ship}.{$ware}" exact="table[
                $Amount = $amount,
                $TotalCost = $totalCost,
                $LastUpdate = player.age
              ]"/>
            </do_if>
            <do_else>
              <!-- Additional purchase - add to existing (weighted average handled automatically) -->
              <set_value name="global.$GT_CargoCostTracking.{$ship}.{$ware}.$Amount" 
                          exact="global.$GT_CargoCostTracking.{$ship}.{$ware}.$Amount + $amount"/>
              <set_value name="global.$GT_CargoCostTracking.{$ship}.{$ware}.$TotalCost" 
                          exact="global.$GT_CargoCostTracking.{$ship}.{$ware}.$TotalCost + $totalCost"/>
              <set_value name="global.$GT_CargoCostTracking.{$ship}.{$ware}.$LastUpdate" exact="player.age"/>
            </do_else>
            
            <!-- Use safe operators for debug text to prevent errors if table structure is invalid -->
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <set_value name="$trackedAmount" exact="@global.$GT_CargoCostTracking.{$ship}.{$ware}.$Amount"/>
              <set_value name="$trackedCost" exact="@global.$GT_CargoCostTracking.{$ship}.{$ware}.$TotalCost"/>
              <debug_text text="'[GT-BuyTracking] BUY tracked: ' + $ship.idcode + ' bought ' + $amount + ' ' + $ware.name + 
                                ' for ' + ($totalCost / 100) + ' Cr (Total tracked: ' + 
                                (if $trackedAmount? then $trackedAmount else 0) + ' units, ' + 
                                (if $trackedCost? then ($trackedCost / 100) else 0) + ' Cr)'" 
                          chance="100"/>
            </do_if>

            <!-- Buy-completion sell-leg gate: inspect the queued sell WITHOUT cancelling first.
                 Cancel and route to disposal only when the buyer offer is universally dead (.available false
                 or partner gone). Never cancel for offeramount.{ship}==0 while .available is true - that is
                 transient fleet saturation and our pending TradePerform still holds the reservation. -->
            <set_value name="$gateHasPendingSell" exact="false"/>
            <do_if value="$ship.tradeorders? and $ship.tradeorders.count gt 0">
              <do_all exact="$ship.tradeorders.count" counter="$gpi">
                <set_value name="$gateOrder" exact="$ship.tradeorders.{$gpi}"/>
                <do_if value="$gateOrder? and $gateOrder != $ship.order and $gateOrder.$tradedeal?">
                  <do_if value="not @$gateOrder.$tradedeal.seller.exists and $gateOrder.$tradedeal.ware == $ware">
                    <set_value name="$gateHasPendingSell" exact="true"/>
                    <break/>
                  </do_if>
                </do_if>
              </do_all>
            </do_if>

            <do_if value="$gateHasPendingSell">
              <set_value name="$gateSellStation" exact="null"/>
              <do_if value="global.$GT_ActiveTrade? and global.$GT_ActiveTrade.{$ship}? and global.$GT_ActiveTrade.{$ship}.$SellStation?">
                <set_value name="$gateSellStation" exact="global.$GT_ActiveTrade.{$ship}.$SellStation"/>
              </do_if>
              <do_if value="not $gateSellStation? or not $gateSellStation.exists">
                <do_if value="$ship.tradeorders? and $ship.tradeorders.count gt 0">
                  <do_all exact="$ship.tradeorders.count" counter="$gpsi">
                    <set_value name="$gatePendingOrder" exact="$ship.tradeorders.{$gpsi}"/>
                    <do_if value="$gatePendingOrder? and $gatePendingOrder.$tradedeal? and not @$gatePendingOrder.$tradedeal.seller.exists and $gatePendingOrder.$tradedeal.ware == $ware">
                      <do_if value="$gatePendingOrder.$tradedeal.owner? and $gatePendingOrder.$tradedeal.owner.exists">
                        <set_value name="$gateSellStation" exact="$gatePendingOrder.$tradedeal.owner"/>
                      </do_if>
                      <break/>
                    </do_if>
                  </do_all>
                </do_if>
              </do_if>

              <set_value name="$gateSellDead" exact="false"/>
              <set_value name="$gateSellStationName" exact="if $gateSellStation? then @$gateSellStation.knownname else 'Unknown'"/>
              <do_if value="not $gateSellStation? or not $gateSellStation.exists or not $gateSellStation.isoperational">
                <set_value name="$gateSellDead" exact="true"/>
              </do_if>
              <do_else>
                <find_buy_offer buyer="$gateSellStation" wares="$ware" tradepartner="$ship" result="$gateSellOffer"/>
                <do_if value="not $gateSellOffer.available">
                  <set_value name="$gateSellDead" exact="true"/>
                </do_if>
                <do_elseif value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                  <set_value name="$gateOfferAmt" exact="@$gateSellOffer.offeramount.{$ship}"/>
                  <debug_text text="'[GT-SellGate] ' + $ship.idcode + ': queued sell leg still valid after buy (' + $ware.name + ' to ' + $gateSellStationName + ', offeramount.ship=' + (if $gateOfferAmt? then $gateOfferAmt else 'null') + ')'" chance="100"/>
                </do_elseif>
              </do_else>

              <do_if value="$gateSellDead">
                <set_value name="$gateCancelled" exact="0"/>
                <do_if value="$ship.tradeorders? and $ship.tradeorders.count gt 0">
                  <do_all exact="$ship.tradeorders.count" counter="$gci">
                    <set_value name="$gateCancelOrder" exact="$ship.tradeorders.{$gci}"/>
                    <do_if value="$gateCancelOrder? and $gateCancelOrder != $ship.order and $gateCancelOrder.$tradedeal?">
                      <do_if value="not @$gateCancelOrder.$tradedeal.seller.exists and $gateCancelOrder.$tradedeal.ware == $ware">
                        <cancel_order order="$gateCancelOrder"/>
                        <set_value name="$gateCancelled" operation="add"/>
                      </do_if>
                    </do_if>
                  </do_all>
                </do_if>

                <run_actions ref="md.GT_Libraries_General.GT_ClearPendingTradeData">
                  <param name="ship" value="$ship"/>
                </run_actions>
                <run_actions ref="md.GT_Libraries_General.GT_ClearUICreditsDueForShip">
                  <param name="ship" value="$ship"/>
                </run_actions>

                <signal_objects object="$ship" param="'GT_Trade_Failed'" param2="table[
                  $Ship = $ship,
                  $Reason = 'ERR_TRADEOFFER_INVALID',
                  $FailureText = null,
                  $Partner = $gateSellStation,
                  $IsBuying = false,
                  $ReasonType = 'MARKET',
                  $PathBlocked = false,
                  $ShouldTryNext = false,
                  $Timestamp = player.age
                ]" delay="1ms"/>

                <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                  <debug_text text="'[GT-SellGate] ' + $ship.idcode + ': sell leg dead after buy - cancelled ' + $gateCancelled + ' queued sell order(s) for ' + $ware.name + ' (partner: ' + $gateSellStationName + ') - routing to cargo disposal'" chance="100"/>
                </do_if>
              </do_if>
            </do_if>
          </do_while>
        </do_if>
      </actions>
    </cue>
    
    <!-- Event-driven cleanup: Ship destroyed -->
    <cue name="CleanupOnShipDestroyed" instantiate="true">
      <conditions>
        <event_object_destroyed object="player.entity"/>
      </conditions>
      <actions>
        <set_value name="$ship" exact="event.object"/>
        
        <!-- Only cleanup if this was a registered GT ship with cargo tracking -->
        <do_if value="global.$GT_CargoCostTracking? and global.$GT_CargoCostTracking.{$ship}?">
          <remove_value name="global.$GT_CargoCostTracking.{$ship}"/>
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[GT-BuyTracking] Ship destroyed - cleared cargo tracking: ' + $ship.idcode + ' (Pilot may have survived via ejection - pilot data preserved)'" chance="100"/>
          </do_if>
        </do_if>
      </actions>
    </cue>
    
  </cues>
</mdscript>
