<?xml version="1.0" encoding="utf-8"?>
<diff>
  <!-- GalaxyTrader: capital miners exit collect when a field depletes mid-run with partial cargo.
       Vanilla loops until the ware bay is full; GT miners must return nogatherrate so the routine
       can sell stale cargo and GalaxyMiner can re-score to the next demand ware. -->

  <add sel="//aiscript[@name='mining.collect.ship.capital']/attention[@min='visible']/actions/set_value[@name='$moving']" pos="after">
    <set_value name="$gtEmptyScanStreak" exact="0"/>
  </add>

  <add sel="//aiscript[@name='mining.collect.ship.capital']/attention[@min='visible']/actions/do_while/set_command_action" pos="before">
    <do_if value="$gtDepletedExit?">
      <break/>
    </do_if>
  </add>

  <add sel="//aiscript[@name='mining.collect.ship.capital']/attention[@min='visible']/actions/do_while/do_if[@value='not $firing?']/wait" pos="before">
    <do_if value="global.$GT_Ships? and global.$GT_Ships.{this.assignedcontrolled}? and this.ship.cargo.{$ware}.count gt 0 and this.ship.cargo.{$ware}.free gt 0">
      <do_if value="(not @$target.exists or not $target.exists) and (not $pickup.count) and (not @$asteroids.count)">
        <set_value name="$gtEmptyScanStreak" exact="$gtEmptyScanStreak + 1"/>
        <debug_text text="'[GT-MiningCollect] ' + this.assignedcontrolled.idcode + ': depleted field scan streak=' + $gtEmptyScanStreak + ' ware=' + $ware.name + ' cargo=' + this.ship.cargo.{$ware}.count" chance="$debugchance"/>
        <do_if value="$gtEmptyScanStreak ge 3">
          <set_value name="$gtDepletedExit" exact="true"/>
          <set_value name="this.assignedcontrolled.$gtDepletedMiningWare" exact="$ware"/>
        </do_if>
      </do_if>
      <do_else>
        <set_value name="$gtEmptyScanStreak" exact="0"/>
      </do_else>
    </do_if>
  </add>

  <replace sel="//aiscript[@name='mining.collect.ship.capital']/attention[@min='visible']/actions/set_value[@name='$returnvalue'][@exact=&quot;'cargofull'&quot;]">
    <do_if value="$gtDepletedExit?">
      <set_value name="$returnvalue" exact="'nogatherrate'"/>
    </do_if>
    <do_else>
      <set_value name="$returnvalue" exact="'cargofull'"/>
    </do_else>
  </replace>
</diff>
