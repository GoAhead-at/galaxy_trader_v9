<?xml version="1.0" encoding="utf-8"?>

<aiscript name="order.gt.idlepark" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="3">

  <order id="GTIdlePark" name="{77000, 1096}" description="{77000, 1097}" category="navigation" infinite="false" canplayercancel="true">

    <params>

      <param name="home" type="object" text="{77000, 1002}" comment="{77000, 1020}">

        <input_param name="class" value="[class.station,class.sector]"/>

      </param>

      <param name="debugchance" default="0" type="number" text="{1001, 9074}" comment="{1001, 9075}">

        <input_param name="min" value="0"/>

        <input_param name="max" value="100"/>

      </param>

    </params>

    <requires>

      <match shiptype="shiptype.lasertower" negate="true"/>

    </requires>

    <location object="$home" condition="@$home.exists"/>

  </order>



  <interrupts>

    <handler ref="TargetInvalidHandler"/>

    <handler ref="AttackHandler"/>

  </interrupts>



  <init>

    <set_order_syncpoint_reached order="this.ship.order"/>

    <set_value name="this.$idleParkOrder" exact="this.ship.order"/>

    <set_value name="this.$idleParkDockHandoff" exact="false"/>

    <set_command command="command.wait"/>

    <set_command_action commandaction="commandaction.standingby"/>

    <set_value name="$releaseMinutes" exact="1"/>

    <do_if value="global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$Fleet?">

      <do_all exact="global.$GT_GlobalSettings.$Fleet.keys.count" counter="$fki">

        <set_value name="$fleetKey" exact="global.$GT_GlobalSettings.$Fleet.keys.{$fki}"/>

        <do_if value="$fleetKey == '$IdleParkingReleaseMinutes'">

          <set_value name="$releaseMinutes" exact="[[global.$GT_GlobalSettings.$Fleet.{$fleetKey}, 0].max, 60].min"/>

        </do_if>

      </do_all>

    </do_if>

    <do_if value="not global.$GT_IdleParkingHold?">

      <set_value name="global.$GT_IdleParkingHold" exact="table[]"/>

    </do_if>

    <do_if value="not global.$GT_IdleParkingHoldUntil?">

      <set_value name="global.$GT_IdleParkingHoldUntil" exact="table[]"/>

    </do_if>

    <do_if value="not global.$GT_IdleParkingDockedSince?">

      <set_value name="global.$GT_IdleParkingDockedSince" exact="table[]"/>

    </do_if>

    <do_if value="not global.$GT_IdleParkingReleased?">

      <set_value name="global.$GT_IdleParkingReleased" exact="table[]"/>

    </do_if>

    <set_value name="global.$GT_IdleParkingHold.{this.ship}" exact="true"/>

    <do_if value="$releaseMinutes gt 0">

      <set_value name="global.$GT_IdleParkingHoldUntil.{this.ship}" exact="player.age + $releaseMinutes * 1min"/>

    </do_if>

    <do_else>

      <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">

        <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>

      </do_if>

    </do_else>

  </init>



  <patch sinceversion="2">

    <do_if value="not global.$GT_IdleParkingHold?">

      <set_value name="global.$GT_IdleParkingHold" exact="table[]"/>

    </do_if>

    <do_if value="not global.$GT_IdleParkingHoldUntil?">

      <set_value name="global.$GT_IdleParkingHoldUntil" exact="table[]"/>

    </do_if>

    <do_if value="not global.$GT_IdleParkingHold.{this.ship}?">

      <set_value name="global.$GT_IdleParkingHold.{this.ship}" exact="true"/>

      <set_value name="global.$GT_IdleParkingHoldUntil.{this.ship}" exact="player.age + 6h"/>

    </do_if>

  </patch>



  <attention min="unknown">

    <actions>

      <do_if value="not $home? or not $home.exists">

        <set_command_action commandaction="commandaction.orderfailed"/>

        <remove_value name="global.$GT_IdleParkingHold.{this.ship}"/>

        <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">

          <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>

        </do_if>

        <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>

        <return/>

      </do_if>



      <run_script name="'lib.gt.idlepark'" result="$parkResolve">
        <param name="handoffMode" value="'resolve_park_station'"/>
        <param name="handoffShip" value="this.ship"/>
        <param name="home" value="$home"/>
        <param name="debugchance" value="$debugchance"/>
      </run_script>
      <set_value name="$parkStation" exact="if $parkResolve.$ParkStation? then $parkResolve.$ParkStation else null"/>
      <set_value name="$parkSector" exact="if $parkResolve.$ParkSector? then $parkResolve.$ParkSector else null"/>

      <do_if value="$parkStation? and $parkStation != null and $parkStation.exists">

        <set_value name="$alreadyDocked" exact="(this.ship.dock and this.ship.dock.container == $parkStation) or (this.ship.parkedat and ((this.ship.parkedat == $parkStation) or this.ship.parkedat.hascontext.{$parkStation}))"/>

        <do_if value="not $alreadyDocked">

          <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': docking at ' + $parkStation.knownname + ' (trader keeps searching)'" chance="$debugchance"/>

          <set_value name="this.$idleParkDockHandoff" exact="true"/>

          <create_order name="$dockOrder" id="'DockAndWait'" object="this.ship" immediate="true">

            <param name="destination" value="$parkStation"/>

            <param name="building" value="false"/>

            <param name="trading" value="true"/>

            <param name="dockfollowers" value="false"/>

            <param name="allowplayeronly" value="true"/>

            <param name="callerid" value="this.$idleParkOrder"/>

            <param name="debugchance" value="$debugchance"/>

          </create_order>



          <wait>

            <interrupt>

              <conditions>

                <event_object_order_ready object="this.ship" order="$dockOrder"/>

              </conditions>

            </interrupt>

          </wait>

          <set_value name="this.$idleParkDockHandoff" exact="false"/>



          <set_value name="$isDockedAtPark" exact="(this.ship.dock and this.ship.dock.container == $parkStation) or (this.ship.parkedat and ((this.ship.parkedat == $parkStation) or this.ship.parkedat.hascontext.{$parkStation}))"/>

          <do_if value="not $isDockedAtPark">

            <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': dock attempt did not complete at park station - releasing for search retry'" chance="$debugchance"/>

            <remove_value name="global.$GT_IdleParkingHold.{this.ship}"/>

            <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">

              <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>

            </do_if>

            <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>

            <return/>

          </do_if>

        </do_if>

        <do_else>

          <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': already docked at ' + $parkStation.knownname + ' (trader keeps searching)'" chance="$debugchance"/>

        </do_else>



        <do_if value="not global.$GT_IdleParkingDockedSince.{this.ship}?">

          <set_value name="global.$GT_IdleParkingDockedSince.{this.ship}" exact="player.age"/>

        </do_if>



        <set_command command="command.wait" param="$parkStation"/>

        <set_command_action commandaction="commandaction.standingby"/>

        <!-- Hold globals stay active; GalaxyTrader main_loop keeps searching (MK1 return-home pattern). -->
        <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': docked at ' + $parkStation.knownname + ' - trader keeps searching'" chance="$debugchance"/>

        <return/>

      </do_if>



      <do_if value="$parkSector? and $parkSector.exists">

        <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': no dockable station in home sector - hold cleared for search retry'" chance="$debugchance"/>

      </do_if>



      <remove_value name="global.$GT_IdleParkingHold.{this.ship}"/>

      <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">

        <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>

      </do_if>

      <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>

      <set_command_action commandaction="commandaction.orderfailed"/>

    </actions>

  </attention>



  <on_abort>

    <!-- Parent order still queued while DockAndWait runs — not a player cancel. -->
    <set_value name="$isOrderPause" exact="false"/>

    <do_if value="this.$idleParkOrder? and this.$idleParkOrder.exists">

      <set_value name="$isOrderPause" exact="true"/>

    </do_if>

    <do_if value="not $isOrderPause and this.$idleParkDockHandoff? and this.$idleParkDockHandoff">

      <set_value name="$isOrderPause" exact="true"/>

    </do_if>

    <do_if value="not $isOrderPause and this.ship.order? and @this.ship.order.id == 'DockAndWait' and this.ship.order.$callerid? and @this.ship.order.$callerid.id == 'GTIdlePark'">

      <set_value name="$isOrderPause" exact="true"/>

    </do_if>

    <do_if value="not $isOrderPause and this.ship.orders.count gt 0">

      <do_all exact="this.ship.orders.count" counter="$ipoi">

        <set_value name="$ipOrder" exact="this.ship.orders.{$ipoi}"/>

        <do_if value="@$ipOrder.id == 'DockAndWait' and $ipOrder.$callerid? and @$ipOrder.$callerid.id == 'GTIdlePark'">

          <set_value name="$isOrderPause" exact="true"/>

          <break/>

        </do_if>

      </do_all>

    </do_if>

    <do_if value="$isOrderPause">

      <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': on_abort skipped (order still active)'" chance="$debugchance"/>

    </do_if>

    <do_elseif value="global.$GT_IdleParkingHold? and global.$GT_IdleParkingHold.{this.ship}?">

      <remove_value name="global.$GT_IdleParkingHold.{this.ship}"/>

      <do_if value="global.$GT_IdleParkingHoldUntil? and global.$GT_IdleParkingHoldUntil.{this.ship}?">

        <remove_value name="global.$GT_IdleParkingHoldUntil.{this.ship}"/>

      </do_if>

      <do_if value="global.$GT_IdleParkingDockedSince? and global.$GT_IdleParkingDockedSince.{this.ship}?">

        <remove_value name="global.$GT_IdleParkingDockedSince.{this.ship}"/>

      </do_if>

      <set_value name="global.$GT_IdleParkingReleased.{this.ship}" exact="true"/>

      <debug_text text="'[GT-IdlePark] ' + this.ship.idcode + ': idle parking cancelled - resuming search'" chance="$debugchance"/>

      <do_if value="this.ship.dock or this.ship.parkedat">

        <create_order object="this.ship" id="'Undock'" immediate="true"/>

      </do_if>

    </do_elseif>

  </on_abort>

</aiscript>
