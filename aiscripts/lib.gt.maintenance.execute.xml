<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.maintenance.execute" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Unified GT maintenance executor (MK3/MK4-2 reference pattern).
    Caller signals GT_DoMaintenance (MD prepares repair/resupply tables), then this library
    creates Repair / Equip build orders and waits for GT_Maintenance_Complete.
    Sets this.$maintenance_transition on the caller while child maintenance orders are active.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="logPrefix" default="'GT-AI'"/>
    <param name="mdPrepareWait" default="0.5s"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists">
        <return/>
      </do_if>

      <run_script name="'lib.gt.reroute.clear'">
        <param name="ship" value="$ship"/>
        <param name="logPrefix" value="$logPrefix"/>
      </run_script>

      <!-- If MD already issued maintenance and is waiting for repair/equipment completion, do not
           re-signal GT_DoMaintenance or recreate orders from stale global.$GT_RepairOrders tables
           (repair leg may be done while equipment is still in flight). -->
      <set_value name="$maintenanceInFlight" exact="false"/>
      <do_if value="global.$GT_MaintenanceOrders? and global.$GT_MaintenanceOrders.{$ship}?">
        <set_value name="$inFlightWaitingEquipment" exact="@global.$GT_MaintenanceOrders.{$ship}.$WaitingForEquipment"/>
        <set_value name="$inFlightWaitingRepair" exact="@global.$GT_MaintenanceOrders.{$ship}.$WaitingForRepair"/>
        <do_if value="$inFlightWaitingEquipment or $inFlightWaitingRepair">
          <set_value name="$maintenanceInFlight" exact="true"/>
        </do_if>
      </do_if>

      <do_if value="not $maintenanceInFlight">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Requesting maintenance check'" chance="100"/>
        </do_if>

        <signal_objects object="player.galaxy" param="'GT_DoMaintenance'" param2="$ship"/>
        <wait exact="$mdPrepareWait"/>
      </do_if>
      <do_elseif value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Maintenance already in flight (WaitingForEquipment=' + $inFlightWaitingEquipment + ', WaitingForRepair=' + $inFlightWaitingRepair + ') - skipping new DoMaintenance'" chance="100"/>
      </do_elseif>

      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <set_value name="$diagHasRepair" exact="global.$GT_RepairOrders? and global.$GT_RepairOrders.{$ship}?"/>
        <set_value name="$diagHasResupply" exact="global.$GT_ResupplyOrders? and global.$GT_ResupplyOrders.{$ship}?"/>
        <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Maintenance check result: RepairOrder=' + $diagHasRepair + ', ResupplyOrder=' + $diagHasResupply + ', HullPct=' + $ship.hullpercentage + '%, InFlight=' + $maintenanceInFlight" chance="100"/>
      </do_if>

      <do_if value="not $maintenanceInFlight and global.$GT_RepairOrders? and global.$GT_RepairOrders.{$ship}?">
        <set_value name="$repairData" exact="global.$GT_RepairOrders.{$ship}"/>
        <set_value name="$repairStation" exact="$repairData.$Station"/>

        <set_value name="$canDockRepair" exact="false"/>
        <do_if value="@$repairStation.exists">
          <run_script name="'lib.gt.dockcheck'" result="$repairDockResult">
            <param name="ship" value="$ship"/>
            <param name="station" value="$repairStation"/>
            <param name="purpose" value="'service_ai'"/>
          </run_script>
          <set_value name="$canDockRepair" exact="$repairDockResult.$CanDock"/>
          <do_if value="not $canDockRepair">
            <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
              <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Repair docking check FAILED: ' + @$repairStation.knownname +
                '\n  Sector: ' + @$repairStation.sector.knownname +
                '\n  Reason: No dock available for ship size ' + $ship.docksize +
                '\n  -> Clearing repair order and continuing...'"
                chance="100"/>
            </do_if>
            <remove_value name="global.$GT_RepairOrders.{$ship}"/>
          </do_if>
        </do_if>

        <!-- Hull may already be healthy if repair finished but global.$GT_RepairOrders was not cleared yet. -->
        <set_value name="$hullAlreadyHealthy" exact="false"/>
        <do_if value="@global.$GT_GlobalSettings.$AutoRepair.$Enabled">
          <set_value name="$repairThreshold" exact="@global.$GT_GlobalSettings.$AutoRepair.$HullThreshold"/>
          <do_if value="$ship.hullpercentage ge $repairThreshold">
            <set_value name="$hullAlreadyHealthy" exact="true"/>
          </do_if>
        </do_if>
        <do_if value="$hullAlreadyHealthy">
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Hull already at ' + $ship.hullpercentage + '% (threshold ' + $repairThreshold + '%) - skipping stale repair order'" chance="100"/>
          </do_if>
          <remove_value name="global.$GT_RepairOrders.{$ship}"/>
        </do_if>
        <do_elseif value="$canDockRepair">
          <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Creating Repair order at ' + $repairStation.knownname" chance="100"/>
          <set_value name="this.$maintenance_transition" exact="true"/>
          <create_order object="$ship" id="'Repair'" immediate="false" priority="true">
            <param name="destination" value="$repairStation"/>
            <param name="hullpercent" value="100"/>
            <param name="repairall" value="true"/>
            <param name="acceptedcost" value="$repairData.$AcceptedCost"/>
            <param name="urgent" value="false"/>
            <param name="internalorder" value="true"/>
          </create_order>
          <remove_value name="global.$GT_RepairOrders.{$ship}"/>
          <run_script name="'lib.gt.attention.refresh_ship_name'">
            <param name="ship" value="$ship"/>
            <param name="force" value="true"/>
          </run_script>
        </do_elseif>
      </do_if>

      <do_if value="not $maintenanceInFlight and global.$GT_ResupplyOrders? and global.$GT_ResupplyOrders.{$ship}?">
        <set_value name="$resupplyData" exact="global.$GT_ResupplyOrders.{$ship}"/>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': CREATING RESUPPLY BUILD ORDER at ' + $resupplyData.$Station.knownname" chance="100"/>
        </do_if>

        <set_value name="$buildSuccessful" exact="false"/>
        <set_value name="$ammoTableKeys" exact="@$resupplyData.$AmmoTable.keys"/>
        <set_value name="$ammoTableCount" exact="@$ammoTableKeys.count"/>
        <set_value name="$unitTableKeys" exact="@$resupplyData.$UnitTable.keys"/>
        <set_value name="$unitTableCount" exact="@$unitTableKeys.count"/>

        <do_if value="$ammoTableCount? or $unitTableCount?">
          <set_value name="$resupplyStation" exact="$resupplyData.$Station"/>
          <set_value name="$canDockResupply" exact="false"/>
          <do_if value="@$resupplyStation.exists">
            <run_script name="'lib.gt.dockcheck'" result="$resupplyDockResult">
              <param name="ship" value="$ship"/>
              <param name="station" value="$resupplyStation"/>
              <param name="purpose" value="'service_ai'"/>
            </run_script>
            <set_value name="$canDockResupply" exact="$resupplyDockResult.$CanDock"/>
            <do_if value="not $canDockResupply">
              <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Resupply docking check FAILED: ' + @$resupplyStation.knownname +
                  '\n  Sector: ' + @$resupplyStation.sector.knownname +
                  '\n  Reason: No dock available for ship size ' + $ship.docksize +
                  '\n  -> Clearing resupply order and continuing...'"
                  chance="100"/>
              </do_if>
              <remove_value name="global.$GT_ResupplyOrders.{$ship}"/>
            </do_if>
          </do_if>

          <do_if value="$canDockResupply">
            <set_value name="this.$maintenance_transition" exact="true"/>
            <add_build_to_modify_ship
                object="$resupplyStation"
                buildobject="$ship"
                ammo="$resupplyData.$AmmoTable"
                units="$resupplyData.$UnitTable"
                immediate="false"
                internal="true"
                result="$buildSuccessful"/>

            <do_if value="not $buildSuccessful">
              <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': FAILED to create build order at ' + $resupplyStation.knownname" chance="100"/>
              </do_if>
              <remove_value name="global.$GT_ResupplyOrders.{$ship}"/>
              <do_if value="not global.$GT_MaintenanceFailedResupply?">
                <set_value name="global.$GT_MaintenanceFailedResupply" exact="table[]"/>
              </do_if>
              <set_value name="global.$GT_MaintenanceFailedResupply.{$ship}" exact="player.age + 300s"/>
              <do_if value="global.$GT_MaintenanceOrders? and global.$GT_MaintenanceOrders.{$ship}?">
                <remove_value name="global.$GT_MaintenanceOrders.{$ship}"/>
              </do_if>
              <signal_objects object="$ship" param="'GT_Maintenance_Complete'"/>
            </do_if>
          </do_if>
        </do_if>
        <do_else>
          <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
            <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Empty resupply shopping list - clearing tracking'" chance="100"/>
          </do_if>
          <remove_value name="global.$GT_ResupplyOrders.{$ship}"/>
          <do_if value="global.$GT_MaintenanceOrders? and global.$GT_MaintenanceOrders.{$ship}?">
            <remove_value name="global.$GT_MaintenanceOrders.{$ship}"/>
          </do_if>
          <signal_objects object="$ship" param="'GT_Maintenance_Complete'"/>
        </do_else>
      </do_if>

      <do_if value="$maintenanceInFlight or (global.$GT_RepairOrders? and global.$GT_RepairOrders.{$ship}?) or (global.$GT_ResupplyOrders? and global.$GT_ResupplyOrders.{$ship}?)">
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Waiting for maintenance orders to complete (max 900s)...'" chance="100"/>
        </do_if>

        <wait max="900s">
          <interrupt>
            <conditions>
              <event_object_signalled object="$ship" param="'GT_Maintenance_Complete'"/>
            </conditions>
            <actions>
              <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
                <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Maintenance complete signal received'" chance="100"/>
              </do_if>
              <remove_value name="this.$maintenance_transition"/>
            </actions>
          </interrupt>
        </wait>

        <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': Maintenance timeout after 900s, proceeding anyway'" chance="100"/>
        <remove_value name="this.$maintenance_transition"/>
      </do_if>
      <do_else>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[' + $logPrefix + '] ' + $ship.idcode + ': No maintenance needed'" chance="100"/>
        </do_if>
      </do_else>
    </actions>
  </attention>
</aiscript>
