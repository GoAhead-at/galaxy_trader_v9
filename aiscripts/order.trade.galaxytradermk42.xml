<?xml version="1.0" encoding="utf-8"?>
<aiscript name="order.trade.galaxytradermk42" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <order id="GalaxyTraderMK4Supply2" name="{77000, 10007}" description="{77000, 10107}" category="trade" infinite="true" allowinloop="false" canplayercancel="true">
    <params>
      <!-- MK4-2 Galaxy-Supply — UI preview stub (OPEN_GALAXYTRADER_MK4-2_SUPPLY_ORDER.md) -->
      <param name="home" default="this.sector" type="object" text="{77000,1002}" comment="Home anchor (sector or station) for supply operations">
        <input_param name="class" value="[class.sector,class.station]"/>
      </param>
      <param name="assignHome" default="true" type="bool" text="{77000,1085}" comment="When home is a station: assign ship as station trade subordinate"/>
      <param name="jumpDistanceCoverage" default="1" type="number" text="{77000,1086}" comment="{77000,1088}">
        <input_param name="startvalue" value="1"/>
        <input_param name="min" value="1"/>
        <input_param name="max" value="[if (global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly) then 25 else (if (this.ship.pilot? and global.$GT_Pilots? and global.$GT_Pilots.{this.ship.pilot}? and global.$GT_Pilots.{this.ship.pilot}.$Level?) then (if global.$GT_Pilots.{this.ship.pilot}.$Level le 2 then 1 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 5 then 3 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 8 then 5 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 11 then 10 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 13 then 15 else 25) else 1), 1].max"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="jumpDistanceBuy" default="1" type="number" text="{77000,1021}" comment="{77000,1021}">
        <input_param name="startvalue" value="1"/>
        <input_param name="min" value="1"/>
        <input_param name="max" value="[if (global.$GT_GlobalSettings? and global.$GT_GlobalSettings.$XP? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly? and global.$GT_GlobalSettings.$XP.$UseVanillaXPOnly) then 25 else (if (this.ship.pilot? and global.$GT_Pilots? and global.$GT_Pilots.{this.ship.pilot}? and global.$GT_Pilots.{this.ship.pilot}.$Level?) then (if global.$GT_Pilots.{this.ship.pilot}.$Level le 2 then 1 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 5 then 3 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 8 then 5 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 11 then 10 else if global.$GT_Pilots.{this.ship.pilot}.$Level le 13 then 15 else 25) else 1), 1].max"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="serveHomeOnly" default="false" type="bool" text="{77000,1072}" comment="{77000,1089}"/>
      <param name="buyFromPlayer" default="true" type="bool" text="{77000,1073}" comment="Allow purchases from player-owned stations"/>
      <param name="buyFromFaction" default="true" type="bool" text="{77000,1074}" comment="Allow purchases from non-player stations"/>
      <!-- MK4-2 delivery-target priority sliders (0=disabled, 1-10=score multiplier) -->
      <param name="priorityBuildstorage" default="10" type="number" text="{77000,11001}" comment="{77000,11005}">
        <input_param name="startvalue" value="10"/>
        <input_param name="min" value="0"/>
        <input_param name="max" value="10"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="priorityStations" default="8" type="number" text="{77000,11002}" comment="{77000,11005}">
        <input_param name="startvalue" value="8"/>
        <input_param name="min" value="0"/>
        <input_param name="max" value="10"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="priorityAux" default="0" type="number" text="{77000,11003}" comment="{77000,11005}">
        <input_param name="startvalue" value="0"/>
        <input_param name="min" value="0"/>
        <input_param name="max" value="10"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="priorityCarrier" default="0" type="number" text="{77000,11004}" comment="{77000,11005}">
        <input_param name="startvalue" value="0"/>
        <input_param name="min" value="0"/>
        <input_param name="max" value="10"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="prioritywares" default="[]" type="list" text="{77000,1064}" comment="{77000,1066}">
        <input_param name="type" value="'ware'"/>
        <input_param name="cancarry" value="this.ship"/>
      </param>
      <param name="priorityscoremultiplier" default="1" type="number" text="{77000,11007}" comment="{77000,11006}">
        <input_param name="startvalue" value="1"/>
        <input_param name="min" value="1"/>
        <input_param name="max" value="10"/>
        <input_param name="step" value="1"/>
      </param>
      <!-- Ware selection (below delivery-target + ware-priority block) -->
      <param name="allowResources" default="true" type="bool" text="{77000,1076}" comment="Supply resource-class wares"/>
      <param name="allowIntermediates" default="true" type="bool" text="{77000,1077}" comment="Supply intermediate/product wares"/>
      <param name="allowTradewares" default="true" type="bool" text="{77000,1078}" comment="{77000,1090}"/>
      <param name="autowares" default="true" type="bool" text="{77000,1015}" comment="{77000,1023}"/>
      <param name="warebasket" default="[]" type="list" text="{77000,1069}" comment="{77000,1024}">
        <input_param name="type" value="'ware'"/>
        <input_param name="cancarry" value="this.ship"/>
      </param>
      <param name="maxTrades" default="3" type="number" text="{77000,1080}" comment="Chained trade rounds per cycle (cap 3)">
        <input_param name="min" value="1"/>
        <input_param name="max" value="3"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="backtrackTolerance" default="1" type="number" text="{77000,1081}" comment="Extra jumps tolerated when chaining suppliers">
        <input_param name="min" value="0"/>
        <input_param name="max" value="5"/>
        <input_param name="step" value="1"/>
      </param>
      <param name="useMinCargoThreshold" default="false" type="bool" text="{77000,1082}" comment="Enable minimum cargo utilization filter"/>
      <param name="minCargoUsed" default="80" type="number" text="{77000,1082}" comment="Target cargo fill % per chunk">
        <input_param name="min" value="10"/>
        <input_param name="max" value="100"/>
        <input_param name="step" value="5"/>
      </param>
      <param name="playerBuyMod" default="0" type="number" text="{77000,1083}" comment="{77000,1091}">
        <input_param name="min" value="0"/>
        <input_param name="max" value="100"/>
        <input_param name="step" value="5"/>
      </param>
      <param name="allowillegal" default="false" type="bool" text="{77000,1011}" comment="{77000,1025}"/>
      <param name="enforceRouteIllegalLegality" default="false" type="bool" text="{77000,1070}" comment="{77000,1071}"/>
      <param name="ignoretraderules" default="false" type="bool" text="{77000,1058}" comment="{77000,1059}"/>
      <param name="ignoremk1supply" default="true" type="bool" text="{77000,1060}" comment="{77000,1061}"/>
      <param name="logbookentries" default="true" type="bool" text="{77000,1012}" comment="{77000,1041}"/>
      <param name="idleParking" default="false" type="bool" text="{77000,1096}" comment="{77000,1097}"/>
      <param name="autoJumpDistanceByLevel" default="false" type="bool" text="{77000,1098}" comment="{77000,1099}"/>
      <param name="sectorwhitelist" default="[]" type="list" text="{77000,1052}" comment="{77000,1053}">
        <input_param name="type" value="'object'"/>
        <input_param name="class" value="[class.sector]"/>
      </param>
      <param name="debuglevel" default="1" type="number" text="{1041, 10086}" advanced="true" comment="{77000,1035}">
        <input_param name="min" value="0"/>
        <input_param name="max" value="2"/>
        <input_param name="step" value="1"/>
      </param>
    </params>
    <requires>
      <match shiptype="shiptype.lasertower" negate="true"/>
    </requires>
  </order>

  <init>
    <set_order_syncpoint_reached order="this.ship.order"/>
    <set_command_action commandaction="commandaction.standingby"/>
    <show_notification text="{77000,1063}" timeout="8s"/>
  </init>

  <attention min="unknown">
    <actions>
      <label name="mk42_stub_idle"/>
      <set_command_action commandaction="commandaction.standingby"/>
      <wait exact="30s"/>
      <resume label="mk42_stub_idle"/>
    </actions>
  </attention>
</aiscript>
