<?xml version="1.0" encoding="utf-8"?>
<diff>
  <!-- GalaxyTrader MK3: after vanilla create_npc_template, resolve the live crew actor once
       (roleentity, else create_npc_from_template — same pattern as npc_state_machines demotion),
       then fire a single MD signal with LiveCrewPilot. Scratch keeps the exact npctemplate
       because signal tables corrupt uint64 template ids.
       Unassigned has no NPC state-machine case; mark $Stay so ENTER_init goes to STATE_stay
       (vanilla pattern for NPCs that must exist without a worker/marine role). -->
  <replace sel="//aiscript[@name='order.rescue.ship']//do_if[@value='$target.exists and not $target.hascontext.{this.assignedcontrolled} and $targetentity != player.entity']/do_if[@value='this.trueowner == $target.trueowner']/create_npc_template">
    <create_npc_template name="$gt_sar_crew_template" entity="$targetentity" object="this.assignedcontrolled" role="entityrole.unassigned" force="true"/>
    <set_value name="$gt_sar_ship" exact="this.assignedcontrolled"/>
    <set_value name="$gt_sar_stable" exact="''"/>
    <do_if value="global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? and global.$GT_Pilots.{$targetentity}.$StableIdentity?">
      <set_value name="$gt_sar_stable" exact="global.$GT_Pilots.{$targetentity}.$StableIdentity"/>
    </do_if>
    <do_elseif value="$targetentity.seed?">
      <set_value name="$gt_sar_stable" exact="'s:' + $targetentity.seed"/>
    </do_elseif>
    <set_value name="$gt_sar_registry_key" exact="if global.$GT_Pilots? and global.$GT_Pilots.{$targetentity}? then $targetentity else null"/>
    <set_value name="$gt_sar_people_seed" exact="null"/>
    <set_value name="$gt_sar_live" exact="null"/>
    <do_if value="$gt_sar_registry_key and $gt_sar_ship? and $gt_sar_ship.exists and $gt_sar_crew_template?">
      <do_if value="$gt_sar_ship.people.{$gt_sar_crew_template}? and $gt_sar_ship.people.{$gt_sar_crew_template}.exists and $gt_sar_ship.people.{$gt_sar_crew_template}.seed?">
        <set_value name="$gt_sar_people_seed" exact="$gt_sar_ship.people.{$gt_sar_crew_template}.seed"/>
      </do_if>
      <set_value name="$gt_sar_live" exact="$gt_sar_ship.roleentity.{$gt_sar_crew_template}"/>
      <do_if value="not $gt_sar_live.exists">
        <create_npc_from_template name="$gt_sar_live" object="$gt_sar_ship" template="$gt_sar_crew_template" owner="this.trueowner" required="true"/>
      </do_if>
      <do_if value="$gt_sar_live.exists">
        <set_value name="$gt_sar_live.$Stay" exact="true"/>
        <do_if value="not global.$GT_SarCrewTemplateScratch?">
          <set_value name="global.$GT_SarCrewTemplateScratch" exact="table[]"/>
        </do_if>
        <set_value name="global.$GT_SarCrewTemplateScratch.{$gt_sar_ship}" exact="table[
          $Template = $gt_sar_crew_template,
          $PeopleSeed = $gt_sar_people_seed,
          $Stable = $gt_sar_stable
        ]"/>
        <signal_objects object="player.galaxy"
                        param="'gt_sar_pilot_transferred'"
                        param2="table[
                          $StrandedPilot = $targetentity,
                          $RescueShip = $gt_sar_ship,
                          $Spacesuit = $target,
                          $CrewTemplate = $gt_sar_crew_template,
                          $PeopleSeed = $gt_sar_people_seed,
                          $StableIdentity = $gt_sar_stable,
                          $RegistryKeyHint = $gt_sar_registry_key,
                          $LiveCrewPilot = $gt_sar_live
                        ]"/>
      </do_if>
      <do_else>
        <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
          <debug_text text="'[GT-SAR] live crew not ready after create_npc_template/from_template on ' + @$gt_sar_ship.idcode" filter="error"/>
        </do_if>
      </do_else>
    </do_if>
  </replace>
</diff>
