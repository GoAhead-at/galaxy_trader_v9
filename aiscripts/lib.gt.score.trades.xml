<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.score.trades" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../ORIGINAL_MODS_DO NOT_MODIFY/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="tradeList" default="[]"/>
    <param name="debugchance" default="0"/>
    <param name="priorityWares" default="[]" comment="Optional: wares to boost (MK3 Priority Wares). Applied last."/>
    <param name="priorityScoreMultiplier" default="125" comment="Optional: score multiplier for priority wares (125=+25%%, 150=+50%%, 200=2x). Applied last."/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bestTrade" exact="null"/>
      <set_value name="$bestScore" exact="0"/>
      <create_list name="$sortedTrades"/>

      <do_if value="not $tradeList? or $tradeList.count == 0">
        <return value="table[
          $Found = false,
          $BestTrade = null,
          $BestScore = 0,
          $SortedTrades = $sortedTrades
        ]"/>
      </do_if>

      <!-- Apply priority ware score multiplier LAST (after all other scoring).
           Normalize nullable incoming list first (save/load resume safety). -->
      <set_value name="$safePriorityWares" exact="if $priorityWares? and $priorityWares != null then $priorityWares else []"/>
      <set_value name="$hasPriorityWares" exact="$safePriorityWares.count gt 0"/>
      <set_value name="$multPct" exact="if $priorityScoreMultiplier? then $priorityScoreMultiplier else 125"/>
      <do_if value="$multPct lt 125"><set_value name="$multPct" exact="125"/></do_if>
      <do_if value="$multPct gt 300"><set_value name="$multPct" exact="300"/></do_if>
      <set_value name="$mult" exact="$multPct / 100.0"/>

      <do_all exact="$tradeList.count" counter="$i">
        <set_value name="$trade" exact="$tradeList.{$i}"/>
        <set_value name="$baseScore" exact="if $trade.$Score? then $trade.$Score else 0"/>
        <set_value name="$finalScore" exact="$baseScore"/>
        <do_if value="$hasPriorityWares and $trade.$Ware?">
          <set_value name="$isPriority" exact="false"/>
          <do_all exact="$safePriorityWares.count" counter="$pw">
            <do_if value="$safePriorityWares.{$pw} == $trade.$Ware">
              <set_value name="$isPriority" exact="true"/>
              <break/>
            </do_if>
          </do_all>
          <do_if value="$isPriority">
            <set_value name="$finalScore" exact="$baseScore * $mult"/>
          </do_if>
        </do_if>
        <set_value name="$trade.$Score" exact="$finalScore"/>
        <append_to_list name="$sortedTrades" exact="$trade"/>
        <do_if value="$finalScore gt $bestScore">
          <set_value name="$bestScore" exact="$finalScore"/>
          <set_value name="$bestTrade" exact="$trade"/>
        </do_if>
      </do_all>

      <sort_list list="$sortedTrades" sortbyvalue="loop.element.$Score" sortdescending="true"/>

      <return value="table[
        $Found = ($bestTrade != null),
        $BestTrade = $bestTrade,
        $BestScore = $bestScore,
        $SortedTrades = $sortedTrades
      ]"/>
    </actions>
  </attention>
</aiscript>
