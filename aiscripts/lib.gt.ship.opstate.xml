<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.ship.opstate" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    AI entry point for ship operational-state flags (Rerouting, CargoDisposal, NeedsRepair, etc.).
    Signals MD GT_Ship_OpState; flag writes and name refresh live in md.GT_Libraries_General.GT_ShipOpState.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="opState" comment="Registry field: Rerouting, CargoDisposal, Escaping, NeedsRepair, Unreachable, PilotExchange"/>
    <param name="active" default="true" comment="true=set flag, false=clear flag"/>
    <param name="refreshName" default="true" comment="Re-render ship name after a real state change"/>
    <param name="reason" default="''" comment="Optional debug tag"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists or not $opState? or $opState == ''">
        <return/>
      </do_if>

      <signal_objects object="player.galaxy" param="'GT_Ship_OpState'" param2="table[
        $Ship = $ship,
        $opState = $opState,
        $active = $active,
        $refreshName = $refreshName,
        $reason = $reason
      ]"/>
    </actions>
  </attention>
</aiscript>
