<?xml version="1.0" encoding="utf-8"?>
<!-- lib.gt.mk42.free.supplier — one rule for MK4-2 free delivery / free supplier.
     No <wait>: called during SELL/BUY create_trade_order queueing. A yield there lets
     already-queued sell TradePerform run before buys are queued → ERR_NOTHING_TO_SELL.

     PlayerFreeSupplier: buyfree hint OR player-owned buy station / buy-offer owner /
       stamped $PlayerFreeSupplier on the trade.
     FreeDelivery: buyfree on customer sell-offer OR PlayerFreeSupplier.
       NPC supplier + empty customer account still needs funds (caller checks money). -->
<aiscript name="lib.gt.mk42.free.supplier" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <params>
    <param name="buyStation" default="null"/>
    <param name="buyOffer" default="null"/>
    <param name="sellStation" default="null"/>
    <param name="sellOffer" default="null"/>
    <param name="trade" default="null" comment="Optional trade table; reads $BuyStation/$BuyOffer/$PlayerFreeSupplier"/>
    <param name="playerFreeSupplierHint" default="false" comment="Explicit stamp when trade table is unavailable"/>
  </params>
  <attention min="unknown">
    <actions>
      <set_value name="$bs" exact="$buyStation"/>
      <set_value name="$bo" exact="$buyOffer"/>
      <set_value name="$ss" exact="$sellStation"/>
      <set_value name="$so" exact="$sellOffer"/>
      <set_value name="$hint" exact="if $playerFreeSupplierHint? then $playerFreeSupplierHint else false"/>

      <do_if value="$trade? and $trade != null">
        <do_if value="(not $bs? or not @$bs.exists) and $trade.$BuyStation? and @$trade.$BuyStation.exists">
          <set_value name="$bs" exact="$trade.$BuyStation"/>
        </do_if>
        <do_if value="(not $bo? or not @$bo.exists) and $trade.$BuyOffer?">
          <set_value name="$bo" exact="$trade.$BuyOffer"/>
        </do_if>
        <do_if value="(not $ss? or not @$ss.exists) and $trade.$SellStation? and @$trade.$SellStation.exists">
          <set_value name="$ss" exact="$trade.$SellStation"/>
        </do_if>
        <do_if value="(not $so? or not @$so.exists) and $trade.$SellOffer?">
          <set_value name="$so" exact="$trade.$SellOffer"/>
        </do_if>
        <do_if value="$trade.$PlayerFreeSupplier? and $trade.$PlayerFreeSupplier">
          <set_value name="$hint" exact="true"/>
        </do_if>
      </do_if>

      <set_value name="$playerFreeSupplier" exact="false"/>
      <do_if value="$hint">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_if>
      <do_elseif value="$bs? and @$bs.exists and @$bs.isplayerowned">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_elseif>
      <do_elseif value="$bo? and @$bo.exists and $bo.owner? and @$bo.owner.exists and @$bo.owner.isplayerowned">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_elseif>
      <do_elseif value="$bo? and @$bo.exists and $bo.seller? and @$bo.seller.exists and @$bo.seller.isplayerowned">
        <set_value name="$playerFreeSupplier" exact="true"/>
      </do_elseif>

      <set_value name="$freeDelivery" exact="false"/>
      <do_if value="$so? and @$so.exists">
        <do_if value="@$so.buyfree">
          <set_value name="$freeDelivery" exact="true"/>
        </do_if>
        <do_elseif value="$ss? and @$ss.exists and @$so.buyfree.{$ss}">
          <set_value name="$freeDelivery" exact="true"/>
        </do_elseif>
      </do_if>
      <do_if value="not $freeDelivery and $playerFreeSupplier">
        <set_value name="$freeDelivery" exact="true"/>
      </do_if>

      <return value="table[
        $PlayerFreeSupplier = $playerFreeSupplier,
        $FreeDelivery = $freeDelivery
      ]"/>
    </actions>
  </attention>
</aiscript>
