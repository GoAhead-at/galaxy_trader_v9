<?xml version="1.0" encoding="utf-8"?>
<diff xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <add sel="/wares">
    <!-- GT Ship Modifications - Level 1 -->
    <!-- NOTE: These modifications are GT-only and automatically installed by the GalaxyTrader system. -->
    <!-- They are not available for purchase, crafting, or manual installation by players. -->
    <ware id="mod_ship_gt_level1" name="Consortium Standard Refinement" description="Trade Consortium Standard Refinement - A basic structural enhancement that reduces hull mass and improves sensor range. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="5000" average="7500" max="10000" />
    </ware>
    <ware id="mod_engine_gt_level1" name="Consortium Standard Maneuverability" description="Trade Consortium Standard Maneuverability - A standard thruster upgrade package that enhances ship rotation and strafing capabilities. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="5000" average="7500" max="10000" />
    </ware>

    <!-- GT Ship Modifications - Level 2 -->
    <ware id="mod_ship_gt_level2" name="Consortium Rare Enhancement" description="Trade Consortium Rare Enhancement - An advanced structural modification that significantly reduces hull mass and dramatically improves sensor range. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="10000" average="15000" max="20000" />
    </ware>
    <ware id="mod_engine_gt_level2" name="Consortium Rare Thruster System" description="Trade Consortium Rare Thruster System - A rare thruster enhancement that provides exceptional rotation and strafing performance. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="10000" average="15000" max="20000" />
    </ware>

    <!-- GT Ship Modifications - Level 3 -->
    <ware id="mod_ship_gt_level3" name="Consortium Lost Technology" description="Trade Consortium Lost Technology - Legendary structural refinement recovered from the lost Consortium ship. Provides exceptional mass reduction and sensor range improvements. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="20000" average="30000" max="40000" />
    </ware>
    <ware id="mod_engine_gt_level3" name="Consortium Lost Propulsion Technology" description="Trade Consortium Lost Propulsion Technology - Legendary thruster system recovered from the lost Consortium ship. Provides unmatched rotation and strafing capabilities. (GT System Only - Not Available for Manual Installation)" transport="inventory" volume="1" tags="equipmentmod noplayerblueprint">
      <price min="20000" average="30000" max="40000" />
    </ware>

    <!-- Trade Consortium research (sortorder 305 = after vanilla mod research 301-304, before SETA/time compression 306).
         Same hundreds bucket as welfare (305) so no menu separator from vanilla mods.
         Exclusive GT gate for bonus ship/engine mods. No vanilla research_mod_* dependency.
         Tier 3 wares = High-mass Teleportation I -20%, nividium x2; T2=T3/4, T1=T3/16. -->
    <ware id="research_gt_consortium_mod_mk1" name="{77000,9601}" description="{77000,9602}" transport="research" volume="1" tags="research" sortorder="305">
      <price min="1" average="1" max="1" />
      <research time="600">
        <primary>
          <ware ware="nividium" amount="100" />
          <ware ware="advancedelectronics" amount="500" />
          <ware ware="energycells" amount="625" />
          <ware ware="fieldcoils" amount="250" />
          <ware ware="superfluidcoolant" amount="400" />
        </primary>
      </research>
    </ware>
    <ware id="research_gt_consortium_mod_mk2" name="{77000,9603}" description="{77000,9604}" transport="research" volume="1" tags="research" sortorder="305">
      <price min="1" average="1" max="1" />
      <research time="900">
        <primary>
          <ware ware="nividium" amount="400" />
          <ware ware="advancedelectronics" amount="2000" />
          <ware ware="energycells" amount="2500" />
          <ware ware="fieldcoils" amount="1000" />
          <ware ware="superfluidcoolant" amount="1600" />
        </primary>
        <research>
          <ware ware="research_gt_consortium_mod_mk1" />
        </research>
      </research>
    </ware>
    <ware id="research_gt_consortium_mod_mk3" name="{77000,9605}" description="{77000,9606}" transport="research" volume="1" tags="research" sortorder="305">
      <price min="1" average="1" max="1" />
      <research time="1200">
        <primary>
          <ware ware="nividium" amount="1600" />
          <ware ware="advancedelectronics" amount="8000" />
          <ware ware="energycells" amount="10000" />
          <ware ware="fieldcoils" amount="4000" />
          <ware ware="superfluidcoolant" amount="6400" />
        </primary>
        <research>
          <ware ware="research_gt_consortium_mod_mk2" />
        </research>
      </research>
    </ware>
  </add>
</diff>
