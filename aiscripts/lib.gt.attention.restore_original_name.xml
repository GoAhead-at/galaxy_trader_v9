<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.restore_original_name" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Emits `GT_Ship_Order_Aborted` with the pilot's `$OriginalShipName` payload
    so the MD-side name-restoration handler can revert the ship's GT-flavored
    name back to the player's original.

    No-ops (returns `false`) when:
      - ship has no pilot
      - pilot is not tracked in `global.$GT_Pilots`
      - pilot has no `$OriginalShipName` recorded
      - ship is still GT-controlled directly OR via a GT commander (caller
        decides via `skipIfStillGT`; when true, the GT-controlled check is
        applied here using lib.gt.attention.is_gt_commander)

    Returns `true` if the signal was emitted, `false` otherwise.

    Replaces 3 near-identical inline blocks in MK3 init / main_loop / Phase 7,
    and 3 more in MK4. Each duplicated the GT_Pilots lookup, OriginalShipName
    extraction, and signal_objects payload. See DOCS/MK3_PIPELINE_REFACTOR.md §3.11.
  -->
  <params>
    <param name="ship" default="this.ship"/>
    <param name="reason" default="'GT order cancelled - restoring original name'"/>
    <param name="skipIfStillGT" default="true"/>
    <param name="validOrderIds" default="['GalaxyTraderMK3']"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="not $ship? or not @$ship.exists or not $ship.pilot?">
        <return value="false"/>
      </do_if>

      <!-- Optional safety: don't restore the name if the ship is still GT-controlled
           (either via direct order or via a GT commander). The caller pre-decides
           this in some sites, but doing it here too keeps every call site honest. -->
      <do_if value="$skipIfStillGT">
        <set_value name="$hasDirectGTOrder" exact="false"/>
        <do_if value="$ship.defaultorder? and $validOrderIds? and $validOrderIds.indexof.{@$ship.defaultorder.id}">
          <set_value name="$hasDirectGTOrder" exact="true"/>
        </do_if>
        <do_if value="$hasDirectGTOrder">
          <return value="false"/>
        </do_if>
        <do_if value="$ship.commander? and $ship.commander.exists and $ship.commander != $ship">
          <run_script name="'lib.gt.attention.is_gt_commander'" result="$cmdrIsGT">
            <param name="commander" value="$ship.commander"/>
            <param name="validOrderIds" value="$validOrderIds"/>
          </run_script>
          <do_if value="$cmdrIsGT">
            <return value="false"/>
          </do_if>
        </do_if>
      </do_if>

      <do_if value="not global.$GT_Pilots? or not global.$GT_Pilots.{$ship.pilot}? or not global.$GT_Pilots.{$ship.pilot}.$OriginalShipName?">
        <return value="false"/>
      </do_if>
      <set_value name="$originalName" exact="global.$GT_Pilots.{$ship.pilot}.$OriginalShipName"/>
      <do_if value="not $originalName? or $originalName == null">
        <return value="false"/>
      </do_if>

      <signal_objects object="player.galaxy" param="'GT_Ship_Order_Aborted'" param2="table[
        $Ship = $ship,
        $Pilot = $ship.pilot,
        $Reason = $reason,
        $OriginalName = $originalName
      ]"/>
      <do_if value="@global.$GT_GlobalSettings.$Debug.$EnableDebugLogging">
        <debug_text text="'[GT-AI] Name restoration signal sent for ' + $ship.idcode + ' (reason: ' + $reason + ', original name: ' + $originalName + ')'" chance="100"/>
      </do_if>
      <return value="true"/>
    </actions>
  </attention>
</aiscript>
