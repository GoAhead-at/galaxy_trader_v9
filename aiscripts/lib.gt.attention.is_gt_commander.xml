<?xml version="1.0" encoding="utf-8"?>
<aiscript name="lib.gt.attention.is_gt_commander" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../stock_game/X4 Foundations/libraries/aiscripts.xsd" version="1">
  <!--
    Returns `true` if `commander` is a GalaxyTrader-controlled commander, i.e.
    its `defaultorder.id` matches one of `validOrderIds`, OR it is running the
    vanilla `Assist` order over a GalaxyTrader baseorder (whose id matches
    `validOrderIds`). Returns `false` for `null`, deleted, or non-GT commanders.

    The (`order == X` OR (`order == 'Assist'` AND `baseorder == X`)) check was
    copy-pasted ~9 times across `init`, `main_loop`, the Phase 6 commander-delta
    branches, the subordinate orphan check, and Phase 7 name-restoration logic
    in MK3 (and again in MK4 with `'GalaxyTraderMK4Supply'` added). Centralizing
    here also guarantees that future GalaxyTrader order variants only need to
    extend `validOrderIds` in one place. See DOCS/MK3_PIPELINE_REFACTOR.md §3.11.
  -->
  <params>
    <param name="commander" default="null"/>
    <param name="validOrderIds" default="['GalaxyTraderMK3']"/>
  </params>
  <attention min="unknown">
    <actions>
      <do_if value="$commander? and @$commander.exists and $commander.defaultorder?">
        <do_if value="$validOrderIds? and $validOrderIds.indexof.{@$commander.defaultorder.id}">
          <return value="true"/>
        </do_if>
        <do_if value="@$commander.defaultorder.id == 'Assist' and $commander.defaultorder.$baseorder? and $validOrderIds? and $validOrderIds.indexof.{@$commander.defaultorder.$baseorder.id}">
          <return value="true"/>
        </do_if>
      </do_if>
      <return value="false"/>
    </actions>
  </attention>
</aiscript>
